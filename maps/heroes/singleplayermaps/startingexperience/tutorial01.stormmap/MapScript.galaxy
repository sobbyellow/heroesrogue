void gf_HookupRegionData () {
    // Automatic Variable Declarations
    // Implementation
    libMapM_gf_MapSetRepulseRegion(libGame_gv_teamOrderIndex_C, RegionFromId(19), PointFromId(24), PointFromId(15), PointFromId(41), null);
    libMapM_gf_MapSetRepulseRegion(libGame_gv_teamChaosIndex_C, RegionFromId(14), PointFromId(40), PointFromId(394), PointFromId(623), null);
    libMapM_gf_MapSetSafeRegion(libGame_gv_teamOrderIndex_C, RegionFromId(19));
    libMapM_gf_MapSetSafeRegion(libGame_gv_teamChaosIndex_C, RegionFromId(14));
}

//--------------------------------------------------------------------------------------------------
// Trigger: Initialize Map
//--------------------------------------------------------------------------------------------------
bool gt_InitializeMap_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    gv_golemStartsOrderTop = (RandomInt(1, 2) == 1);
    libMHtM_gv_mMHM_OrderBossGoesTopLane = gv_golemStartsOrderTop;
    TriggerExecute(libAIAI_gt_IncludeAI, true, false);
    TriggerExecute(libGame_gt_IncludeGame, true, false);
    TriggerExecute(libGDHL_gt_IncludeGameDataHelper, true, false);
    TriggerExecute(libMapM_gt_IncludeMapMechanics, true, false);
    TriggerExecute(libSond_gt_IncludeSound, true, false);
    TriggerExecute(libSprt_gt_IncludeSupport, true, false);
    TriggerExecute(libUIUI_gt_IncludeUI, true, false);
    gf_HookupGlobalVariables();
    gf_HookupLaneData();
    gf_HookupJungleCreepData();
    gf_HookupTownData();
    gf_HookupRegionData();
    libMapM_gf_MapMechanicAdd("HauntedMinesRework", gt_InitializeMapMechanic);
    libMHtM_gf_MMHMInitializeHauntedMinesMercData();
    libCore_gv_sYSGameMode = libCore_ge_GameModes_Sandbox;
    libCore_gv_sYSTowns = true;
    libCore_gv_sYSJungleCreepCamps = true;
    libCore_gv_sYSJungleWatchTowers = true;
    libCore_gv_sYSTowerAI = true;
    libCore_gv_sYSMinionAI = true;
    TriggerExecute(libCore_gt_InitializeStormMod, true, true);
    libCore_gf_DataAnnouncerVOSetDefaultAnnouncerForPlayerGroup(PlayerGroupAll(), "Necromancer");
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_InitializeMap_Init () {
    gt_InitializeMap = TriggerCreate("gt_InitializeMap_Func");
    TriggerAddEventMapInit(gt_InitializeMap);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Initialize Map Mechanic
//--------------------------------------------------------------------------------------------------
bool gt_InitializeMapMechanic_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_indexPlayer;

    // Automatic Variable Declarations
    const int auto0603EF1B_ae = libCore_gv_bALMaxPlayers;
    const int auto0603EF1B_ai = 1;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    libMHtM_gv_mMUnderworldGatesAbove = UnitGroupEmpty();
    libMHtM_gv_mMUnderworldGatesBelow = UnitGroupEmpty();
    UnitGroupAdd(libMHtM_gv_mMUnderworldGatesAbove, UnitFromId(1047275310));
    libMHtM_gv_gatesAbovePositions[1] = UnitGetPosition(UnitFromId(1047275310));
