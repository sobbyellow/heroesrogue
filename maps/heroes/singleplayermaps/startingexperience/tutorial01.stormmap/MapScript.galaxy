//--------------------------------------------------------------------------------------------------
bool gt_RestrictAbilitiestoOverworld_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_eventUnit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_eventUnit = EventUnit();

    // Conditions
    if (testConds) {
        if (!((libGame_gf_UnitIsHero(lv_eventUnit) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    libMapM_gf_RestrictAbilitiesToRegionForUnit(lv_eventUnit, RegionFromId(48));
    libMHtM_gf_MMUnderworldChangePlaneForUnit(lv_eventUnit, libMHtM_ge_MMHM_GroundPlane_AboveGround);
    return true;
}

