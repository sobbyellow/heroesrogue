//--------------------------------------------------------------------------------------------------
// Trigger: No Projectile Between Planes
//--------------------------------------------------------------------------------------------------
bool gt_NoProjectileBetweenPlanes_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_eventUnit;
    string lv_unitTypeOfEventUnit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_eventUnit = EventUnit();
    lv_unitTypeOfEventUnit = UnitGetType(lv_eventUnit);

    // Conditions
    if (testConds) {
        if (!((UnitFilterMatch(lv_eventUnit, EventPlayer(), UnitFilter((1 << c_targetFilterMissile), 0, 0, (1 << (c_targetFilterDead - 32)))) == true))) {
            return false;
        }

        if (!((lv_unitTypeOfEventUnit != "SgtHammerBluntForceGunMissile"))) {
            return false;
        }

        if (!((lv_unitTypeOfEventUnit != "SgtHammerBluntForceGunMissileOrbital"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitKill(lv_eventUnit);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_NoProjectileBetweenPlanes_Init () {
    gt_NoProjectileBetweenPlanes = TriggerCreate("gt_NoProjectileBetweenPlanes_Func");
    TriggerAddEventUnitRegion(gt_NoProjectileBetweenPlanes, null, RegionFromId(38), true);
}

