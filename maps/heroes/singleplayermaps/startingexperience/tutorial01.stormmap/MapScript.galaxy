        if (((DistanceBetweenPoints(lv_posOfEventUnit, libMHtM_gv_gatesAbovePositions[lv_i]) + DistanceBetweenPoints(libMHtM_gv_gatesBelowPositions[lv_i], lv_eventOrderPoint)) < (DistanceBetweenPoints(lv_posOfEventUnit, libMHtM_gv_gatesAbovePositions[lv_closestGate]) + DistanceBetweenPoints(libMHtM_gv_gatesBelowPositions[lv_closestGate], lv_eventOrderPoint)))) {
