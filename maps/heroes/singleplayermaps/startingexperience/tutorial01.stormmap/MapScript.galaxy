        lv_orderQueue[lv_i] = UnitOrder(lv_eventUnit, lv_i);
        lv_orderCount += 1;
    }
    UnitIssueOrder(lv_eventUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
    if ((UnitAbilityExists(lv_eventUnit, "CaptureMacGuffin") == false)) {
        return true;
    }

    UnitIssueOrder(lv_eventUnit, OrderTargetingUnit(AbilityCommand("CaptureMacGuffin", 0), libMHtM_gv_gatesAbove[lv_closestGate]), c_orderQueueAddToEnd);
    UnitIssueOrder(lv_eventUnit, OrderTargetingPoint(EventUnitAbility(), lv_eventOrderPoint), c_orderQueueAddToEnd);
    auto50373D97_ae = lv_orderCount;
    lv_i = 1;
    for ( ; ( (auto50373D97_ai >= 0 && lv_i <= auto50373D97_ae) || (auto50373D97_ai < 0 && lv_i >= auto50373D97_ae) ) ; lv_i += auto50373D97_ai ) {
