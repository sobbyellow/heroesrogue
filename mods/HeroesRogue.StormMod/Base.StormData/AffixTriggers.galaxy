// ---------------------------------------------------------------
// Backdoor Protection
// ---------------------------------------------------------------
bool libAffx_BackdoorProtection (bool testConds, bool runActions) {
    int fortCount;
    if (!runActions) {
        return true;
    }
    fortCount = UnitCount("TownTownHallL2", libAffx_teamChaos, RegionEntireMap(), libCore_gv_filtersStructure, 0);

    libAffx_AddBehaviorAllUnitsFilter("AffixBackdoorProtection", libCore_gv_filtersStructure, libAffx_teamChaos, "TownCannonTowerL3", fortCount);
    libAffx_AddBehaviorAllUnitsFilter("AffixBackdoorProtection", libCore_gv_filtersStructure, libAffx_teamChaos, "TownTownHallL3", fortCount);

    return true;
}
bool libAffx_BackdoorProtectionUnitDied (bool testConds, bool runActions) {
    unit dyingStructure;
    int townIndex;
    int victimTeam;
    int town;

    dyingStructure = EventUnit();

    if (testConds) {
        if (!UnitTypeTestAttribute(UnitGetType(dyingStructure), c_unitAttributeStructure)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    townIndex = libGame_gf_TownGetTownForUnit(dyingStructure);
    victimTeam = libGame_gf_TeamNumberOfPlayer(UnitGetOwner(dyingStructure));
    if (UnitGetType(dyingStructure) == "TownTownHallL2" && victimTeam == libGame_gv_teamChaosIndex_C) {
        libAffx_RemoveBehaviorAllUnitsFilter("AffixBackdoorProtection", libCore_gv_filtersStructure, libAffx_teamChaos, "TownCannonTowerL3", 1);
        libAffx_RemoveBehaviorAllUnitsFilter("AffixBackdoorProtection", libCore_gv_filtersStructure, libAffx_teamChaos, "TownTownHallL3", 1);
    }

    return true;
}
