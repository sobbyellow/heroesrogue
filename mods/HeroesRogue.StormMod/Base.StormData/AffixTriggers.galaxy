// ---------------------------------------------------------------
// Talent Disadvantage
// ---------------------------------------------------------------
int talentDisadvantageIndex;
bool[21] talentDisadvantageApplied;
void libAffx_ApplyTalentDisadvantage(int player, int level) {
    string hero = libCore_gf_GetHeroFromIndex(libAffx_playersHeroIndex[player]);
    unit heroUnit = libGame_gv_players[player].lv_heroUnit;
    int levelAdjustment = 0;
    if (level <= 0 || level > 20) {
        return;
    }
    if (talentDisadvantageApplied[level]) {
        return;
    }

    if (hero == "Chromie") {
        levelAdjustment = -2;
    }
    if (level == 1 && libAffx_affixes[talentDisadvantageIndex].count >= 1) {
        if (hero == "WitchDoctor") {
            libGame_gf_TalentsChooseTalentForPlayer(1, 1, player);
            libGame_gf_TalentsChooseTalentForPlayer(1, 2, player);
            libGame_gf_TalentsChooseTalentForPlayer(1, 3, player);
        } else {
            libGame_gf_TalentsChooseTalentForPlayer(1, 1, player);
            libGame_gf_TalentsChooseTalentForPlayer(1, 2, player);
            libGame_gf_TalentsChooseTalentForPlayer(1, 3, player);
            libGame_gf_TalentsChooseTalentForPlayer(1, 4, player);
            libGame_gf_TalentsChooseTalentForPlayer(1, 5, player);
        }
    } else if (level == (4 + levelAdjustment) && libAffx_affixes[talentDisadvantageIndex].count >= 2 && hero != "Varian" && UnitGetType(heroUnit) != "HeroVarian") {
        if (hero == "WitchDoctor") {
            libGame_gf_TalentsChooseTalentForPlayer(2, 1, player);
            libGame_gf_TalentsChooseTalentForPlayer(2, 2, player);
            libGame_gf_TalentsChooseTalentForPlayer(2, 3, player);
        } else {
            libGame_gf_TalentsChooseTalentForPlayer(2, 1, player);
            libGame_gf_TalentsChooseTalentForPlayer(2, 2, player);
            libGame_gf_TalentsChooseTalentForPlayer(2, 3, player);
            libGame_gf_TalentsChooseTalentForPlayer(2, 4, player);
            libGame_gf_TalentsChooseTalentForPlayer(2, 5, player);
        }
    } else if ((level == (7 + levelAdjustment) && libAffx_affixes[talentDisadvantageIndex].count >= 3) || (level == (7 + levelAdjustment) && libAffx_affixes[talentDisadvantageIndex].count >= 2 && hero == "Varian")) {
        if (hero == "WitchDoctor") {
            libGame_gf_TalentsChooseTalentForPlayer(3, 1, player);
            libGame_gf_TalentsChooseTalentForPlayer(3, 2, player);
            libGame_gf_TalentsChooseTalentForPlayer(3, 3, player);
        } else {
            libGame_gf_TalentsChooseTalentForPlayer(3, 1, player);
            libGame_gf_TalentsChooseTalentForPlayer(3, 2, player);
            libGame_gf_TalentsChooseTalentForPlayer(3, 3, player);
            libGame_gf_TalentsChooseTalentForPlayer(3, 4, player);
            libGame_gf_TalentsChooseTalentForPlayer(3, 5, player);
        }
    } else if (level == (10 + levelAdjustment) && libAffx_affixes[talentDisadvantageIndex].count >= 3 && hero == "Varian") {
        libGame_gf_TalentsChooseTalentForPlayer(4, 1, player);
        libGame_gf_TalentsChooseTalentForPlayer(4, 2, player);
        libGame_gf_TalentsChooseTalentForPlayer(4, 3, player);
        libGame_gf_TalentsChooseTalentForPlayer(4, 4, player);
        libGame_gf_TalentsChooseTalentForPlayer(4, 5, player);
    } else if (level == (13 + levelAdjustment) && libAffx_affixes[talentDisadvantageIndex].count >= 4) {
        libGame_gf_TalentsChooseTalentForPlayer(5, 1, player);
        libGame_gf_TalentsChooseTalentForPlayer(5, 2, player);
        libGame_gf_TalentsChooseTalentForPlayer(5, 3, player);
        libGame_gf_TalentsChooseTalentForPlayer(5, 4, player);
        libGame_gf_TalentsChooseTalentForPlayer(5, 5, player);
    } else if (level == (16 + levelAdjustment) && libAffx_affixes[talentDisadvantageIndex].count >= 5) {
        if (hero == "WitchDoctor") {
            libGame_gf_TalentsChooseTalentForPlayer(6, 1, player);
            libGame_gf_TalentsChooseTalentForPlayer(6, 2, player);
            libGame_gf_TalentsChooseTalentForPlayer(6, 3, player);
        } else {
            libGame_gf_TalentsChooseTalentForPlayer(6, 1, player);
            libGame_gf_TalentsChooseTalentForPlayer(6, 2, player);
            libGame_gf_TalentsChooseTalentForPlayer(6, 3, player);
            libGame_gf_TalentsChooseTalentForPlayer(6, 4, player);
            libGame_gf_TalentsChooseTalentForPlayer(6, 5, player);
        }
    } else if (level == (20 + levelAdjustment) && libAffx_affixes[talentDisadvantageIndex].count >= 6) {
        libGame_gf_TalentsChooseTalentForPlayer(7, 1, player);
        libGame_gf_TalentsChooseTalentForPlayer(7, 2, player);
        libGame_gf_TalentsChooseTalentForPlayer(7, 3, player);
        libGame_gf_TalentsChooseTalentForPlayer(7, 4, player);
        libGame_gf_TalentsChooseTalentForPlayer(7, 5, player);
    }
    talentDisadvantageApplied[level] = true;
}
bool libAffx_TalentDisadvantageAffixAdded (bool testConds, bool runActions) {
    int i;
    int total = libAffx_EventAffixCount();
    if (!runActions) {
        return true;
    }
    talentDisadvantageIndex = libAffx_EventAffix();
    return true;
}
bool libAffx_TalentDisadvantageExecute (bool testConds, bool runActions) {
    int i;
    if (!runActions) {
        return true;
    }
    for (i = 6; i <= 10; i += 1) {
        libAffx_ApplyTalentDisadvantage(i, UnitLevel(libGame_gv_players[i].lv_heroUnit));
    }
    return true;
}
bool libAffx_TalentDisadvantageLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player < 6 || player > 10) {
            return false;
        }
        if (talentDisadvantageIndex == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_ApplyTalentDisadvantage(player, UnitLevel(libGame_gv_players[player].lv_heroUnit));
    return true;
}
