int trappedIndex;
int trappedMineCount;
bool libAffx_TrappedExecuteOncePerGame (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libGame_AddAbilityEffectMapping("AbathurToxicNest", "ToxicNestDamage");

    return true;
}
bool libAffx_TrappedExecute (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_CatalogFieldValueSetFixed(c_gameCatalogEffect, "ToxicNestDamage", "Amount", libAffx_teamChaos, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "ToxicNestDamage", "Amount", 0)) * Pow(1.04, UnitLevel(libGame_gv_players[6].lv_heroUnit)));

    return true;
}
bool libAffx_TrappedAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    trappedIndex = libAffx_EventAffix();
    trappedMineCount = 2 * libAffx_EventAffixCount();
    return true;
}
bool libAffx_TrappedPeriodic (bool testConds, bool runActions) {
    int i;
    int random;
    point trapPoint;
    int trapAmount;
    if (testConds) {
        if (!libAffx_GateIsOpen() || libAffx_gamePaused) {
            return false;
        }
        if (trappedIndex == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    trapAmount = 2 * libAffx_affixes[trappedIndex].count;
    for (i = 1; i <= trapAmount; i += 1) {
        trapPoint = RegionRandomPoint(RegionEntireMap());
        random = RandomInt(1, 100);
        UnitCreateEffectPoint(libGame_gv_teams[libAffx_teamChaosIndex].lv_core, "AbathurToxicNestInitialSet", trapPoint);
    }
    return true;
}
bool libAffx_TrappedLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player != libAffx_enemy) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_CatalogFieldValueSetFixed(c_gameCatalogEffect, "ToxicNestDamage", "Amount", libAffx_teamChaos, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "ToxicNestDamage", "Amount", 0)) * Pow(1.04, level));

    return true;
}
// ---------------------------------------------------------------
// Resurgence of the Storm
// ---------------------------------------------------------------
fixed resurgenceoftheStormCooldown = 300;
bool libAffx_ResurgenceoftheStormAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    resurgenceoftheStormIndex = libAffx_EventAffix();
    resurgenceoftheStormCooldown = 300 - (60 * (libAffx_EventAffixCount() - 1));
    return true;
}
bool libAffx_ResurgenceoftheStormHeroKilled (bool testConds, bool runActions) {
    unit deadUnit = libGame_gf_HeroKilledUnit();
    int deadPlayer = libGame_gf_HeroKilledPlayer();
    fixed lifeModifier;

    if (testConds) {
        if (resurgenceoftheStormIndex == 0) {
            return false;
        }
        if (deadPlayer != libAffx_player || libAffx_affixes[resurgenceoftheStormIndex].cooldown > 0) {
            return false;
        }
        if (deadUnit != libGame_gv_players[libAffx_player].lv_heroUnit) {
            return false;
        }
        if (libGame_diabloUsedSouls[libAffx_player]) {
            return false;
        }
        if (UnitGetType(deadUnit) == "HeroMurky" && !((UnitIsAlive(libGame_gv_heroDeathMurkyRespawnEggs[deadPlayer]) == false) || (libGame_gv_heroDeathMurkyRespawnEggs[deadPlayer] == null))) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    libGame_gv_players[libAffx_player].lv_suppressReviveVOSound = true;
    libAffx_affixes[resurgenceoftheStormIndex].cooldown = resurgenceoftheStormCooldown;
    libGame_gf_HeroDeathUpdateRespawnTimer(libAffx_player, 5);
    if (UnitGetType(deadUnit) == "HeroLeoric") {
        UnitBehaviorSetDuration(deadUnit, "LeoricUndying", TimerGetRemaining(libGame_gv_players[deadPlayer].lv_respawnTimer));
        UnitBehaviorSetDuration(deadUnit, "Dead", TimerGetRemaining(libGame_gv_players[deadPlayer].lv_respawnTimer));
        libGDHL_gv_hero_Leoric_Undying_Dead_Duration[deadPlayer] = UnitBehaviorDurationTotal(deadUnit, "LeoricUndying");
        CatalogFieldValueSetFixed(c_gameCatalogEffect, "LeoricUndyingLifeRegenModifyUnit", "VitalArray[" + IntToString(0) + "].ChangeFraction", deadPlayer, (0.5 / (libGDHL_gv_hero_Leoric_Undying_Dead_Duration[deadPlayer])));
    }
    return true;
}
bool libAffx_ResurgenceoftheStormP (bool testConds, bool runActions) {
    if (testConds) {
        if (resurgenceoftheStormIndex == 0 ) {
            return false;
        }
        if (libAffx_gamePaused || libAffx_affixes[resurgenceoftheStormIndex].cooldown <= 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    libAffx_affixes[resurgenceoftheStormIndex].cooldown -= 0.0625;

    return true;
}
// ---------------------------------------------------------------
// Bribery
// ---------------------------------------------------------------
int briberyIndex;
fixed briberyCooldown;
bool libAffx_BriberyAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    briberyIndex = libAffx_EventAffix();
    briberyCooldown = 300 - (libAffx_EventAffixCount() - 1) * 60;
    return true;
}
bool libAffx_BriberyP (bool testConds, bool runActions) {
    int i;
    int i2;
    int unitCount;
    int campType;
    if (testConds) {
        if (libAffx_gamePaused) {
            return false;
        }
        if (briberyIndex == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    if (libAffx_affixes[briberyIndex].cooldown > 0) {
        libAffx_affixes[briberyIndex].cooldown -= 0.0625;
    } else {
        for (i = 1; i <= libMapM_gv_jungleMaxCamps; i += 1) {
            campType = libMapM_gv_jungleCreepCamps[i].lv_mapDataCampDefenderType;
            if (campType == libMapM_ge_JungleCampDefenderTypes_GraveGolem || campType == libMapM_ge_JungleCampDefenderTypes_BossCamp1 || campType == libMapM_ge_JungleCampDefenderTypes_BossCamp2 || campType == libMapM_ge_JungleCampDefenderTypes_BossCamp3) {
                continue;
            }
            unitCount = UnitGroupCount(libMapM_gv_jungleCreepCamps[i].lv_defenderUnitGroup, c_unitCountAlive);
            if (unitCount > 0 && !libNtve_gf_UnitIsInvulnerable(UnitGroupUnit(libMapM_gv_jungleCreepCamps[i].lv_defenderUnitGroup, 1)) && !UnitHasBehavior2(UnitGroupUnit(libMapM_gv_jungleCreepCamps[i].lv_defenderUnitGroup, 1), "JungleMercDefenderBirthInvulnerability") && libAffx_affixes[briberyIndex].cooldown <= 0) {
                libAffx_affixes[briberyIndex].cooldown = briberyCooldown;
                for (i2 = unitCount; i2 > 0; i2 -= 1) {
                    UnitCreateEffectUnit(libGame_gv_players[libAffx_player].lv_heroUnit, "BribeSetAffix", UnitGroupUnitFromEnd(libMapM_gv_jungleCreepCamps[i].lv_defenderUnitGroup, i2));
                }
                libMapM_gv_jungleCreepCamps[i].customRespawnTime = libMapM_gv_jungleCreepCamps[i].lv_defenderRespawnTime / 2;
                Wait(0.125, c_timeGame);
                libGame_gv_capturePoints[libMapM_gv_jungleCreepCamps[i].lv_captureCapturePointIndex].lv_captureCounter = 999;
            }
        }
        Wait(1, c_timeGame);
    }

    return true;
}
