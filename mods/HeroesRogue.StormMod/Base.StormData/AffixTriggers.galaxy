// ---------------------------------------------------------------
// All Talents
// ---------------------------------------------------------------

bool[11][21] allTalentsApplied;
void libAffx_PickAllTalents(int player, int tier) {
    if (allTalentsApplied[player][tier]) {
        return;
    }
    if (player == libAffx_choPlayer || player == libAffx_gallPlayer) {
        libGame_gf_TalentsChooseTalentForPlayer(tier, 1, libAffx_gallPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 2, libAffx_gallPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 3, libAffx_gallPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 4, libAffx_gallPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 5, libAffx_gallPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 1, libAffx_choPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 2, libAffx_choPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 3, libAffx_choPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 4, libAffx_choPlayer);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 5, libAffx_choPlayer);
        allTalentsApplied[player][tier] = true;
    } else { 
        libGame_gf_TalentsChooseTalentForPlayer(tier, 1, player);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 2, player);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 3, player);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 4, player);
        libGame_gf_TalentsChooseTalentForPlayer(tier, 5, player);
        allTalentsApplied[player][tier] = true;
    }
}
void libAffx_ApplyAllTalents(int level) {
    int levelAdjustment = 0;
    int player = libAffx_player;
    string hero = libCore_gf_GetHeroFromIndex(libAffx_playersHeroIndex[libAffx_player]);
    if (level <= 0) {
        return;
    }
    if (hero == "Chromie") {
        levelAdjustment = -2;
    }
    if (level == 1) {
        libAffx_PickAllTalents(player, 1);
    } else if (level == (4 + levelAdjustment) && hero != "Varian") {
        libAffx_PickAllTalents(player, 2);
    } else if (level == (7 + levelAdjustment)) {
        libAffx_PickAllTalents(player, 3);
    } else if (level == (10 + levelAdjustment) && hero == "Varian") {
        libAffx_PickAllTalents(player, 4);
    } else if (level == (13 + levelAdjustment)) {
        libAffx_PickAllTalents(player, 5);
    } else if (level == (16 + levelAdjustment)) {
        libAffx_PickAllTalents(player, 6);
    } else if (level == (20 + levelAdjustment)) {
        libAffx_PickAllTalents(player, 7);
    }
}
bool libAffx_AllTalentsExecute (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_ApplyAllTalents(UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit));
    return true;
}
bool libAffx_AllTalentsAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    return true;
}
bool libAffx_AllTalentsLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_ApplyAllTalents(UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit));
    return true;
}
// ---------------------------------------------------------------
// All Stats Self
// ---------------------------------------------------------------
bool libAffx_AffixAllStatsSelfBehaviorChange (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    while ((UnitHasBehavior2(EventUnit(), "AffixAllStatsSelf") == true)) {
        while ((UnitHasBehaviorWithCategoryFlag(EventUnit(), c_behaviorCategoryTimeStop) == true) || libAffx_gamePaused) {
            Wait(0.0625, c_timeGame);
        }
        libGame_gf_StormUniversalModifyCooldownonUnitCDRforAbilities(EventUnit(), -(0.5 / 16), false, false, false);
        Wait(0.0625, c_timeGame);
    }
    return true;
}
// ---------------------------------------------------------------
// Legally Blind
// ---------------------------------------------------------------
bool libAffx_LegallyBlindBehaviorChangeCategory (bool testConds, bool runActions) {
    unit unitVar;
    string behavior;
    fixed behaviorDuration;
    fixed newDuration;
    fixed percentIncrease;
    if (testConds) {
        if (UnitGetOwner(EventUnit()) != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    unitVar = EventUnit();
    behavior = EventUnitBehavior();

    UnitBehaviorRemove(unitVar, behavior, 1);
    if ((behaviorDuration > 0.0)) {
        UnitBehaviorSetDuration(unitVar, behavior, 0);
    }
    
    return true;
}
// ---------------------------------------------------------------
// Wheres Illidan
// ---------------------------------------------------------------
int wheresIllidanIndex;
bool libAffx_WheresIllidanAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    wheresIllidanIndex = libAffx_EventAffix();
    libAffx_affixes[wheresIllidanIndex].cooldown = RandomInt(50, 250);
    return true;
}
bool libAffx_WheresIllidanPeriodic (bool testConds, bool runActions) {
    unit maiev;
    if (testConds) {
        if (libAffx_gamePaused) {
            return false;
        }
        if (wheresIllidanIndex == 0) {
            return false;
        }
        if (!libAffx_GateIsOpen()) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    if (libAffx_affixes[wheresIllidanIndex].cooldown <= 0 && UnitIsAlive(libGame_gv_players[libAffx_player].lv_heroUnit)) {
        libAffx_affixes[wheresIllidanIndex].cooldown = RandomInt(50, 250);
        libNtve_gf_SendActorMessageToUnit(libGame_gv_players[libAffx_player].lv_heroUnit, "Create MaievWheresIllidanWarningVO");
        libAffx_Wait(2.5, c_timeGame);
        libNtve_gf_CreateUnitsAtPoint2(1, "HeroMaiev", c_unitCreateIgnorePlacement, libAffx_teamChaos, PointWithOffsetPolar(UnitGetPosition(libGame_gv_players[libAffx_player].lv_heroUnit), 14, RandomFixed(0, 360)), null);
        maiev = UnitLastCreated();
        UnitBehaviorAdd(maiev, "Affix60MoveSpeed", maiev, 1);
        libNtve_gf_SendActorMessageToUnit(maiev, "Signal Respawn");
        UnitIssueOrder(maiev, OrderTargetingPoint(AbilityCommand("move", 0), UnitGetPosition(libGame_gv_players[libAffx_player].lv_heroUnit)), c_orderQueueReplace);
        libAffx_Wait(0.825, c_timeGame);
        if (UnitIsAlive(maiev)) {
            UnitCreateEffectPoint(maiev, "MaievContainmentDiscLaunchMissile", UnitGetPosition(libGame_gv_players[libAffx_player].lv_heroUnit));
        }
        libAffx_Wait(0.75, c_timeGame);
        UnitRemove(maiev);
        UnitKill(maiev);
        
    } else {
        libAffx_affixes[wheresIllidanIndex].cooldown -= 0.0625;
    }
    
    return true;
}
// ---------------------------------------------------------------
// Night Elf Bond
// ---------------------------------------------------------------
unit nightElfBondMalfurion;
unit nightElfBondTyrande;
void libAffx_NightElfBondSpawnMalfurion () {
    fixed sharedHealth;
    if (nightElfBondMalfurion == null || !UnitIsAlive(nightElfBondMalfurion)) {
        libNtve_gf_CreateUnitsAtPoint2(1, "HeroMalfurion", c_unitCreateIgnorePlacement, libAffx_teamOrder, PointWithOffsetPolar(UnitGetPosition(libGame_gv_players[libAffx_player].lv_heroUnit), 5, RandomFixed(0, 360)), null);
        nightElfBondMalfurion = UnitLastCreated();
        nightElfBondTyrande = libAffx_GetHeroUnit(libAffx_player);
        libNtve_gf_SendActorMessageToUnit(nightElfBondMalfurion, "Signal Respawn");
        UnitCreateEffectUnit(libGame_gv_players[libAffx_player].lv_heroUnit, "ApplyNightElfBondMalfurion", nightElfBondMalfurion);
        sharedHealth = (UnitGetPropertyFixed(nightElfBondTyrande, c_unitPropLife, true) + UnitGetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, true) / 2);
        UnitSetPropertyFixed(nightElfBondTyrande, c_unitPropLife, sharedHealth);
        UnitSetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, sharedHealth);
    }
}
bool libAffx_NightElfBondDamageTaken (bool testConds, bool runActions) {
    unit eventUnit = EventUnit();
    int player = UnitGetOwner(eventUnit);
    fixed incomingDamage = EventUnitDamageAmount();
    if (testConds) {
        if (eventUnit != nightElfBondMalfurion && eventUnit != nightElfBondTyrande) {
            return false;
        }
        if (nightElfBondMalfurion == null || nightElfBondTyrande == null) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (eventUnit == nightElfBondTyrande) {
        //UnitSetPropertyFixed(nightElfBondTyrande, c_unitPropLife, UnitGetPropertyFixed(nightElfBondTyrande, c_unitPropLife, true) + incomingDamage / 2);
        UnitSetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, UnitGetPropertyFixed(nightElfBondTyrande, c_unitPropLife, true));
    } else {
        //UnitSetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, UnitGetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, true) + incomingDamage / 2);
        UnitSetPropertyFixed(nightElfBondTyrande, c_unitPropLife, UnitGetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, true));
    }
    return true;
}
bool libAffx_NightElfBondHealed (bool testConds, bool runActions) {
    unit eventUnit = EventUnit();
    int player = UnitGetOwner(eventUnit);
    fixed healingReceived = EventUnitHealAmount();
    if (testConds) {
        if (eventUnit != nightElfBondMalfurion && eventUnit != nightElfBondTyrande) {
            return false;
        }
        if (nightElfBondMalfurion == null || nightElfBondTyrande == null) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (eventUnit == nightElfBondTyrande) {
        //UnitSetPropertyFixed(nightElfBondTyrande, c_unitPropLife, UnitGetPropertyFixed(nightElfBondTyrande, c_unitPropLife, true) - healingReceived / 2);
        UnitSetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, UnitGetPropertyFixed(nightElfBondTyrande, c_unitPropLife, true));
    } else {
        //UnitSetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, UnitGetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, true) - healingReceived / 2);
        UnitSetPropertyFixed(nightElfBondTyrande, c_unitPropLife, UnitGetPropertyFixed(nightElfBondMalfurion, c_unitPropLife, true));
    }
    return true;
}
bool libAffx_NightElfBondOncePerGame (bool testConds, bool runActions) {
    trigger damageEvent;
    trigger healEvent;
    if (!runActions) {
        return true;
    }
    libGame_AddAbilityEffectMapping("NightElfBond", "NightElfBondDamage");

    damageEvent = TriggerCreate("libAffx_NightElfBondDamageTaken");
    healEvent = TriggerCreate("libAffx_NightElfBondHealed");

    TriggerAddDamageEvent(damageEvent, null, "HeroTyrande", c_unitDamageTypeAny, c_unitDamageEither, null);
    TriggerAddDamageEvent(damageEvent, null, "HeroMalfurion", c_unitDamageTypeAny, c_unitDamageEither, null);
    TriggerAddEventUnitHealed(healEvent, null, c_unitVitalLife, null);
    return true;
}
bool libAffx_NightElfBondAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_NightElfBondSpawnMalfurion();
    return true;
}
bool libAffx_NightElfBondRespawn (bool testConds, bool runActions) {
    int player = libGame_gf_HeroRespawnPlayer();
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_NightElfBondSpawnMalfurion();

    return true;
}
bool libAffx_NightElfBondUnitDied (bool testConds, bool runActions) {
    unit deadUnit = EventUnit();
    int deadPlayer = EventPlayer();
    if (testConds) {
        if (deadPlayer != libAffx_player && deadUnit != nightElfBondMalfurion) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (deadPlayer == libAffx_player) {
        UnitKill(nightElfBondMalfurion);
        UnitRemove(nightElfBondMalfurion);
    } else if (deadUnit == nightElfBondMalfurion) {
        UnitCreateEffectUnit(nightElfBondMalfurion, "NightElfBondDamage", libGame_gv_players[libAffx_player].lv_heroUnit);
    }

    return true;
}
bool libAffx_NightElfBondPeriodic (bool testConds, bool runActions) {
    if (testConds) {
        if (!UnitIsAlive(nightElfBondMalfurion)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if ((DistanceBetweenPoints(UnitGetPosition(nightElfBondMalfurion), UnitGetPosition(nightElfBondTyrande)) >= 24)) {
        UnitSetPosition(nightElfBondMalfurion, PointWithOffsetPolar(UnitGetPosition(nightElfBondTyrande), 1.5, RandomFixed(0, 360)), false);
        UnitIssueOrder(nightElfBondMalfurion, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
    }

    if (UnitGetPropertyFixed(nightElfBondMalfurion, c_unitPropLifeMax, true) != UnitGetPropertyFixed(nightElfBondTyrande, c_unitPropLifeMax, true)) {
        UnitSetPropertyFixed(nightElfBondMalfurion, c_unitPropLifeMax, UnitGetPropertyFixed(nightElfBondTyrande, c_unitPropLifeMax, true));
    }

    return true;
}
// ---------------------------------------------------------------
// Injury
// ---------------------------------------------------------------
bool libAffx_InjuryExecute (bool testConds, bool runActions) {
    unitgroup unitGroup;
    unit heroUnit;
    int groupCount;
    if (!runActions) {
        return true;
    }
    unitGroup = libGame_gv_players[libAffx_player].lv_heroUnitGroup;
    groupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    for (;; groupCount -= 1) {
        if (groupCount <= 0) { break; }
        heroUnit = UnitGroupUnitFromEnd(unitGroup, groupCount);
        if (UnitGetType(heroUnit) == "HeroLostVikingsController") { continue; }
        if (UnitGetType(heroUnit) == "HeroErik" || UnitGetType(heroUnit) == "HeroRexxar" || UnitGetType(heroUnit) == "HeroDVaMech") {
            libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixInjury2", "Modification.VitalRegenArray[Life]", libAffx_player, -UnitGetPropertyFixed(heroUnit, c_unitPropLifeRegen, false) * Pow(1.04, UnitLevel(heroUnit)));
            UnitBehaviorRemove(heroUnit, "AffixInjury", 1);
            UnitBehaviorRemove(heroUnit, "AffixInjury3", 1);
            UnitBehaviorAdd(heroUnit, "AffixInjury2", heroUnit, 1);
        } else if (UnitGetType(heroUnit) == "HeroBaleog") {
            libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixInjury3", "Modification.VitalRegenArray[Life]", libAffx_player, -UnitGetPropertyFixed(heroUnit, c_unitPropLifeRegen, false) * Pow(1.04, UnitLevel(heroUnit)));
            UnitBehaviorRemove(heroUnit, "AffixInjury", 1);
            UnitBehaviorRemove(heroUnit, "AffixInjury2", 1);
            UnitBehaviorAdd(heroUnit, "AffixInjury3", heroUnit, 1);
        } else {
            UnitBehaviorRemove(heroUnit, "AffixInjury2", 1);
            UnitBehaviorRemove(heroUnit, "AffixInjury3", 1);
            libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixInjury", "Modification.VitalRegenArray[Life]", libAffx_player, -UnitGetPropertyFixed(heroUnit, c_unitPropLifeRegen, false) * Pow(1.04, UnitLevel(heroUnit)));
        }
    }

    return true;
}
bool libAffx_InjuryLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    unitgroup unitGroup;
    unit heroUnit;
    int groupCount;
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (level <= 0) {
        return true;
    }
    unitGroup = libGame_gv_players[libAffx_player].lv_heroUnitGroup;
    groupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    for (;; groupCount -= 1) {
        if (groupCount <= 0) { break; }
        heroUnit = UnitGroupUnitFromEnd(unitGroup, groupCount);
        if (UnitGetType(heroUnit) == "HeroLostVikingsController") { continue; }
        if (UnitGetType(heroUnit) == "HeroErik" || UnitGetType(heroUnit) == "HeroRexxar" || UnitGetType(heroUnit) == "HeroDVaMech") {
            libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixInjury2", "Modification.VitalRegenArray[Life]", libAffx_player, -UnitGetPropertyFixed(heroUnit, c_unitPropLifeRegen, false) * Pow(1.04, level));
            UnitBehaviorRemove(heroUnit, "AffixInjury", 1);
            UnitBehaviorRemove(heroUnit, "AffixInjury3", 1);
            UnitBehaviorAdd(heroUnit, "AffixInjury2", heroUnit, 1);
        } else if (UnitGetType(heroUnit) == "HeroBaleog") {
            libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixInjury3", "Modification.VitalRegenArray[Life]", libAffx_player, -UnitGetPropertyFixed(heroUnit, c_unitPropLifeRegen, false) * Pow(1.04, level));
            UnitBehaviorRemove(heroUnit, "AffixInjury", 1);
            UnitBehaviorRemove(heroUnit, "AffixInjury2", 1);
            UnitBehaviorAdd(heroUnit, "AffixInjury3", heroUnit, 1);
        } else {
            UnitBehaviorRemove(heroUnit, "AffixInjury2", 1);
            UnitBehaviorRemove(heroUnit, "AffixInjury3", 1);
            libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixInjury", "Modification.VitalRegenArray[Life]", libAffx_player, -UnitGetPropertyFixed(heroUnit, c_unitPropLifeRegen, false) * Pow(1.04, level));
        }
    }

    return true;
}
