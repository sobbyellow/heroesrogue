// ---------------------------------------------------------------
// Double Ult
// ---------------------------------------------------------------

bool[11] libAffx_doubleUltActive;
void libAffx_DoubleUltApply(int player) {
    unit playerUnit = libGame_gv_players[player].lv_heroUnit;
    string hero = libCore_gf_GetHeroFromUnitType(UnitGetType(playerUnit));

    if (libAffx_doubleUltActive[player]) {
        return;
    }

    if (hero == "Varian") {
        if (!(UnitLevel(playerUnit) >= 4)) {
            return;
        }
    } else if (hero == "Chromie") {
        if (!(UnitLevel(playerUnit) >= 8)) {
            return;
        }
    } else {
        if (!(UnitLevel(playerUnit) >= 10)) {
            return;
        }
    }

    libAffx_doubleUltActive[player] = true;
    if (hero == "Tracer") {
        while (!PlayerHasTalent(player, "TracerQuantumSpike") && !PlayerHasTalent(player, "TracerStickyBomb") && !PlayerHasTalent(player, "TracerPulseRounds")) {
            libAffx_Wait(0.0625, c_timeGame);
        }
    } else {
        while (!UnitHasBehavior2(playerUnit, "Ultimate1Unlocked") && !UnitHasBehavior2(playerUnit, "Ultimate2Unlocked") && !UnitHasBehavior2(playerUnit, "Ultimate3Unlocked")) {
            libAffx_Wait(0.0625, c_timeGame);
        }
    }

    if (hero == "Varian") {
        libGame_gf_TalentsChooseTalentForPlayer(2, 1, player);
        libGame_gf_TalentsChooseTalentForPlayer(2, 2, player);
        libGame_gf_TalentsChooseTalentForPlayer(2, 3, player);
    } else {
        libGame_gf_TalentsChooseTalentForPlayer(4, 1, player);
        libGame_gf_TalentsChooseTalentForPlayer(4, 2, player);
        if (hero == "Alarak") {
            SetTalentEnabled("AlarakMightOfTheHighlord", false);
        } else if (hero == "Tracer") {
            libGame_gf_TalentsChooseTalentForPlayer(4, 3, player);
        }
    }
}
bool libAffx_DoubleUlt (bool testConds, bool runActions) {
    int i;
    if (!runActions) {
        return true;
    }
    for (i = 6; i <= 10; i += 1) {
        libAffx_DoubleUltApply(i);
    }
    return true;
}
bool libAffx_DoubleUltLevelUp (bool testConds, bool runActions) {
    int player;
    int level;
    if (testConds) {
        if (libGame_gf_HeroLevelUpPlayer() < 6 || libGame_gf_HeroLevelUpPlayer() > 10) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    player = libGame_gf_HeroLevelUpPlayer();
    level = libGame_gf_HeroLevelUpLevel();
    libAffx_DoubleUltApply(player);
    return true;
}
// ---------------------------------------------------------------
// CC Increase
// ---------------------------------------------------------------
bool libAffx_AffixCCIncrease (bool testConds, bool runActions) {
    unit unitVar;
    string behavior;
    fixed behaviorDuration;
    fixed newDuration;
    fixed percentIncrease;
    if (testConds) {
        if (!((UnitGetOwner(EventUnit()) > 0))) {
            return false;
        }

        if (!((UnitGetOwner(EventUnit()) <= 5))) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    unitVar = EventUnit();
    behavior = EventUnitBehavior();

    behaviorDuration = UnitBehaviorDuration(unitVar, behavior);
    percentIncrease = 0.25 * UnitBehaviorCount(unitVar, "AffixCCIncrease");

    if ((behaviorDuration > 0.0 && percentIncrease > 0.0)) {
        newDuration = (behaviorDuration * (1.0 + percentIncrease));
        UnitBehaviorSetDuration(unitVar, behavior, newDuration);
    }
    
    return true;
}
// ---------------------------------------------------------------
// Enemy Level
// ---------------------------------------------------------------
bool libAffx_EnemyLevelAA (bool testConds, bool runActions) {
    int stacks;
    int currentLevel;
    int i;
    if (!runActions) {
        return true;
    }
    stacks = libAffx_EventAffixCount("EnemyLevel");
    currentLevel = UnitLevel(libGame_gv_players[libAffx_enemy].lv_heroUnit);
    for (i = 6; i <= 10; i += 1) {
        UnitSetPropertyFixed(libGame_gv_players[i].lv_heroUnit, c_unitPropLevel, MinI(currentLevel + stacks, 30));
    }

    return true;
}
