// ---------------------------------------------------------------
// Mythic 1
// ---------------------------------------------------------------
bool libAffx_Mythic1OncePerGame (bool testConds, bool runActions) {
    unitgroup structures = UnitGroup(null, libAffx_teamOrder, RegionEntireMap(), libCore_gv_filtersStructure, 0);
    int structureCount = UnitGroupCount(structures, c_unitCountAll);
    unit structure;
    if (!runActions) {
        return true;
    }
    for (;; structureCount -= 1) {
        if (structureCount <= 0) { break; }
        structure = UnitGroupUnitFromEnd(structures, structureCount);

        if (UnitGetType(structure) == "TownMoonwellL3" || UnitGetType(structure) == "TownMoonwellL2") {
            continue;
        }

        UnitBehaviorAdd(structure, "Mythic1Debuff", structure, 1);
        UnitSetPropertyFixed(structure, c_unitPropLife, UnitGetPropertyFixed(structure, c_unitPropLife, true) * 0.5);
    }

    return true;
}
// ---------------------------------------------------------------
// Mythic 2
// ---------------------------------------------------------------
bool libAffx_Mythic2ExecuteOncePerGame (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_AddBehaviorAllUnitsFilter("Mythic2Buff", libCore_gv_filtersStructure, libAffx_teamChaos, null, 1);

    return true;
}
// ---------------------------------------------------------------
// Mythic 4
// ---------------------------------------------------------------
bool libAffx_Mythic4OncePerGame (bool testConds, bool runActions) {
    int i;
    int i2;
    int heroLevel;
    unit heroUnit;
    if (!runActions) {
        return true;
    }
    for (i = 1; i <= 7; i += 1) {
        for (i2 = 6; i2 <= 10; i2 += 1) {
            heroUnit = libGame_gv_players[i2].lv_heroUnit;
            heroLevel = UnitLevel(heroUnit);
            if (heroLevel < 7) {
                UnitXPAddXP(heroUnit, null, StringToFixed(CatalogReferenceGet("Behavior,HeroXPCurve,VeterancyLevelArray[" + IntToString(heroLevel) +"].MinVeterancyXP", i2)) + 1);
            }
        }
    }

    return true;
}
// ---------------------------------------------------------------
// Mythic 5
// ---------------------------------------------------------------
int libAffx_mythic5Index;
bool libAffx_Mythic5AffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_mythic5Index = libAffx_EventAffix();
    return true;
}
bool libAffx_Mythic5OncePerGame (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_maxAffixesFromObjectives -= 1;
    return true;
}
bool libAffx_Mythic5HeroKilled (bool testConds, bool runActions) {
    unit deadUnit = libGame_gf_HeroKilledUnit();
    int deadPlayer = libGame_gf_HeroKilledPlayer();
    int killingPlayer = libGame_gf_HeroKilledKillingPlayer();
    int i;
    if (testConds) {
        if (libGame_gv_gameOver) {
            return false;
        }
        if (deadPlayer != libAffx_player) {
            return false;
        }
        if (!(UnitTestState(deadUnit, c_unitStateHallucination) == false)) {
            return false;
        }
        if (!UnitTypeTestAttribute(UnitGetType(deadUnit), c_unitAttributeHeroic)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_affixes[libAffx_mythic5Index].customValue += 1;
    if (libAffx_affixes[libAffx_mythic5Index].customValue >= 3) {
        libAffx_affixes[libAffx_mythic5Index].customValue = 0;
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringExternal("Message/CurseCursed"));
        libAffx_QueueCurse(1);
    }
    return true;
}
bool libAffx_Mythic5LevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
        if (level < 20) {
            return false;
        }
        if (libAffx_affixes[libAffx_mythic5Index].customBool) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (level <= 0) {
        return true;
    }
    libAffx_affixes[libAffx_mythic5Index].customBool = true;
    libAffx_affixes[libAffx_mythic5Index].cooldown = 120;
    TriggerAddEventTimePeriodic(TriggerCreate("libAffx_Mythic5Periodic"), 0.0625, c_timeGame);
    TriggerAddEventUnitCreated(TriggerCreate("libAffx_Mythic5UnitCreated"), null, null, null);
    TriggerAddEventUnitChangeOwner(TriggerCreate("libAffx_Mythic5UnitChangeOwner"), null);
    libAffx_AddBehaviorAllUnitsFilter("Mythic5Debuff", libAffx_filtersTeamOrder, 0, "", 1);
    
    return true;
}
bool libAffx_Mythic5UnitCreated (bool testConds, bool runActions) {
    if (testConds) {
        if (!libAffx_affixes[libAffx_mythic5Index].customBool) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_AddBehaviorFilter(EventUnitCreatedUnit(), "Mythic5Debuff", libAffx_filtersTeamOrder, 0, "", 1);
    return true;
}
bool libAffx_Mythic5UnitChangeOwner (bool testConds, bool runActions) {
    if (testConds) {
        if (!libAffx_affixes[libAffx_mythic5Index].customBool) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_AddAndRemoveBehaviorFilter(EventUnit(), "Mythic5Debuff", libAffx_filtersTeamOrder, 0, "", 1);
    return true;
}
bool libAffx_Mythic5Periodic (bool testConds, bool runActions) {
    int level;
    if (testConds) {
        if (!libAffx_affixes[libAffx_mythic5Index].customBool) {
            return false;
        }
        if (libAffx_gamePaused) {
            return false;
        }
        if (!libAffx_GateIsOpen()) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (libAffx_affixes[libAffx_mythic5Index].cooldown <= 0) {
        level = UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit);
        if (level < 30) {
            libAffx_CatalogModifyForAllPlayers("Behavior,Mythic5Debuff,ArmorModification.AllArmorBonus", FixedToString(StringToFixed(CatalogReferenceGet("Behavior,Mythic5Debuff,ArmorModification.AllArmorBonus", libAffx_player)) - 10, 0));
            libAffx_affixes[libAffx_mythic5Index].cooldown = 120;
        } else {
            libAffx_CatalogModifyForAllPlayers("Behavior,Mythic5Debuff,ArmorModification.AllArmorBonus", FixedToString(StringToFixed(CatalogReferenceGet("Behavior,Mythic5Debuff,ArmorModification.AllArmorBonus", libAffx_player)) - 100, 0));
            libAffx_affixes[libAffx_mythic5Index].cooldown = 60;
        }
    } else {
        libAffx_affixes[libAffx_mythic5Index].cooldown -= 0.0625;
    }
    return true;
}
// ---------------------------------------------------------------
// Ritual of Boons
// ---------------------------------------------------------------
int ritualOfBoonsIndex;
bool libAffx_NazeeboRitualofBoonsAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    ritualOfBoonsIndex = libAffx_EventAffix();
    
    return true;
}
bool libAffx_NazeeboRitualofBoons (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_AddBehavior(libAffx_player, "WitchDoctorRitualofBoonsQuestToken", 1, false);
    
    return true;
}
bool libAffx_NazeeboRitualofBoonsQuestComplete (bool testConds, bool runActions) {
    if (testConds) {
        if (ritualOfBoonsIndex == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_QueueAffix(libAffx_rarityUncommon, false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), 1, true);
    libAffx_QueueAffix(libAffx_rarityRare, false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), 1, true);
    libAffx_affixes[ritualOfBoonsIndex].quest.questDone = true;
    
    return true;
}
// ---------------------------------------------------------------
// Very Bad Bargain
// ---------------------------------------------------------------
int veryBadBargainIndex;
bool libAffx_VeryBadBargainAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    veryBadBargainIndex = libAffx_EventAffix();
    return true;
}
bool libAffx_VeryBadBargainOncePerGame (bool testConds, bool runActions) {
    libAffx_Wait(0.0625, c_timeGame);
    if (testConds) {
        if (veryBadBargainIndex == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_affixes[veryBadBargainIndex].cooldown = 60;
    return true;
}
bool libAffx_VeryBadBargainPeriodic (bool testConds, bool runActions) {
    if (testConds) {
        if (veryBadBargainIndex == 0) {
            return false;
        }
        if (libAffx_gamePaused) {
            return false;
        }
        if (!libAffx_GateIsOpen()) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    if (libAffx_affixes[veryBadBargainIndex].cooldown <= 0) {
        libAffx_CatalogReferenceModify2("Behavior,VeryBadBargainDebuff,Modification.HealDealtAdditiveMultiplier[Life]", libAffx_player, FixedToString(0.02 * libAffx_affixes[veryBadBargainIndex].count, 2), c_upgradeOperationSubtract);
        libAffx_CatalogReferenceModify2("Behavior,VeryBadBargainDebuff,Modification.HealDealtAdditiveMultiplier[Shields]", libAffx_player, FixedToString(0.02 * libAffx_affixes[veryBadBargainIndex].count, 2), c_upgradeOperationSubtract);
        libAffx_CatalogReferenceModify2("Behavior,VeryBadBargainDebuff,Modification.DamageDealtFraction[Ability]", libAffx_player, FixedToString(0.02 * libAffx_affixes[veryBadBargainIndex].count, 2), c_upgradeOperationSubtract);
        libAffx_CatalogReferenceModify2("Behavior,VeryBadBargainDebuff,Modification.DamageDealtFraction[Basic]", libAffx_player, FixedToString(0.02 * libAffx_affixes[veryBadBargainIndex].count, 2), c_upgradeOperationSubtract);
        libAffx_affixes[veryBadBargainIndex].cooldown = 60;
    } else {
        libAffx_affixes[veryBadBargainIndex].cooldown -= 0.0625;
    }

    return true;
}
// ---------------------------------------------------------------
// Purification Protocol
// ---------------------------------------------------------------
unit libAffx_purificationProtocolUnit;
bool libAffx_purificationProtocolActive;
void libAffx_CastPurifierBeam() {
    unitgroup heroGroup = libGame_gv_players[libAffx_player].lv_heroUnitGroup;
    int groupCount = UnitGroupCount(heroGroup, c_unitCountAll);
    unit heroUnit;
    
    while (!libAffx_purificationProtocolActive) {
        for (;; groupCount -= 1) {
            if (groupCount <= 0) { break; }
            heroUnit = UnitGroupUnitFromEnd(heroGroup, groupCount);
            if (UnitGetType(heroUnit) == "HeroLostVikingsController") { continue; }
            
            while (!UnitIsAlive(heroUnit) || UnitHasBehavior2(heroUnit, "HallOfStormsProtectionBuff")) {
                libAffx_Wait(0.0625, c_timeGame);
            }
    
            libAffx_purificationProtocolUnit = heroUnit;
            UnitCreateEffectUnit(libGame_gv_teams[libAffx_teamChaosIndex].lv_core, "ArtanisSpearofAdunPurifierBeamInitialSet", libAffx_purificationProtocolUnit);
            libAffx_purificationProtocolActive = true;
            break;
        }
        libAffx_Wait(0.25, c_timeGame);
    }
}
bool libAffx_PurificationProtocolOncePerGame (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    TriggerEnable(libGDHL_gt_HeroArtanisSpearofAdunPurifierBeamSetTarget, true);
    TriggerEnable(libGDHL_gt_HeroArtanisSpearofAdunPurifierBeamRedirectTarget2ElectricBoogaloo, true);
    TriggerEnable(libGDHL_gt_HeroArtanisSpearofAdunPurifierBeamUnitCreated, true);
    libGame_AddAbilityEffectMapping("ArtanisSpearofAdunPurifierBeam", "ArtanisSpearofAdunPurifierBeamDamage");
    libAffx_CatalogReferenceModify("Behavior,ArtanisSpearofAdunPurifierBeamTimedLife,Duration", libAffx_teamChaos, "0");
    libAffx_CatalogReferenceModify("Behavior,ArtanisSpearofAdunPurifierBeamRevealer,Duration", libAffx_teamChaos, "1");
    libAffx_CatalogReferenceModify("Behavior,ArtanisSpearofAdunPurifierBeamPointMovementOverride,Duration", libAffx_teamChaos, "0");
    libAffx_CatalogReferenceModify("Behavior,ArtanisSpearofAdunPurifierBeamMoveSearch,Duration", libAffx_teamChaos, "0");
    while (!libAffx_GateIsOpen()) {
        libAffx_Wait(0.0625, c_timeGame);
    }
    libAffx_CastPurifierBeam();
    return true;
}
bool libAffx_PurificationProtocolLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player != libAffx_enemy) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_LevelUpScaling("Effect,ArtanisSpearofAdunPurifierBeamDamage,Amount", libAffx_teamChaos);
    
    return true;
}
