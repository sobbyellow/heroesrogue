// ---------------------------------------------------------------
// Bad Mannerism
// ---------------------------------------------------------------
bool libAffx_BadMannerismHeroTakedown (bool testConds, bool runActions) {
    int player = libGame_gf_HeroParticipatedInTakedownKillingPlayer();
    unit killerUnit = libGame_gv_players[player].lv_heroUnit;
    unit deadUnit = libGame_gf_HeroParticipatedInTakedownKilledHero();
    int i;
    if (testConds) {
        if (player < 6 || player > 10) {
            return false;
        }
        if (UnitGetOwner(deadUnit) != libAffx_player) {
            return false;
        }
        if (UnitTestState(deadUnit, c_unitStateHallucination)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_Wait(RandomFixed(0.25, 1.25), c_timeGame);
    for (i = 1; i <= RandomInt(6, 12); i += 1) {
        UnitIssueOrder(killerUnit, Order(AbilityCommand("Hearthstone", 0)), c_orderQueueReplace);
        libAffx_Wait(RandomFixed(0.0625, 0.1875), c_timeGame);
        UnitIssueOrder(killerUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
        libAffx_Wait(0.0625, c_timeGame);
    }
    return true;
}
bool libAffx_BadMannerismPeriodic (bool testConds, bool runActions) {
    int random = RandomInt(6, 10);
    unitgroup nearbyUnits;
    unit bmUnit = libGame_gv_players[random].lv_heroUnit;
    unit playerUnit;
    int nearbyUnitsCount;
    int i;
    if (testConds) {
        if (!UnitIsAlive(bmUnit)) {
            return false;
        }
        if (UnitHasBehavior2(bmUnit, "Mounted")) {
            return false;
        }
        if (libAffx_gamePaused || libGame_gv_gameOver) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    
    nearbyUnits = UnitGroup(null, libAffx_player, RegionCircle(UnitGetPosition(bmUnit), 12), null, 0);
    nearbyUnitsCount = UnitGroupCount(nearbyUnits, c_unitCountAll);
    for (;; nearbyUnitsCount -= 1) {
        if (nearbyUnitsCount <= 0) { break; }
        playerUnit = UnitGroupUnitFromEnd(nearbyUnits, nearbyUnitsCount);
        if (UnitTypeTestAttribute(UnitGetType(bmUnit), c_unitAttributeHeroic)) {
            random = RandomInt(1, 100);
            if (random <= 66) {
                UnitIssueOrder(bmUnit, Order(AbilityCommand("LootSpray", 0)), c_orderQueueReplace);
            } else if (random <= 100) {
                UnitIssueOrder(bmUnit, Order(AbilityCommand("LootYellVoiceLine", 0)), c_orderQueueReplace);
            }
        }
    }
    return true;
}
bool libAffx_BadMannerismExecute (bool testConds, bool runActions) {
    int i;
    if (!runActions) {
        return true;
    }
    for (i = 6; i <= 10; i += 1) {
        PlayerSetSpray(i, "RandomSpray");
        libGame_gf_HeroSelectionRandomlyPickSpray(i);
    }
    
    return true;
}
