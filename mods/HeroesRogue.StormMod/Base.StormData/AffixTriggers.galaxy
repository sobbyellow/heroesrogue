// ---------------------------------------------------------------
// BUDDY
// ---------------------------------------------------------------
int buddyAllIndex;
int buddyCount = 1;
int[11] currentBuddies;
int[11] currentBuddies2;
int[11] currentBuddies3;
void libAffx_AddBuddy(int player, unit ownerUnit, int count) {
    if (UnitGetType(ownerUnit) == "HeroErik") {
        currentBuddies3[player] += count;
    } else if (UnitGetType(ownerUnit) == "HeroBaleog" || UnitGetType(ownerUnit) == "RexxarMisha") {
        currentBuddies2[player] += count;
    } else {
        currentBuddies[player] += count;
    }
}
int libAffx_GetBuddyCount(int player, unit ownerUnit) {
    if (UnitGetType(ownerUnit) == "HeroErik") {
        return currentBuddies3[player];
    } else if (UnitGetType(ownerUnit) == "HeroBaleog" || UnitGetType(ownerUnit) == "RexxarMisha") {
        return currentBuddies2[player];
    } else {
        return currentBuddies[player];
    }
}
const fixed buddyDamage = 142;
const fixed buddyHealing = 154;
bool libAffx_BuddyAI (bool testConds, bool runActions) {
    const int buddyIdleState = 1;
    const int buddyLeashingState = 2;
    const int buddyMovingState = 3;
    const int buddyCirclingState = 4;

    fixed buddyFollowRange = 8;
    fixed buddyTeleportRange = buddyFollowRange * 3;

    unit ownerUnit = EventPlayerEffectUsedUnit(c_effectUnitCaster);
    unit buddyUnit;
    int ownerPlayer = EventPlayerEffectUsedUnitOwner(c_effectPlayerCaster);
    int currentState = buddyIdleState;
    fixed circleAngle;
    unit activeUnit;
    if (testConds) {
        if (UnitGetType(ownerUnit) == "HeroLostVikingsController") {
            return false;
        }
        if (currentBuddies[ownerPlayer] >= buddyCount) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    libNtve_gf_CreateUnitsAtPoint2(1, "AffixBuddyDrone", 0, ownerPlayer, PointWithOffsetPolar(UnitGetPosition(ownerUnit), 1.5, libNtve_gf_RandomAngle()), ownerUnit);
    buddyUnit = UnitLastCreated();
    UnitGroupAdd(libGame_gv_players[ownerPlayer].lv_summonedUnitGroup, buddyUnit);
    libAffx_AddBuddy(ownerPlayer, ownerUnit, 1);
    circleAngle = RandomFixed(0, 360);
    while ((UnitIsAlive(buddyUnit) == true) && (UnitIsAlive(ownerUnit) == true) && (UnitHasBehavior2(ownerUnit, "Dead") == false)) {
        circleAngle += 2.15;
        if (circleAngle >= 360) {
            circleAngle -= 360;
        }
        if (libGame_gv_players[ownerPlayer].lv_activeVehicle != null && libNtve_gf_UnitIsInsideTransport(ownerUnit)) {
            activeUnit = UnitTransport(ownerUnit);
        } else if (UnitGetType(ownerUnit) == "HeroDVaPilot" && libNtve_gf_UnitIsInsideTransport(ownerUnit)) {
            activeUnit = UnitTransport(ownerUnit);
        } else {
            activeUnit = ownerUnit;
        }
        
        while (UnitHasBehaviorWithCategoryFlag(activeUnit, c_behaviorCategoryTimeStop)) {
            UnitGroupRemove(libGame_gv_players[ownerPlayer].lv_summonedUnitGroup, buddyUnit);
            UnitKill(buddyUnit);
            Wait(0.0625, c_timeGame);
        }
        // Heal owner
        if (UnitGroupCount(UnitGetTrackedUnitGroup(buddyUnit, "AffixBuddyHealUnitTracker"), c_unitCountAll) <= 0) {
            if (ownerPlayer == libAffx_gallPlayer) {
                UnitIssueOrder(buddyUnit, OrderTargetingUnit(AbilityCommand("AffixBuddyHeal", 0), libGame_gv_players[libAffx_choPlayer].lv_heroUnit), c_orderQueueReplace);
            } else {
                UnitIssueOrder(buddyUnit, OrderTargetingUnit(AbilityCommand("AffixBuddyHeal", 0), activeUnit), c_orderQueueReplace);
            }
        }
        // Movement
        if (UnitOrderCount(buddyUnit) <= 1) {
            if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(activeUnit)) >= buddyTeleportRange)) {
                UnitSetPosition(buddyUnit, PointWithOffsetPolar(UnitGetPosition(activeUnit), 1.5, libNtve_gf_RandomAngle()), false);
                UnitIssueOrder(buddyUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
                currentState = buddyIdleState;
            }
            else if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(activeUnit)) >= buddyFollowRange) && (currentState != buddyLeashingState)) {
                UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(activeUnit), -1.0, UnitGetFacing(activeUnit))), c_orderQueueReplace);
                currentState = buddyLeashingState;
            }

            if (currentState == buddyIdleState && UnitOrderCount(buddyUnit) != 0 && OrderGetAbilityCommand(UnitOrder(activeUnit, 0)) == AbilityCommand("move", 0)) {
                if ((DistanceBetweenPoints(OrderGetTargetPosition(UnitOrder(activeUnit, 0)), UnitGetPosition(buddyUnit)) > buddyFollowRange)) {
                    UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(OrderGetTargetPosition(UnitOrder(activeUnit, 0)), 1.0, UnitGetFacing(activeUnit))), c_orderQueueReplace);
                    currentState = buddyMovingState;
                }
            }
            
            if (currentState == buddyIdleState && UnitOrderCount(buddyUnit) == 0) {
                currentState = buddyCirclingState;
                UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(activeUnit), buddyFollowRange / 1.75, circleAngle)), c_orderQueueReplace);
            } else if (currentState == buddyCirclingState) {
                UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(activeUnit), buddyFollowRange / 1.75, circleAngle)), c_orderQueueReplace);
            } else if (currentState == buddyMovingState) {
                if ((UnitOrderCount(buddyUnit) == 0)) {
                    currentState = buddyIdleState;
                } else {
                    if ((UnitOrderCount(activeUnit) == 0)) {
                        if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(activeUnit)) <= buddyFollowRange)) {
                            UnitIssueOrder(buddyUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
                            currentState = buddyIdleState;
                        }
                    }
                    else if ((OrderGetAbilityCommand(UnitOrder(activeUnit, 0)) == AbilityCommand("move", 0))) {
                        if ((DistanceBetweenPoints(OrderGetTargetPosition(UnitOrder(activeUnit, 0)), OrderGetTargetPosition(UnitOrder(buddyUnit, 0))) > buddyFollowRange / 2)) {
                            UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(OrderGetTargetPosition(UnitOrder(activeUnit, 0)), 1.0, UnitGetFacing(activeUnit))), c_orderQueueReplace);
                            currentState = buddyMovingState;
                        }
                    }
                }
            } else if (currentState == buddyLeashingState) {
                if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(activeUnit)) <= buddyFollowRange)) {
                    UnitIssueOrder(buddyUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
                    currentState = buddyIdleState;
                }
                else {
                    if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(activeUnit)) <= buddyFollowRange) && (UnitOrderCount(buddyUnit) == 0)) {
                        if ((UnitOrderCount(activeUnit) == 0)) {
                            currentState = buddyIdleState;
                        }
                        else {
                            UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(activeUnit), 1.0, UnitGetFacing(activeUnit))), c_orderQueueReplace);
                            currentState = buddyLeashingState;
                        }
                    }
                    else {
                        if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(activeUnit)) > buddyFollowRange) && (UnitOrderCount(buddyUnit) == 0)) {
                            UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(activeUnit), 1.0, UnitGetFacing(activeUnit))), c_orderQueueReplace);
                            currentState = buddyLeashingState;
                        }
                        else {
                            if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), OrderGetTargetPoint(UnitOrder(buddyUnit, 0))) <= buddyFollowRange) && (DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(activeUnit)) > buddyFollowRange)) {
                                UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(activeUnit), 1.0, UnitGetFacing(activeUnit))), c_orderQueueReplace);
                                currentState = buddyLeashingState;
                            }
                        }
                    }
                }
            }
        }
        libAffx_Wait(0.0625, c_timeGame);
    }
    libAffx_AddBuddy(ownerPlayer, ownerUnit, -1);
    UnitGroupRemove(libGame_gv_players[ownerPlayer].lv_summonedUnitGroup, buddyUnit);
    UnitKill(buddyUnit);
    UnitBehaviorRemove(ownerUnit, "AffixBuddyDroneOwner", 1);

    return true;
}
bool libAffx_BuddyCheck (bool testConds, bool runActions) {
    unit user = EventPlayerEffectUsedUnit(c_effectUnitCaster);
    int player = EventPlayerEffectUsedUnitOwner(c_effectPlayerCaster);
    int i;
    int totalBuddies = currentBuddies[player] + currentBuddies2[player] + currentBuddies3[player];
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
        if (totalBuddies >= buddyCount) {
            return false;
        }
        if (!UnitIsAlive(user)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    for (i = 1; i <= (buddyCount - totalBuddies); i += 1) {
        totalBuddies = currentBuddies[player] + currentBuddies2[player] + currentBuddies3[player];
        if (totalBuddies >= buddyCount) {
            break;
        }
        if (UnitGetType(user) == "HeroErik") {
            if (currentBuddies3[player] < currentBuddies[player] && currentBuddies3[player] < currentBuddies2[player]) {
                UnitCreateEffectUnit(user, "AffixBuddyDroneApplyOwner", user);
            }
        } else if (UnitGetType(user) == "HeroBaleog") {
            if (currentBuddies2[player] < currentBuddies[player] && currentBuddies2[player] <= currentBuddies3[player]) {
                UnitCreateEffectUnit(user, "AffixBuddyDroneApplyOwner", user);
            }
        } else if (UnitGetType(user) == "HeroOlaf") {
            if (currentBuddies[player] <= currentBuddies2[player] && currentBuddies[player] <= currentBuddies3[player]) {
                UnitCreateEffectUnit(user, "AffixBuddyDroneApplyOwner", user);
            }
        } else if (UnitGetType(user) == "RexxarMisha") {
            if (currentBuddies2[player] < currentBuddies[player]) {
                UnitCreateEffectUnit(user, "AffixBuddyDroneApplyOwner", user);
            }
        } else if (UnitGetType(user) == "HeroRexxar") {
            if (currentBuddies[player] <= currentBuddies2[player]) {
                UnitCreateEffectUnit(user, "AffixBuddyDroneApplyOwner", user);
            }
        } else {
            UnitCreateEffectUnit(user, "AffixBuddyDroneApplyOwner", user);
        }
        libAffx_Wait(0.0625, c_timeGame);
    }

    return true;
}
bool libAffx_BuddyScaling (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (libAffx_affixes[buddyAllIndex].count > 0) {
        libAffx_LevelUpScaling3("Effect,AffixBuddyHealCreateHealer,RechargeVitalRate", player, 0.04, StringToFixed(libAffx_GetCatalogDefault("Effect,AffixBuddyHealCreateHealer,RechargeVitalRate")) * 0.75);
        libAffx_LevelUpScaling3("Effect,AffixBuddyDroneMissileDamage,Amount", player, 0.04, StringToFixed(libAffx_GetCatalogDefault("Effect,AffixBuddyDroneMissileDamage,Amount")) * 0.75);
    } else {
        libAffx_LevelUpScaling("Effect,AffixBuddyHealCreateHealer,RechargeVitalRate", player);
        libAffx_LevelUpScaling("Effect,AffixBuddyDroneMissileDamage,Amount", player);
    }

    return true;
}
bool libAffx_BuddyAffixAdded (bool testConds, bool runActions) {
    int count = libAffx_EventAffixCount();
    if (!runActions) {
        return true;
    }
    libAffx_CatalogModifyForAllPlayers("Behavior,AffixBuddyDroneController,Period", FixedToString(4 - (count - 1), 2));
    libAffx_CatalogModifyForAllPlayers("Effect,AffixBuddyHealCreatePersistent,PeriodicPeriodArray[0]", FixedToString(3 - 0.25 * (count - 1), 2));
    return true;
}
bool libaffx_BuddyOncePerGame (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    if (libAffx_playersHeroIndex[libAffx_player] == libCore_gf_GetIndexFromHero("LostVikings")) {
        buddyCount = 3;
    } else if (libAffx_playersHeroIndex[libAffx_player] == libCore_gf_GetIndexFromHero("Rexxar")) {
        buddyCount = 2;
    }
    libAffx_AddBehaviorWithExclusion(libAffx_player, "AffixBuddyDroneSpawnBehavior", 1, true, "HeroDVaMech");
    return true;
}
// ---------------------------------------------------------------
// Many Rituals
// ---------------------------------------------------------------
bool libAffx_manyRitualsInitial = true;
int libAffx_manyRitualsTotal;
bool libAffx_ManyRitualsAffixAdded (bool testConds, bool runActions) {
    const int manyRitualsInitial = 40;
    const int manyRitualsPerStack = 20;

    int stacks = libAffx_EventAffixCountAdded();
    unit heroUnit = libGame_gv_players[libAffx_player].lv_heroUnit;
    int amount;

    if (!runActions) {
        return true;
    }
    if (libAffx_manyRitualsInitial) {
        libAffx_manyRitualsInitial = false;
        amount = manyRitualsInitial + manyRitualsPerStack * (stacks - 1);
    } else {
        amount = manyRitualsPerStack;
    }

    libAffx_AddTokenCount(heroUnit, "WitchDoctorVoodooRitual", amount);
    libAffx_AddTokenCount(heroUnit, "WitchDoctorThingOfTheDeepQuestToken", amount);
    libAffx_AddTokenCount(heroUnit, "WitchDoctorRitualofBoonsQuestToken", amount);

    libAffx_manyRitualsTotal += amount;
    
    return true;
}
