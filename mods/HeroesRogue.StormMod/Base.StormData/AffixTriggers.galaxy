int pathOfTheWizardIndex;
bool libAffx_PathoftheWizardAffixAdded (bool testConds, bool runActions) {
    int level;
    if (!runActions) {
        return true;
    }
    pathOfTheWizardIndex = libAffx_EventAffix();
    level = UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit);
    libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixPathoftheWizard", "Modification.VitalRegenArray[Energy]", libAffx_player, 0.2 * libAffx_affixes[pathOfTheWizardIndex].count * level);
    libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixPathoftheWizard", "Modification.VitalMaxArray[Energy]", libAffx_player, 10 * libAffx_affixes[pathOfTheWizardIndex].count * level);
    return true;
}

bool libAffx_PathoftheWizardLevelUp (bool testConds, bool runActions) {
    int level = libGame_gf_HeroLevelUpLevel();
    int player = libGame_gf_HeroLevelUpPlayer();
    if (testConds) {
        if (player != libAffx_player && !UnitHasBehavior2(libGame_gv_players[player].lv_heroUnit, "AffixPathoftheWizard")) {
            return false;
        }
        if (pathOfTheWizardIndex == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixPathoftheWizard", "Modification.VitalRegenArray[Energy]", player, 0.2 * libAffx_affixes[pathOfTheWizardIndex].count * level);
    libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixPathoftheWizard", "Modification.VitalMaxArray[Energy]", player, 10 * libAffx_affixes[pathOfTheWizardIndex].count * level);
    return true;
}
