
include "LibAffx_h"

const int manyRitualsStacks = 20;
const int manyRitualsStacksInitial = 40;
const fixed zombieHandlerRange = 12;
const fixed zombieHandlerChance = 0.5;
const fixed nanoBoostCDR = 0.75;
const fixed blessingoftheDragonsCDR = 0.35;
const fixed buddyFollowRange = 8;
const fixed buddyTeleportRange = buddyFollowRange * 3;
const int buddyIdleState = 1;
const int buddyLeashingState = 2;
const int buddyMovingState = 3;
const int buddyCirclingState = 4;
const fixed buddyDamage = 142;
const fixed buddyHealing = 154;
const fixed deathTimerModifier = 0.5;
const fixed enemySpeedCDR = 0.25;

int resurgenceoftheStormIndex;

// ---------------------------------------------------------------
// Zombie Handler
// ---------------------------------------------------------------
bool libAffx_AffixZombieHandlerTrigger (bool testConds, bool runActions) {
    unit lv_playerHero;
    int lv_player;
    unit lv_minion;
    point lv_positionofMinion;
    int random;
    if (testConds) {
        if (!(((UnitGetType(libGame_gf_HeroParticipatedInNPCTakedownMinion()) == "FootmanMinion") || (UnitGetType(libGame_gf_HeroParticipatedInNPCTakedownMinion()) == "RangedMinion") || (UnitBehaviorCount(libGame_gf_HeroParticipatedInNPCTakedownMinion(), "IsCatapultMinionOrCatapultReplacement") > 0) || (UnitGetType(libGame_gf_HeroParticipatedInNPCTakedownMinion()) == "WizardMinion") || ((UnitFilterMatch(libGame_gf_HeroParticipatedInNPCTakedownMinion(), libAffx_teamChaos, UnitFilter((1 << c_targetFilterMinion), 0, 0, 0)) == true))))) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    lv_player = libGame_gf_HeroParticipatedInNPCTakedownKillingPlayer();
    lv_minion = libGame_gf_HeroParticipatedInNPCTakedownMinion();
    lv_positionofMinion = UnitGetPosition(lv_minion);
    lv_playerHero = libGame_gv_players[lv_player].lv_heroUnit;
    if (lv_player != libAffx_player) {
        return true;
    }
    if ((UnitIsAlive(lv_playerHero) == true) && (DistanceBetweenPoints(UnitGetPosition(lv_playerHero), lv_positionofMinion) <= zombieHandlerRange) && (UnitFilterMatch(lv_playerHero, lv_player, UnitFilter(0, (1 << (c_targetFilterStasis - 32)), 0, 0)) == false)) {
        random = RandomInt(1, 100);
        if (random <= zombieHandlerChance * 100) {
            UnitCreateEffectPoint(lv_playerHero, "AffixZombieHandlerCreationPersistent", lv_positionofMinion);
        }
    }
    return true;
}

