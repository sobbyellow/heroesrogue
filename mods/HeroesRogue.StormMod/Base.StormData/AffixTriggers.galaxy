    libAffx_AddBehavior(libAffx_player, "MuradinAvatarInitialDelay", 1, true);
    UnitCreateEffectUnit(libGame_gv_players[libAffx_player].lv_heroUnit, "MuradinAvatarApplyBehaviorsSet", libGame_gv_players[libAffx_player].lv_heroUnit);

    libAffx_RemoveBehavior(libAffx_player, "Ultimate1Unlocked", 1, true);
    return true;
