// Enemy Block
// ---------------------------------------------------------------
bool libAffx_EnemyBlockExecute (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    PlayerAddTalent(6, "GenericTalentBlock");
    PlayerAddTalent(7, "GenericTalentBlock");
    PlayerAddTalent(8, "GenericTalentBlock");
    PlayerAddTalent(9, "GenericTalentBlock");
    PlayerAddTalent(10, "GenericTalentBlock");
    return true;
}
// ---------------------------------------------------------------
// Unstoppable Avatar
// ---------------------------------------------------------------
bool libAffx_UnstoppableAvatarRespawn (bool testConds, bool runActions) {
    unit respawnedUnit = libGame_gf_HeroRespawnUnit();
    if (testConds) {
        if (UnitGetOwner(respawnedUnit) != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_AddBehavior(libAffx_player, "MuradinAvatarInitialDelay", 1, true);
    UnitCreateEffectUnit(respawnedUnit, "MuradinAvatarApplyBehaviorsSet", respawnedUnit);
    
    libAffx_RemoveBehavior(libAffx_player, "Ultimate1Unlocked", 1, true);
    libAffx_RemoveBehavior(libAffx_player, "MuradinSecondWind", 1, true);
    libAffx_RemoveBehavior(libAffx_player, "MuradinSecondWindActiveImproved", 1, true);
    return true;
}
bool libAffx_UnstoppableAvatarExecute (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_LevelUpScaling(c_gameCatalogEffect, "MuradinSecondWindImprovedCreateHealerPermanent", "RechargeVitalRate", libAffx_player);
    libAffx_LevelUpScaling(c_gameCatalogEffect, "MuradinSecondWindImprovedCriticalCreateHealerPermanent", "RechargeVitalRate", libAffx_player);
    CatalogFieldValueSet(c_gameCatalogBehavior, "MuradinAvatarHealthBuff", "Modification.VitalMaxArray[" + IntToString(0) + "]", libAffx_player, CatalogFieldValueGet(c_gameCatalogBehavior, "MuradinAvatar", "Modification.VitalMaxArray[" + IntToString(0) + "]", libAffx_player));
    
    libAffx_AddBehavior(libAffx_player, "MuradinAvatarInitialDelay", 1, true);
    UnitCreateEffectUnit(libGame_gv_players[libAffx_player].lv_heroUnit, "MuradinAvatarApplyBehaviorsSet", libGame_gv_players[libAffx_player].lv_heroUnit);

    libAffx_RemoveBehavior(libAffx_player, "Ultimate1Unlocked", 1, true);
    libAffx_RemoveBehavior(libAffx_player, "MuradinSecondWind", 1, true);
    libAffx_RemoveBehavior(libAffx_player, "MuradinSecondWindActiveImproved", 1, true);
    return true;
}
bool libAffx_UnstoppableAvatarLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_LevelUpScaling(c_gameCatalogEffect, "MuradinSecondWindImprovedCreateHealerPermanent", "RechargeVitalRate", libAffx_player);
    libAffx_LevelUpScaling(c_gameCatalogEffect, "MuradinSecondWindImprovedCriticalCreateHealerPermanent", "RechargeVitalRate", libAffx_player);
    CatalogFieldValueSet(c_gameCatalogBehavior, "MuradinAvatarHealthBuff", "Modification.VitalMaxArray[" + IntToString(0) + "]", libAffx_player, CatalogFieldValueGet(c_gameCatalogBehavior, "MuradinAvatar", "Modification.VitalMaxArray[" + IntToString(0) + "]", libAffx_player));
    return true;
}
// ---------------------------------------------------------------
// Second Start
// ---------------------------------------------------------------
bool libAffx_SecondStartExecuteOnce (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_QueueAffix(libAffx_rarityStarter, false, 1, 1, true);
    return true;
}
bool libAffx_SecondStartExecute (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_boonsLevel10 -= 1;
    return true;
}
// ---------------------------------------------------------------
// Explosive End
// ---------------------------------------------------------------
bool libAffx_ExplosiveEndExecute (bool testConds, bool runActions) {
    int i;
    if (!runActions) {
        return true;
    }
    for (i = 6; i <= 10; i += 1) {
        CatalogFieldValueSetFixed(c_gameCatalogEffect, "JunkratTotalMayhemDamage", "Amount", i, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "JunkratTotalMayhemDamage", "Amount", 0)) * Pow(1.04, UnitLevel(libGame_gv_players[i].lv_heroUnit)));
    }

    return true;
}
bool libAffx_ExplosiveEndLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player < 6) {
            return false;
        }
        if (player > 10) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    CatalogFieldValueSetFixed(c_gameCatalogEffect, "JunkratTotalMayhemDamage", "Amount", player, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "JunkratTotalMayhemDamage", "Amount", 0)) * Pow(1.04, level));

    return true;
}
// ---------------------------------------------------------------
// Lava Wave
// ---------------------------------------------------------------
int lavaWaveIndex;
bool libAffx_LavaWaveAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    lavaWaveIndex = libAffx_EventAffix("LavaWave");
    libGame_AddAbilityEffectMapping("AffixLavaWave", "RagnarosLavaWaveDamage");
    CatalogFieldValueSetFixed(c_gameCatalogEffect, "RagnarosLavaWaveDamage", "Amount", libAffx_teamChaos, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "RagnarosLavaWaveDamage", "Amount", 0)) * Pow(1.04, UnitLevel(libGame_gv_players[libAffx_enemy].lv_heroUnit)));
    TriggerEnable(libHMaj_gt_HeroRagnarosLavaWavePointTarget, true);
    TriggerAddEventPlayerEffectUsed(libHMaj_gt_HeroRagnarosLavaWavePointTarget, c_playerAny, "AffixLavaWave");

    return true;
}
bool libAffx_LavaWavePeriodic (bool testConds, bool runActions) {
    int random;
    point targetPoint;
    if (testConds) {
        if (libAffx_gamePaused) {
            return false;
        }
        if (lavaWaveIndex == 0) {
            return false;
        }
        if (!libAffx_GateIsOpen()) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    if (libAffx_affixes[lavaWaveIndex].cooldown <= 0) {
        random = RandomInt(1, 3);
        if (random == 1) {
            targetPoint = Point(202, 92);
        } else if (random == 2) {
            targetPoint = Point(186, 108);
        } else if (random == 3) {
            targetPoint = Point(194, 133);
        }
        UnitCreateEffectPoint(libGame_gv_teams[libAffx_teamChaosIndex].lv_core, "AffixLavaWave", targetPoint);
    
        libAffx_affixes[lavaWaveIndex].cooldown = 120;
    } else {
        libAffx_affixes[lavaWaveIndex].cooldown -= 0.0625;
    }

    return true;
}
bool libAffx_LavaWaveLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player != libAffx_enemy) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    CatalogFieldValueSetFixed(c_gameCatalogEffect, "RagnarosLavaWaveDamage", "Amount", libAffx_teamChaos, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "RagnarosLavaWaveDamage", "Amount", 0)) * Pow(1.04, level));

    return true;
}
