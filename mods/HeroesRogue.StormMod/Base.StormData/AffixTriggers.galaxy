        while ((UnitHasBehaviorWithCategoryFlag(EventUnit(), c_behaviorCategoryTimeStop) == true) || libAffx_gamePaused) {
            Wait(0.0625, c_timeGame);
        }
        libGame_gf_StormUniversalModifyCooldownonUnitCDRforAbilities(EventUnit(), -(blessingoftheDragonsCDR / 16), false, false, false);
        Wait(0.0625, c_timeGame);
    }
    return true;
}
// ---------------------------------------------------------------
// BUDDY
// ---------------------------------------------------------------
bool libAffx_BuddyAI (bool testConds, bool runActions) {
    unit ownerUnit;
    unit oldUnit;
    unit buddyUnit;
    int ownerPlayer;
    int currentState;
    fixed circleAngle;
    ownerUnit = EventPlayerEffectUsedUnit(c_effectUnitCaster);
    oldUnit = ownerUnit;
    if (testConds) {
        if (UnitGetType(ownerUnit) == "HeroLostVikingsController") {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    circleAngle = libNtve_gf_RandomAngle();
    currentState = buddyIdleState;
    ownerPlayer = EventPlayerEffectUsedUnitOwner(c_effectPlayerCaster);
    libNtve_gf_CreateUnitsAtPoint2(1, "AffixBuddyDrone", 0, ownerPlayer, PointWithOffsetPolar(UnitGetPosition(ownerUnit), 1.5, libNtve_gf_RandomAngle()), ownerUnit);
    buddyUnit = UnitLastCreated();
    UnitGroupAdd(libGame_gv_players[ownerPlayer].lv_summonedUnitGroup, buddyUnit);
    while ((UnitIsAlive(buddyUnit) == true) && (UnitIsAlive(ownerUnit) == true) && (UnitHasBehavior2(ownerUnit, "Dead") == false)) {
        circleAngle += 2.15;
        if (circleAngle >= 360) {
            circleAngle -= 360;
        }
        if (libGame_gv_players[ownerPlayer].lv_activeVehicle != null) {
            ownerUnit = libGame_gv_players[ownerPlayer].lv_activeVehicle;
        } else {
            ownerUnit = oldUnit;
        }
        while (UnitHasBehaviorWithCategoryFlag(ownerUnit, c_behaviorCategoryTimeStop)) {
            UnitGroupRemove(libGame_gv_players[ownerPlayer].lv_summonedUnitGroup, buddyUnit);
            UnitKill(buddyUnit);
            Wait(0.0625, c_timeGame);
        }
        // Heal owner
        if (UnitGroupCount(UnitGetTrackedUnitGroup(buddyUnit, "AffixBuddyHealUnitTracker"), c_unitCountAll) <= 0) {
            UnitIssueOrder(buddyUnit, OrderTargetingUnit(AbilityCommand("AffixBuddyHeal", 0), ownerUnit), c_orderQueueReplace);
        }
        // Movement
        if (UnitOrderCount(buddyUnit) <= 1) {
            if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(ownerUnit)) >= buddyTeleportRange)) {
                UnitSetPosition(buddyUnit, PointWithOffsetPolar(UnitGetPosition(ownerUnit), 1.5, libNtve_gf_RandomAngle()), false);
                UnitIssueOrder(buddyUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
                currentState = buddyIdleState;
            }
            else if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(ownerUnit)) >= buddyFollowRange) && (currentState != buddyLeashingState)) {
                UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(ownerUnit), -1.0, UnitGetFacing(ownerUnit))), c_orderQueueReplace);
                currentState = buddyLeashingState;
            }
            if (currentState == buddyIdleState && UnitOrderCount(buddyUnit) != 0 && OrderGetAbilityCommand(UnitOrder(ownerUnit, 0)) == AbilityCommand("move", 0)) {
                if ((DistanceBetweenPoints(OrderGetTargetPosition(UnitOrder(ownerUnit, 0)), UnitGetPosition(buddyUnit)) > buddyFollowRange)) {
                    UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(OrderGetTargetPosition(UnitOrder(ownerUnit, 0)), 1.0, UnitGetFacing(ownerUnit))), c_orderQueueReplace);
                    currentState = buddyMovingState;
                }
            }
            if (currentState == buddyIdleState && UnitOrderCount(buddyUnit) == 0) {
                currentState = buddyCirclingState;
                UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(ownerUnit), buddyFollowRange / 1.75, circleAngle)), c_orderQueueReplace);
            } else if (currentState == buddyCirclingState) {
                UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(ownerUnit), buddyFollowRange / 1.75, circleAngle)), c_orderQueueReplace);
            } else if (currentState == buddyMovingState) {
                if ((UnitOrderCount(buddyUnit) == 0)) {
                    currentState = buddyIdleState;
                } else {
                    if ((UnitOrderCount(ownerUnit) == 0)) {
                        if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(ownerUnit)) <= buddyFollowRange)) {
                            UnitIssueOrder(buddyUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
                            currentState = buddyIdleState;
                        }
                    }
                    else if ((OrderGetAbilityCommand(UnitOrder(ownerUnit, 0)) == AbilityCommand("move", 0))) {
                        if ((DistanceBetweenPoints(OrderGetTargetPosition(UnitOrder(ownerUnit, 0)), OrderGetTargetPosition(UnitOrder(buddyUnit, 0))) > buddyFollowRange / 2)) {
                            UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(OrderGetTargetPosition(UnitOrder(ownerUnit, 0)), 1.0, UnitGetFacing(ownerUnit))), c_orderQueueReplace);
                            currentState = buddyMovingState;
                        }
                    }
                }
            } else if (currentState == buddyLeashingState) {
                if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(ownerUnit)) <= buddyFollowRange)) {
                    UnitIssueOrder(buddyUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
                    currentState = buddyIdleState;
                }
                else {
                    if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(ownerUnit)) <= buddyFollowRange) && (UnitOrderCount(buddyUnit) == 0)) {
                        if ((UnitOrderCount(ownerUnit) == 0)) {
                            currentState = buddyIdleState;
                        }
                        else {
                            UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(ownerUnit), 1.0, UnitGetFacing(ownerUnit))), c_orderQueueReplace);
                            currentState = buddyLeashingState;
                        }
                    }
                    else {
                        if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(ownerUnit)) > buddyFollowRange) && (UnitOrderCount(buddyUnit) == 0)) {
                            UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(ownerUnit), 1.0, UnitGetFacing(ownerUnit))), c_orderQueueReplace);
                            currentState = buddyLeashingState;
                        }
                        else {
                            if ((DistanceBetweenPoints(UnitGetPosition(buddyUnit), OrderGetTargetPoint(UnitOrder(buddyUnit, 0))) <= buddyFollowRange) && (DistanceBetweenPoints(UnitGetPosition(buddyUnit), UnitGetPosition(ownerUnit)) > buddyFollowRange)) {
                                UnitIssueOrder(buddyUnit, OrderTargetingPoint(AbilityCommand("move", 0), PointWithOffsetPolar(UnitGetPosition(ownerUnit), 1.0, UnitGetFacing(ownerUnit))), c_orderQueueReplace);
                                currentState = buddyLeashingState;
                            }
                        }
                    }
                }
            }
        }
        libAffx_Wait(0.0625, c_timeGame);
    }
    UnitGroupRemove(libGame_gv_players[ownerPlayer].lv_summonedUnitGroup, buddyUnit);
    UnitKill(buddyUnit);
    UnitBehaviorRemove(ownerUnit, "AffixBuddyDroneOwner", 1);

    return true;
}
bool libAffx_BuddyLevelUp (bool testConds, bool runActions) {
    int level;
    if (testConds) {
        if (libGame_gf_HeroLevelUpPlayer() != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    level = libGame_gf_HeroLevelUpLevel();

    CatalogFieldValueSetFixed(c_gameCatalogEffect, "AffixBuddyHealCreateHealer", "RechargeVitalRate", libGame_gf_HeroLevelUpPlayer(), buddyHealing * Pow(1.04, level));
    CatalogFieldValueSetFixed(c_gameCatalogEffect, "AffixBuddyDroneMissileDamage", "Amount", libGame_gf_HeroLevelUpPlayer(), buddyDamage * Pow(1.04, level));

    return true;
}
// ---------------------------------------------------------------
// Many Rituals
// ---------------------------------------------------------------
bool libAffx_ManyRituals (bool testConds, bool runActions) {
    int stacks = libAffx_EventAffixCount("ManyRituals");
    unit heroUnit;
    if (!runActions) {
        return true;
    }
    heroUnit = libGame_gv_players[libAffx_player].lv_heroUnit;
    
    UnitSetTokenCount(heroUnit, "WitchDoctorVoodooRitual", UnitGetTokenCount(heroUnit, "WitchDoctorVoodooRitual") + manyRitualsStacksInitial + (manyRitualsStacks * (stacks - 1)), heroUnit);
    UnitSetTokenCount(heroUnit, "WitchDoctorThingOfTheDeepQuestToken", UnitGetTokenCount(heroUnit, "WitchDoctorThingOfTheDeepQuestToken") + manyRitualsStacksInitial + (manyRitualsStacks * (stacks - 1)), heroUnit);
    
    return true;
}
