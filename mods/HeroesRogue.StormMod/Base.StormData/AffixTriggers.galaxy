// ---------------------------------------------------------------
// Enemy Speed
// ---------------------------------------------------------------
int enemySpeed;
fixed enemySpeedModifier = 0.25;
bool libAffx_EnemySpeedBehaviorChange (bool testConds, bool runActions) {
    if (testConds) {
        if (enemySpeed == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    while ((UnitHasBehavior2(EventUnit(), "AffixEnemySpeedBuff") == true)) {
        while ((UnitHasBehaviorWithCategoryFlag(EventUnit(), c_behaviorCategoryTimeStop) == true) || libAffx_gamePaused) {
            Wait(0.0625, c_timeGame);
        }
        libGame_gf_StormUniversalModifyCooldownonUnitCDRforAbilities(EventUnit(), -(enemySpeedModifier) / 16, true, true, false);
        Wait(0.0625, c_timeGame);
    }
    return true;
}
