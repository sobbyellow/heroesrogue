// ---------------------------------------------------------------
fixed ringOfMagicModifier = 0.05;
bool libAffx_RingOfMagicBehaviorChange (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    while ((UnitHasBehavior2(EventUnit(), "AffixRingofMagic") == true)) {
        while ((UnitHasBehaviorWithCategoryFlag(EventUnit(), c_behaviorCategoryTimeStop) == true) || libAffx_gamePaused) {
            Wait(0.0625, c_timeGame);
        }
        libGame_gf_StormUniversalModifyCooldownonUnitCDRforAbilities(EventUnit(), -(ringOfMagicModifier) / 16, true, true, false);
        Wait(0.0625, c_timeGame);
    }
    return true;
}
