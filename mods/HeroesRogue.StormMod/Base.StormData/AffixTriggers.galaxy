bool libAffx_SpecializedVikingsExecute (bool testConds, bool runActions) {
    int i;
    unitgroup unitGroup;
    int unitGroupCount;
    if (!runActions) {
        return true;
    }
    unitGroup = libGame_gv_players[libAffx_player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    for (i = unitGroupCount; i > 0; i -= 1) {
        if (UnitGetType(UnitGroupUnitFromEnd(unitGroup, i)) == "HeroErik") {
            UnitBehaviorAdd(UnitGroupUnitFromEnd(unitGroup, i), "AffixErik", UnitGroupUnitFromEnd(unitGroup, i), 1);
        } else if (UnitGetType(UnitGroupUnitFromEnd(unitGroup, i)) == "HeroBaleog") {
            UnitBehaviorAdd(UnitGroupUnitFromEnd(unitGroup, i), "AffixBaleog", UnitGroupUnitFromEnd(unitGroup, i), 1);
        } else if (UnitGetType(UnitGroupUnitFromEnd(unitGroup, i)) == "HeroOlaf") {
            UnitBehaviorAdd(UnitGroupUnitFromEnd(unitGroup, i), "AffixOlaf", UnitGroupUnitFromEnd(unitGroup, i), 1);
        }
    }
    
    return true;
}
