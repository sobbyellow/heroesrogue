// ---------------------------------------------------------------
// Cloned
// ---------------------------------------------------------------
int clonedIndex;
int clones;
bool libAffx_ClonedAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    clonedIndex = libAffx_EventAffix("Cloned");
    return true;
}
bool libAffx_ClonedUnitDied (bool testConds, bool runActions) {
    unit deadUnit = EventUnit();
    if (testConds) {
        if (UnitGetOwner(deadUnit) != libAffx_teamChaos) {
            return false;
        }
        if (!UnitHasBehavior2(deadUnit, "AffixClone")) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libNtve_gf_MakeUnitUncommandable(deadUnit, true);
    clones = MaxI(0, clones - 1);
    UnitRemove(deadUnit);
    return true;
}
bool libAffx_ClonedPeriodic (bool testConds, bool runActions) {
    int random;
    int unitCount;
    unitgroup unitGroup;
    unit unitVar;
    if (testConds) {
        if (libAffx_gamePaused) {
            return false;
        }
        if (clonedIndex == 0) {
            return false;
        }
        if (!libAffx_GateIsOpen()) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (libAffx_affixes[clonedIndex].cooldown <= 0) {
        random = RandomInt(6, 10);
        unitVar = libGame_gv_players[random].lv_heroUnit;
        // Block Leoric, Medivh, Rexxar, and Abathur due to issues with clones
        if (UnitGetType(unitVar) != "HeroLostVikingsController" && UnitGetType(unitVar) != "HeroMedivh" && UnitGetType(unitVar) != "HeroLeoric" && UnitGetType(unitVar) != "HeroRexxar" && UnitGetType(unitVar) != "HeroAbathur" ) {
            libNtve_gf_CreateUnitsAtPoint2(1, UnitGetType(unitVar), 0, random, libGame_gv_players[random].lv_spawnPoint, null);
            libNtve_gf_SendActorMessageToUnit(UnitLastCreated(), "SetTintColor 135,135,255");
            libNtve_gf_SendActorMessageToUnit(UnitLastCreated(), "SetOpacity 0.6");
            UnitBehaviorAdd(UnitLastCreated(), "HeroGenericPermanentHallucinationFlag", UnitLastCreated(), 1);
            UnitBehaviorAdd(UnitLastCreated(), "UltimateEvolutionPlaystyleAdjustment", UnitLastCreated(), 1);
            UnitBehaviorAdd(UnitLastCreated(), "AffixClone", UnitLastCreated(), 1);
            UnitBehaviorAdd(UnitLastCreated(), "SuppressGenericDeath", UnitLastCreated(), 1);
            UnitBehaviorAdd(UnitLastCreated(), "SuppressGenericDeathRagdoll", UnitLastCreated(), 1);
            UnitBehaviorAdd(UnitLastCreated(), "CapturePointAllowed", UnitLastCreated(), 1);
            UnitBehaviorAdd(UnitLastCreated(), "UltimateEvolutionThreatIncrease", UnitLastCreated(), 1);
            UnitSetPropertyFixed(UnitLastCreated(), c_unitPropXP, 0);
            UnitSetPropertyFixed(UnitLastCreated(), c_unitPropKillXP, 0);
            AIAddPlayerUnit(UnitLastCreated());
            clones += 1;
            libAffx_affixes[clonedIndex].cooldown = 200;
        }
        libAffx_Wait(1, c_timeGame);
    } else {
        if (clones > 0) {
            libAffx_affixes[clonedIndex].cooldown -= 0.0625;
        } else {
            libAffx_affixes[clonedIndex].cooldown -= 0.125;
        }
    }
    return true;
}
// ---------------------------------------------------------------
// Structure Ammo
// ---------------------------------------------------------------
bool libAffx_StructureAmmoExecute (bool testConds, bool runActions) {
    int i;
    unit unitVar;
    unitgroup unitGroup;
    if (!runActions) {
        return true;
    }
    CatalogFieldValueModify(c_gameCatalogActor, "TownCannonTowerL2", "CustomUnitStatusFrame", libAffx_teamOrder, "AffixUI/TowerUnitStatusFrameTemplateRealAmmo", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogActor, "TownCannonTowerL3", "CustomUnitStatusFrame", libAffx_teamOrder, "AffixUI/TowerUnitStatusFrameTemplateRealAmmo", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogActor, "TownCannonTowerL2Standalone", "CustomUnitStatusFrame", libAffx_teamOrder, "AffixUI/TowerUnitStatusFrameTemplateRealAmmo", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogActor, "TownCannonTowerL3Standalone", "CustomUnitStatusFrame", libAffx_teamOrder, "AffixUI/TowerUnitStatusFrameTemplateRealAmmo", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogActor, "TownTownHallL2", "CustomUnitStatusFrame", libAffx_teamOrder, "AffixUI/TowerUnitStatusFrameTemplate40RealAmmo", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogActor, "TownTownHallL3", "CustomUnitStatusFrame", libAffx_teamOrder, "AffixUI/TowerUnitStatusFrameTemplate40RealAmmo", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogEffect, "StructureAmmoConsumeAmmoSet", "Chance", libAffx_teamOrder, "1", c_upgradeOperationSet);
    unitGroup = UnitGroup(null, libAffx_teamOrder, RegionEntireMap(), UnitFilter(1 << c_targetFilterStructure, 0, 0, 0), 0);
    i = UnitGroupCount(unitGroup, c_unitCountAll);
    for (;; i -= 1) {
        unitVar = UnitGroupUnitFromEnd(unitGroup, i);
        if (unitVar == null) {
            break;
        }
        if (UnitGetType(unitVar) == "TownCannonTowerL2" || UnitGetType(unitVar) == "TownCannonTowerL3" || UnitGetType(unitVar) == "TownCannonTowerL2Standalone" || UnitGetType(unitVar) == "TownCannonTowerL3Standalone") {
            UnitSetPropertyFixed(unitVar, c_unitPropEnergyMax, 20);
            UnitBehaviorAdd(unitVar, "StructureAmmoMonitor", unitVar, 1);
            UnitBehaviorAdd(unitVar, "StructureAmmoReplenisher", unitVar, 1);
        }
        if (UnitGetType(unitVar) == "TownTownHallL2" || UnitGetType(unitVar) == "TownTownHallL3") {
            UnitSetPropertyFixed(unitVar, c_unitPropEnergyMax, 40);
            UnitBehaviorAdd(unitVar, "StructureAmmoMonitor", unitVar, 1);
            UnitBehaviorAdd(unitVar, "StructureAmmoReplenisher", unitVar, 1);
        }
    }

    return true;
}
// ---------------------------------------------------------------
// Grenadier
// ---------------------------------------------------------------
int[6] grenadierPlayers;
bool libAffx_GrenadierExecute (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libGame_AddAbilityEffectMapping("TychusGrenade", "TychusGrenadeDamage");
    libGame_AddAbilityEffectMapping("AnaBioticGrenade", "AnaBioticGrenadeEnemyImpactDamage");
    libGame_AddAbilityEffectMapping("ZaryaParticleGrenade", "ZaryaParticleGrenadeDamageAffix");
    return true;
}
bool libAffx_GrenadierAffixAdded (bool testConds, bool runActions) {
    int i;
    int amount;
    if (!runActions) {
        return true;
    }
    amount = MinI(libAffx_affixes[libAffx_EventAffix("Grenadier")].count, 5);
    for (i = 1; i <= amount; i += 1) {
        if (grenadierPlayers[i] == 0) {
            grenadierPlayers[i] = 5 + i;
            if (UnitGetType(libGame_gv_players[5 + i].lv_heroUnit) == "HeroDVaPilot" || UnitGetType(libGame_gv_players[5 + i].lv_heroUnit) == "HeroDVaMech") {
                libAffx_AddBehavior(5 + i, "AffixGrenadier", 1, false);
            } else {
                libAffx_AddBehavior(5 + i, "AffixGrenadier", 1, true);
            }
        }
    }
    return true;
}
bool libAffx_GrenadierLevelUp (bool testConds, bool runActions) {
    int level;
    int player = libGame_gf_HeroLevelUpPlayer();
    if (testConds) {
        if (player != grenadierPlayers[1] && player != grenadierPlayers[2] && player != grenadierPlayers[3] && player != grenadierPlayers[4] && player != grenadierPlayers[5]) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    level = libGame_gf_HeroLevelUpLevel();
    CatalogFieldValueSetFixed(c_gameCatalogEffect, "TychusGrenadeDamage", "Amount", player, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "TychusGrenadeDamage", "Amount", 0)) * Pow(1.04, level));
    CatalogFieldValueSetFixed(c_gameCatalogEffect, "AnaBioticGrenadeEnemyImpactDamage", "Amount", player, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "AnaBioticGrenadeEnemyImpactDamage", "Amount", 0)) * Pow(1.04, level));
    CatalogFieldValueSetFixed(c_gameCatalogEffect, "AnaBioticGrenadeAllyImpactCreateHealer", "RechargeVitalRate", player, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "AnaBioticGrenadeAllyImpactCreateHealer", "RechargeVitalRate", 0)) * Pow(1.04, level));
    CatalogFieldValueSetFixed(c_gameCatalogEffect, "ZaryaParticleGrenadeDamageAffix", "Amount", player, StringToFixed(CatalogFieldValueGet(c_gameCatalogEffect, "ZaryaParticleGrenadeDamageAffix", "Amount", 0)) * 3 * Pow(1.04, level));
    return true;
}
bool libAffx_GrenadierEffectUsed (bool testConds, bool runActions) {
    int random;
    unit caster;
    unit target;
    if (!runActions) {
        return true;
    }
    caster = EventPlayerEffectUsedUnit(c_effectUnitCaster);
    target = EventPlayerEffectUsedUnit(c_effectUnitTarget);
    random = RandomInt(1, 3);
    if (random == 1) {
        UnitCreateEffectUnit(caster, "GrenadeInitialSet", target);
    } else if (random == 2) {
        UnitCreateEffectUnit(caster, "AnaBioticGrenadeInitialSet", target);
    } else if (random == 3) {
        UnitCreateEffectUnit(caster, "ZaryaParticleGrenadeLaunchMissileAffix", target);
    }

    return true;
}
// ---------------------------------------------------------------
// Great Viking Hoard
// ---------------------------------------------------------------
bool libAffx_GreatVikingHoardUnitDied (bool testConds, bool runActions) {
    int i;
    unit deadUnit = EventUnit();
    if (testConds) {
        if (UnitGetOwner(deadUnit) < 6 || UnitGetOwner(deadUnit) > 10) {
            return false;
        }
        if (!UnitTypeTestAttribute(UnitGetType(deadUnit), c_unitAttributeHeroic)) {
            return false;
        }
        if (UnitTestState(deadUnit, c_unitStateHallucination)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    for (i = 1; i <= 5; i += 1) {
        UnitCreate(1, "RegenGlobe", c_unitCreateIgnorePlacement, libAffx_teamOrder, PointWithOffsetPolar(UnitGetPosition(deadUnit), 2, 72 * i), 0, null);
        UnitBehaviorRemove(UnitLastCreated(), "RegenGlobeTimedLifeInitial", 1);
        UnitBehaviorAdd(UnitLastCreated(), "RegenGlobeTimedLife", UnitLastCreated(), 1);
    }
              
    return true;
}
bool libAffx_GreatVikingHoardUnitDiedStructure (bool testConds, bool runActions) {
    unit deadUnit = EventUnit();
    if (testConds) {
        if (UnitGetOwner(deadUnit) != 12) {
            return false;
        }
        if (!UnitTypeTestAttribute(UnitGetType(deadUnit), c_unitAttributeStructure)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    UnitCreate(1, "RegenGlobe", c_unitCreateIgnorePlacement, libAffx_teamOrder, UnitGetPosition(deadUnit), 0, null);
    UnitBehaviorRemove(UnitLastCreated(), "RegenGlobeTimedLifeInitial", 1);
    UnitBehaviorAdd(UnitLastCreated(), "RegenGlobeTimedLife", UnitLastCreated(), 1);
    UnitBehaviorSetDuration(UnitLastCreated(), "RegenGlobeTimedLife", 6);
              
    return true;
}
