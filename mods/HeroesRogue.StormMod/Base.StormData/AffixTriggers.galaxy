// ---------------------------------------------------------------
// Nano Boost
// ---------------------------------------------------------------
fixed libAffx_nanoBoostCDR = 0.75;
bool libAffx_NanoBoostAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_nanoBoostCDR = 0.75 * libAffx_EventAffixCount();
    return true;
}
bool libAffx_NanoBoostBehaviorChange (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    while ((UnitHasBehavior2(EventUnit(), "AffixNanoBoost") == true)) {
        while ((UnitHasBehaviorWithCategoryFlag(EventUnit(), c_behaviorCategoryTimeStop) == true) || libAffx_gamePaused) {
            Wait(0.0625, c_timeGame);
        }
        libGame_gf_StormUniversalModifyCooldownonUnitCDRforAbilities(EventUnit(), -(libAffx_nanoBoostCDR / 16), false, false, false);
        Wait(0.0625, c_timeGame);
    }
    return true;
}
