// ---------------------------------------------------------------
// Path of the Assassin
// ---------------------------------------------------------------
fixed pathoftheAssassinValue = 5;
bool libAffx_HasFastAA(int heroIndex) {
    if (heroIndex == libCore_gf_GetIndexFromHero("DVa")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Tassadar")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Tychus")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Zarya")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Kharazim")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Lucio")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Genji")) {
        return true;
    }
    return false;
}
bool libAffx_PathoftheAssassinExecute (bool testConds, bool runActions) {
    int level;
    if (!runActions) {
        return true;
    }
    level = UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit);
    if (libAffx_playerHeroIndex == libCore_gf_GetIndexFromHero("Tracer")) {
        pathoftheAssassinValue = 1;
    } else if (libAffx_HasFastAA(libAffx_playerHeroIndex)) {
        pathoftheAssassinValue = 2;
    } else {
        pathoftheAssassinValue = 5;
    }
    CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixPathoftheAssassin", "Modification.DamageDealtScaled[Basic]", libAffx_player, pathoftheAssassinValue * level);
    
    return true;
}
bool libAffx_PathoftheAssassinLevelUp (bool testConds, bool runActions) {
    int level;
    if (testConds) {
        if (libGame_gf_HeroLevelUpPlayer() != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    level = libGame_gf_HeroLevelUpLevel();

    CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixPathoftheAssassin", "Modification.DamageDealtScaled[Basic]", libGame_gf_HeroLevelUpPlayer(), pathoftheAssassinValue * level);
    return true;
}

