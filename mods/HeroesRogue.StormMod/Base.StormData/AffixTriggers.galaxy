// ---------------------------------------------------------------
// Critical Mass
// ---------------------------------------------------------------
bool libAffx_CriticalMassHT (bool testConds, bool runActions) {
    int player = libGame_gf_HeroParticipatedInTakedownKillingPlayer();
    unit killerUnit = libGame_gv_players[player].lv_heroUnit;
    unit deadUnit = libGame_gf_HeroParticipatedInTakedownKilledHero();

    if (testConds) {
        if (!UnitIsAlive(killerUnit)) {
            return false;
        }
        if ((player != libAffx_player) && libAffx_choPlayer == 0) {
            return false;
        }
        if ((player != libAffx_choPlayer && player != libAffx_gallPlayer) && libAffx_choPlayer != 0) {
            return false;
        }
        if (UnitTestState(deadUnit, c_unitStateHallucination)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    libAffx_ResetCooldowns(killerUnit);
    
    return true;
}
