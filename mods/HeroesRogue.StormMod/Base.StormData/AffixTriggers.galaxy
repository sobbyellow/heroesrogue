// No Minimap DLC
// ---------------------------------------------------------------
bool libAffx_NoMinimapDLCExecute (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    UISetFrameVisible(libCore_gv_playerGroupFromPlayer[libAffx_player], c_syncFrameTypeMinimapPanel, false);
    return true;
}
