// ---------------------------------------------------------------
// Convenient Portals
// ---------------------------------------------------------------
bool libAffx_ConvenientPortalsExecute (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    CatalogFieldValueModify(c_gameCatalogBehavior, "MedivhPortalTimedLife", "Duration", libAffx_teamOrder, "-1", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogEffect, "MedivhPortalDirectionSearch", "AreaArray[0].Radius", libAffx_teamOrder, "500", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogEffect, "MedivhPortalCreationDirectionSearch", "AreaArray[0].Radius", libAffx_teamOrder, "500", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogEffect, "MedivhPortalDirectionDummy", "Chance", libAffx_teamOrder, "0", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogActor, "MedivhPortalRealUnit", "CustomUnitStatusFrame", libAffx_teamOrder, "", c_upgradeOperationSet);
    while (!libAffx_GateIsOpen()) {
        Wait(1, c_timeGame);
    }
    if (libAffx_currentMap == libAffx_mapCursedHollow) {
        UnitCreate(1, "MedivhPortalCreation", c_unitCreateIgnorePlacement, libAffx_teamOrder, Point(122, 166), 0, null);
        UnitCreate(1, "MedivhPortalCreation", c_unitCreateIgnorePlacement, libAffx_teamOrder, Point(125, 49), 0, null);
    } else if (libAffx_currentMap == libAffx_mapShrines) {
        UnitCreate(1, "MedivhPortalCreation", c_unitCreateIgnorePlacement, libAffx_teamOrder, Point(124.3, 151.26), 0, null);
        UnitCreate(1, "MedivhPortalCreation", c_unitCreateIgnorePlacement, libAffx_teamOrder, Point(124.05, 40.19), 0, null);
    } else if (libAffx_currentMap == libAffx_mapCrypts) {
        UnitCreate(1, "MedivhPortalCreation", c_unitCreateIgnorePlacement, libAffx_teamOrder, Point(124.08, 140), 0, null);
        UnitCreate(1, "MedivhPortalCreation", c_unitCreateIgnorePlacement, libAffx_teamOrder, Point(124.14, 45.11), 0, null);
    } else if (libAffx_currentMap == libAffx_mapDragonShire) {
        UnitCreate(1, "MedivhPortalCreation", c_unitCreateIgnorePlacement, libAffx_teamOrder, Point(124.15, 146.24), 0, null);
        UnitCreate(1, "MedivhPortalCreation", c_unitCreateIgnorePlacement, libAffx_teamOrder, Point(123.96, 53.97), 0, null);
    }

    return true;
}
// ---------------------------------------------------------------
// Periodic Regen Globes
// ---------------------------------------------------------------
int perRegenGlobeIndex;
bool libAffx_PeriodicRegenGlobesAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    perRegenGlobeIndex = libAffx_EventAffix("PeriodicRegenGlobes");

    CatalogFieldValueModify(c_gameCatalogBehavior, "RegenGlobeTimedLifeInitial", "Duration", libAffx_teamOrder, "6", c_upgradeOperationSet);
    CatalogFieldValueModify(c_gameCatalogBehavior, "RegenGlobeTimedLifeInitial", "Period", libAffx_teamOrder, "4.5", c_upgradeOperationSet);

    return true;
}
bool libAffx_PeriodicRegenGlobesPeriodic (bool testConds, bool runActions) {
    int unitCount;
    int random;
    unit unitVar;
    if (testConds) {
        if (libAffx_gamePaused) {
            return false;
        }
        if (perRegenGlobeIndex == 0) {
            return false;
        }
        if (!libAffx_GateIsOpen()) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    if (libAffx_affixes[perRegenGlobeIndex].cooldown <= 0) {
        random = RandomInt(1, 6);
        if (random == 6) {
            random = 1;
        }
        unitCount = UnitGroupCount(libGame_gv_players[random].lv_heroUnitGroup, c_unitCountAll);
        for (;; unitCount -= 1) {
            unitVar = UnitGroupUnitFromEnd(libGame_gv_players[random].lv_heroUnitGroup, unitCount);
            if (UnitIsAlive(unitVar) && UnitGetType(unitVar) != "HeroLostVikingsController") {
                UnitCreate(1, "RegenGlobe", c_unitCreateIgnorePlacement, libAffx_teamOrder, PointWithOffset(UnitGetPosition(unitVar), 2 * (RandomInt(0, 1) * 2) - 1, 2 * (RandomInt(0, 1) * 2) - 1), 0, null);
                libAffx_affixes[perRegenGlobeIndex].cooldown = 16 - 4 * libAffx_affixes[perRegenGlobeIndex].count;
            }
            if (unitCount <= 0) { break; }
        }
    } else {
        libAffx_affixes[perRegenGlobeIndex].cooldown -= 0.0625;
    }

    return true;
}
// ---------------------------------------------------------------
// Evasive
// ---------------------------------------------------------------
bool libAffx_EvasiveUnitCreated (bool testConds, bool runActions) {
    int player = UnitGetOwner(EventUnitCreatedUnit());
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_AddBehavior(libAffx_player, "IllidanEvasion", 1, true);
    libAffx_AddBehavior(libAffx_player, "IllidanEvasionSpellArmor", 1, true);
    return true;
}
