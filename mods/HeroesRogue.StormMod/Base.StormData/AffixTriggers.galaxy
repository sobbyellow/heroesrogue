// ---------------------------------------------------------------
// Kill Contract
// ---------------------------------------------------------------
int killContract;
bool killContractSuppressRewards;
bool libAffx_KillContractAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    killContract = libAffx_EventAffix();
    return true;
}
bool libAffx_KillContract (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_AddBehavior(libAffx_player, "AffixKillContractQuestToken", 1, false);
    
    return true;
}
bool libAffx_KillContractQuestComplete (bool testConds, bool runActions) {
    if (testConds) {
        if (killContract == 0) {
            return false;
        }
        if (killContractSuppressRewards) {
            return false;
        }
        if (libAffx_affixes[killContract].quest.questDone) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_QueueAffix(libAffx_rarityCommon, false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), 1, true);
    libAffx_QueueAffix(libAffx_rarityUncommon, false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), 1, true);
    libAffx_affixes[killContract].quest.questDone = true;
    
    return true;
}
bool libAffx_KillContractHeroTakedown (bool testConds, bool runActions) {
    int maxStacks = 25;
    int player = libGame_gf_HeroParticipatedInTakedownKillingPlayer();
    unit playerUnit = libGame_gv_players[player].lv_heroUnit;
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
        if (!libAffx_PlayerHasBehavior(player, "AffixKillContractQuestToken")) {
            return false;
        }
        if (!(libAffx_PlayerBehaviorCount(player, "AffixKillContractQuestToken") < maxStacks)) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    libAffx_UnitCreateEffectUnit(player, "AffixKillContractIncrementToken");
    libAffx_affixes[killContract].quest.questProgress += 1;
    
    return true;
}
bool libAffx_KillContractUnitBehaviorCreate (bool testConds, bool runActions) {
    unit heroUnit = EventUnit();
    if (testConds) {
        if (!UnitHasBehavior2(heroUnit, "AffixKillContractQuestToken")) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    killContractSuppressRewards = true;
    UnitSetTokenCount(heroUnit, "AffixKillContractQuestToken", libAffx_affixes[killContract].quest.questProgress, heroUnit);
    killContractSuppressRewards = false;
    return true;
}

// ---------------------------------------------------------------
// Structure Quest
// ---------------------------------------------------------------
int structureQuestIndex;
bool structureQuestSuppressRewards;
bool[4] structureQuestFinished;
bool libAffx_StructureQuestAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }

    structureQuestIndex = libAffx_EventAffix();
    return true;
}
bool libAffx_StructureQuest (bool testConds, bool runActions) {
    int quest;
    if (!runActions) {
        return true;
    }
    quest = libAffx_affixes[libAffx_executingAffix].quest.questProgress;
    libAffx_AddBehavior(libAffx_player, "AffixStructureQuestToken", 1, false);
    
    if (quest > 0) {
        structureQuestSuppressRewards = true;
        libAffx_ModifyTokenCount(libAffx_player, quest, "AffixStructureQuestToken");
        libAffx_Wait(0.0625, c_timeGame);
        structureQuestSuppressRewards = false;
    }
    
    return true;
}
bool libAffx_StructureQuestUD (bool testConds, bool runActions) {
    int maxStacks = 24;
    unit dyingStructure;
    int victimTeam;
    unit playerUnit;

    dyingStructure = EventUnit();
    victimTeam = libGame_gf_TeamNumberOfPlayer(UnitGetOwner(dyingStructure));
    playerUnit = libGame_gv_players[libAffx_player].lv_heroUnit;

    if (testConds) {
        if (!UnitTypeTestAttribute(UnitGetType(dyingStructure), c_unitAttributeStructure)) {
            return false;
        }
        if (UnitGetType(dyingStructure) != "TownTownHallL2" && UnitGetType(dyingStructure) != "TownTownHallL3") {
            return false;
        }
        if (victimTeam != libGame_gv_teamChaosIndex_C) {
            return false;
        }
        if (!libAffx_PlayerHasBehavior(libAffx_player, "AffixStructureQuestToken")) {
            return false;
        }
        if (!(libAffx_PlayerBehaviorCount(libAffx_player, "AffixStructureQuestToken") < maxStacks)) {
            return false;
        }
        if (structureQuestIndex == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_UnitCreateEffectUnit(libAffx_player, "AffixStructureQuestIncrementToken");
    libAffx_affixes[structureQuestIndex].quest.questProgress += 1;
    
    return true;
}
bool libAffx_StructureQuestComplete (bool testConds, bool runActions) {
    if (testConds) {
        if (structureQuestSuppressRewards) {
            return false;
        }
        if (structureQuestIndex == 0) {
            return false;
        }
        if (libAffx_affixes[structureQuestIndex].quest.questDone) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_QueueAffix(libAffx_rarityRare, false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), 1, true);
    libAffx_affixes[structureQuestIndex].quest.questDone = true;
    
    return true;
}
bool libAffx_StructureQuest6 (bool testConds, bool runActions) {
    if (testConds) {
        if (structureQuestSuppressRewards) {
            return false;
        }
        if (structureQuestFinished[1]) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_QueueAffix(libAffx_rarityCommon, false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), 1, true);
    structureQuestFinished[1] = true;
    
    return true;
}
bool libAffx_StructureQuest12 (bool testConds, bool runActions) {
    if (testConds) {
        if (structureQuestSuppressRewards) {
            return false;
        }
        if (structureQuestFinished[2]) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_QueueAffix(libAffx_rarityUncommon, false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), 1, true);
    structureQuestFinished[2] = true;
    
    return true;
}
bool libAffx_StructureQuestUnitBehaviorCreate (bool testConds, bool runActions) {
    unit heroUnit = EventUnit();
    if (testConds) {
        if (!UnitHasBehavior2(heroUnit, "AffixStructureQuestToken")) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    structureQuestSuppressRewards = true;
    UnitSetTokenCount(heroUnit, "AffixStructureQuestToken", libAffx_affixes[structureQuestIndex].quest.questProgress, heroUnit);
    structureQuestSuppressRewards = false;
    return true;
}
// ---------------------------------------------------------------
// Fortifications
// ---------------------------------------------------------------
int fortificationsIndex;
bool[12] fortificationsSpawned;
int fortificationsTotal = 0;
void libAffx_FortificationsCreateTower(int id, string unitName, point location, fixed rotation) {
    if (fortificationsSpawned[id] == false) {
        fortificationsSpawned[id] = true;
        UnitCreate(1, unitName, c_unitCreateIgnorePlacement, libAffx_teamChaos, location, rotation, null);
        UnitBehaviorAdd(UnitLastCreated(), "AffixFortificationsTowerReveal", UnitLastCreated(), 1);
        ActorSend(libNtve_gf_MainActorofUnit(UnitLastCreated()), "Signal PlayBuild");
        fortificationsTotal += 1;
    }
}
bool libAffx_FortificationsAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
