// ---------------------------------------------------------------
// Path of the Assassin
// ---------------------------------------------------------------
fixed pathoftheAssassinValue = 4;
fixed pathoftheAssassinValue2 = 2;
int pathOfTheAssassinIndex;
bool libAffx_HasFastAA(int heroIndex) {
    if (heroIndex == libCore_gf_GetIndexFromHero("DVa")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Tassadar")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Tychus")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Zarya")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Lucio")) {
        return true;
    } else if (heroIndex == libCore_gf_GetIndexFromHero("Genji")) {
        return true;
    }
    return false;
}
void libAffx_PathoftheAssassinInit() {
    if (libAffx_playersHeroIndex[libAffx_player] == libCore_gf_GetIndexFromHero("Tracer")) {
        pathoftheAssassinValue = 1;
        pathoftheAssassinValue2 = 1;
    } else if (libAffx_HasFastAA(libAffx_playersHeroIndex[libAffx_player])) {
        pathoftheAssassinValue = 2;
        pathoftheAssassinValue2 = 1;
    } else {
        pathoftheAssassinValue = 4;
        pathoftheAssassinValue2 = 2;
    }
}
bool libAffx_PathoftheAssassinExecuteImmediate (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    libAffx_PathoftheAssassinInit();
    return true;
}
bool libAffx_PathoftheAssassinAffixAdded (bool testConds, bool runActions) {
    int level;
    if (!runActions) {
        return true;
    }
    pathOfTheAssassinIndex = libAffx_EventAffix();
    level = UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit);
    libAffx_PathoftheAssassinInit();
    libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixPathoftheAssassin", "Modification.DamageDealtScaled[Basic]", libAffx_player, (pathoftheAssassinValue + pathoftheAssassinValue2 * (libAffx_affixes[pathOfTheAssassinIndex].count - 1)) * level);
    
    return true;
}
bool libAffx_PathoftheAssassinLevelUp (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (testConds) {
        if (player != libAffx_player && !UnitHasBehavior2(libGame_gv_players[player].lv_heroUnit, "AffixPathoftheAssassin")) {
            return false;
        }
        if (pathOfTheAssassinIndex == 0) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    libAffx_CatalogFieldValueSetFixed(c_gameCatalogBehavior, "AffixPathoftheAssassin", "Modification.DamageDealtScaled[Basic]", player, (pathoftheAssassinValue + pathoftheAssassinValue2 * (libAffx_affixes[pathOfTheAssassinIndex].count - 1)) * level);
    return true;
}

