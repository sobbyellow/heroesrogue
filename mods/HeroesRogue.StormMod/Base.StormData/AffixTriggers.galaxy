// ---------------------------------------------------------------
// Memory Shortage
// ---------------------------------------------------------------
bool libAffx_MemoryShortage (bool testConds, bool runActions) {
    int affix;
    int amount;
    int difficulty;
    int i;
    if (!runActions) {
        return true;
    }
    affix = libAffx_EventAffix("MemoryShortage");
    amount = libAffx_affixes[affix].count;
    
    if (amount == 1) {
        difficulty = libAIAI_ge_HeroAIDifficulty_HeroAIVeryHard;
    } else if (amount == 2) {
        difficulty = libAIAI_ge_HeroAIDifficulty_HeroAIMedium;
    } else if (amount == 3) {
        difficulty = libAIAI_ge_HeroAIDifficulty_HeroAIEasy;
    } else if (amount == 4) {
        difficulty = libAIAI_ge_HeroAIDifficulty_HeroAIVeryEasy;
    } else {
        difficulty = libAIAI_ge_HeroAIDifficulty_HeroAIElite;
    }
    libAffx_Wait(1.25, c_timeGame);
    for (i = 2; i <= 5; i += 1) {
        libAIAI_gf_HeroAISetAIDifficultyLevel(i, difficulty);
        UnitIssueOrder(libAIAI_gv_aIHeroes[i].lv_currentHeroUnit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
        AIEnableForPlayer(i, (libAIAI_gv_aIHeroes[i].lv_difficulty));
        DialogControlHookupStandard(c_triggerControlTypeLabel, ("UIContainer/FullscreenUpperContainer/HeroLeaderPanel/HeroLeaderPanelContainer/TabControl/PlayerFrame" + IntToString(i - 1) + "/PlayerNameFrame/PlayerNameLabel"));
        libNtve_gf_SetDialogItemText(DialogControlLastCreated(), StringToText("AI - ") + libAIAI_gf_HeroAIDifficultyDisplayText(i), PlayerGroupAll());
    }

    return true;
}
// ---------------------------------------------------------------
// No Fountain
// ---------------------------------------------------------------
bool libAffx_NoFountain (bool testConds, bool runActions) {
    unitgroup unitGroup;
    int i;
    unit unitvar;
    if (!runActions) {
        return true;
    }
    unitGroup = UnitGroup(null, libAffx_teamOrder, RegionEntireMap(), libCore_gv_filtersStructure, 0);
    i = UnitGroupCount(unitGroup, c_unitCountAll);
    for (;; i -= 1) {
        unitvar = UnitGroupUnitFromEnd(unitGroup, i);
        if (unitvar == null) { break; }
        if (UnitGetType(unitvar) == "TownMoonwellL3" || UnitGetType(unitvar) == "TownMoonwellL2" || UnitGetType(unitvar) == "TownMoonwell") {
            UnitKill(unitvar);
        }
    }
    return true;
}
// ---------------------------------------------------------------
// Death Timer
// ---------------------------------------------------------------
int deathTimerIndex;
bool libAffx_DeathTimerAffixAdded (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    deathTimerIndex = libAffx_EventAffix("DeathTimer");
    return true;
}
bool libAffx_DeathTimerUnitDied (bool testConds, bool runActions) {
    unit deadUnit;
    int deadPlayer;
    int killingPlayer;
    fixed deathTime;
    deadUnit = EventUnit();
    deadPlayer = EventPlayer();
    killingPlayer = libNtve_gf_KillingPlayer();
    // Conditions
    if (testConds) {
        if (libGame_gv_gameOver) {
            return false;
        }
        if (!(deadPlayer >= 1)) {
            return false;
        }
        if (!(deadPlayer <= libCore_gv_bALMaxPlayers)) {
            return false;
        }
        if (!(deadUnit == libGame_gv_players[deadPlayer].lv_heroUnit)) {
            return false;
        }
        if (!(UnitTestState(deadUnit, c_unitStateHallucination) == false)) {
            return false;
        }
        if (deathTimerIndex == 0) {
            return false;
        }
        if (libGame_diabloUsedSouls[deadPlayer]) {
            return false;
        }
        if (resurgenceoftheStormIndex != 0 && libAffx_affixes[resurgenceoftheStormIndex].cooldown <= 0) {
            return false;
        }
    }
    // Actions
    if (!runActions) {
        return true;
    }
    if (deadPlayer >= 1 && deadPlayer <= 5) {
        if (UnitGetType(deadUnit) == "HeroMurky" && !((UnitIsAlive(libGame_gv_heroDeathMurkyRespawnEggs[deadPlayer]) == false) || (libGame_gv_heroDeathMurkyRespawnEggs[deadPlayer] == null))) {
            deathTime = libCore_gv_bALMurkyWithEggDeathTime * (1 + deathTimerModifier * libAffx_affixes[deathTimerIndex].count);
        } else {
            deathTime = libCore_gf_HeroDeathTime(deadPlayer, UnitLevel(libGame_gv_players[deadPlayer].lv_heroUnit)) * (1 + deathTimerModifier * libAffx_affixes[deathTimerIndex].count);
        }
        libGame_gf_HeroDeathStartRespawnTimer(deadPlayer, deathTime);
        libGame_gf_HeroDeathUpdateUIElementsForDeath(true, true, true, deadPlayer, killingPlayer);
        libGame_gf_HeroDeathEnableDisableDeadSoundStateForPlayer(true, deadPlayer);
        libGame_gf_HeroDeathPortHeroBackAndSetDeathState(deadPlayer, libGame_gv_players[deadPlayer].lv_spawnPoint);
    }
    return true;
}
