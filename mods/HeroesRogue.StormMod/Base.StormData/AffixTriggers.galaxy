bool libAffx_AncientBlessingsScaling (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_LevelUpScaling("Effect,DeckardAncientBlessingsAoEDamage,Amount", player);
    libAffx_LevelUpScaling("Effect,DeckardAncientBlessingsHealCreateHealer,RechargeVitalRate", player);

    return true;
}
// ---------------------------------------------------------------
// Machine Gunner
// ---------------------------------------------------------------
bool libAffx_SgtHammerMachineGunnerOncePerGame (bool testConds, bool runActions) {
    unit heroUnit = libAffx_GetHeroUnit(libAffx_player);
    if (!runActions) {
        return true;
    }
    libAffx_CatalogReferenceModify("Weapon,HeroSgtHammer,Period", libAffx_player, "0.125");
    libAffx_CatalogReferenceModify2("Effect,SgtHammerTankAttackDamage,Amount", libAffx_player, "0.25", c_upgradeOperationMultiply);
    libAffx_CatalogReferenceModify("Weapon,SgtHammerSiegeModeWeapon,Period", libAffx_player, "0.125");
    libAffx_CatalogReferenceModify2("Effect,SiegeWeaponBaseDamage,Amount", libAffx_player, "0.25", c_upgradeOperationMultiply);
    libAffx_CatalogReferenceModify("Effect,SiegeWeaponImpactSet,EffectArray[6]", libAffx_player, "EmptySetDummy");

    UnitCreateEffectUnit(heroUnit, "SiegeModeRemoveSet", heroUnit);

    return true;
}


