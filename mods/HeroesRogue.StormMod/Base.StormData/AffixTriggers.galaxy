
include "LibAffx_h"

const fixed enemySpeedCDR = 0.25;

int resurgenceoftheStormIndex;

// ---------------------------------------------------------------
// Zombie Handler
// ---------------------------------------------------------------
bool libAffx_ZombieHandlerNPCTakedown (bool testConds, bool runActions) {
    fixed zombieHandlerRange = 12;
    fixed zombieHandlerChance = 0.5;
    
    int player = libGame_gf_HeroParticipatedInNPCTakedownKillingPlayer();
    unit heroUnit = libGame_gv_players[player].lv_heroUnit;
    unit npcUnit = libGame_gf_HeroParticipatedInNPCTakedownMinion();
    point npcPosition = UnitGetPosition(npcUnit);
    int random;
    if (testConds) {
        if (player != libAffx_player) {
            return false;
        }
        if (!libAffx_IsMinion(npcUnit)) {
            return false;
        }
        if (!UnitFilterMatch(npcUnit, libAffx_teamChaos, UnitFilter((1 << c_targetFilterMinion), 0, 0, 0))) {
            return false;
        }
        if (!UnitIsAlive(heroUnit)) {
            return false;
        }
        if (UnitFilterMatch(heroUnit, player, UnitFilter(0, (1 << (c_targetFilterStasis - 32)), 0, 0))) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if ((DistanceBetweenPoints(UnitGetPosition(heroUnit), npcPosition) <= zombieHandlerRange)) {
        random = RandomInt(1, 100);
        if (random <= zombieHandlerChance * 100) {
            UnitCreateEffectPoint(heroUnit, "AffixZombieHandlerCreationPersistent", npcPosition);
        }
    }
    return true;
}

