//--------------------------------------------------------------------------------------------------
// Trigger: Curate HS UI Countdown Timer Expires
//--------------------------------------------------------------------------------------------------
bool libPBU2_gt_CurateHSUICountdownTimerExpires_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_itPlayer2;
    sound lv_crowdSound;
    int player;

    // Automatic Variable Declarations
    playergroup autoD70C5296_g;
    playergroup auto2A9A4B3A_g;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!((TriggerIsEnabled(TriggerGetCurrent()) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    TriggerExecute(libPBU2_timerExpired, false, false);
    TriggerEnable(TriggerGetCurrent(), false);
    libNtve_gf_StopTimer(libPBU2_gv_curateHeroSelectionSetting.lv_countdownTimer);
    DialogControlSetEnabled(libPBU2_gv_curateHeroSelectionUI.lv_abilitiesInfoButton, PlayerGroupAll(), false);
    DialogControlSetEnabled(libPBU2_gv_curateHeroSelectionUI.lv_talentsInfoButton, PlayerGroupAll(), false);
    DialogControlSetEnabled(libPBU2_gv_curateHeroSelectionUI.lv_brawlInfoButton, PlayerGroupAll(), false);
    libNtve_gf_SetDialogItemToggled(libPBU2_gv_curateHeroSelectionUI.lv_abilitiesInfoButton, false, PlayerGroupAll());
    libNtve_gf_SetDialogItemToggled(libPBU2_gv_curateHeroSelectionUI.lv_talentsInfoButton, false, PlayerGroupAll());
    libNtve_gf_SetDialogItemToggled(libPBU2_gv_curateHeroSelectionUI.lv_brawlInfoButton, false, PlayerGroupAll());
    autoD70C5296_g = libGame_gf_PlayersOnTeamHeroes(libGame_gv_teamOrderIndex_C, false);
    lv_itPlayer2 = -1;
    while (true) {
        	lv_itPlayer2 = PlayerGroupNextPlayer(autoD70C5296_g, lv_itPlayer2);
        	if (lv_itPlayer2<0) { break; }
        	if ((PlayerStatus(lv_itPlayer2) != c_playerStatusUnused) && (libPBU2_gv_curateHeroSelectionSetting.lv_lockedIn[lv_itPlayer2] == false)) {
            if ((libPBU2_gv_curateHeroSelectionSetting.lv_selectedHeroRow[lv_itPlayer2] > 0) && (libPBU2_gv_curateHeroSelectionSetting.lv_selectedHeroCol[lv_itPlayer2] > 0)) {
                libPBU2_gv_curateHeroSelectionSetting.lv_lockedIn[lv_itPlayer2] = true;
            }

        }

    }
    auto2A9A4B3A_g = libGame_gf_PlayersOnTeamHeroes(libGame_gv_teamOrderIndex_C, false);
    lv_itPlayer2 = -1;
    while (true) {
        	lv_itPlayer2 = PlayerGroupNextPlayer(auto2A9A4B3A_g, lv_itPlayer2);
        	if (lv_itPlayer2<0) { break; }
        	if ((PlayerStatus(lv_itPlayer2) != c_playerStatusUnused)) {
            if ((libPBU2_gv_curateHeroSelectionSetting.lv_lockedIn[lv_itPlayer2] == false)) {
                libPBU2_gf_CurateHSUIAutoPickHeroForPlayer(lv_itPlayer2);
            }

            libPBU2_gf_CurateHSUISetHeroSkinAndMountForPlayer(lv_itPlayer2, true);
        }

    }
    for ( ; ( (1 >= 0 && player <= libCore_gv_bALMaxPlayers) || (1 < 0 && player >= libCore_gv_bALMaxPlayers) ) ; player += 1 ) {
        if ((PlayerStatus(player) != c_playerStatusUnused) && (PlayerType(player) != c_playerTypeHostile)) {
            if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                if (player >= 6) {
                    libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickMetaUnusedHero(player);
                    if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                        libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickUnusedHeroWithRole(player, true, true, true, true, true, false);
                        if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                            libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickAnyUnusedHero(player, false, false);
                            if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                                libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickAnyUnusedHero(player, true, false);
                                if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                                    libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickAnyUnusedHero(player, true, true);
                                }

                            }

                        }

                    }

                }
                libCore_gf_DataLoadHeroDataIntoIndex(libCore_gf_GetHeroFromIndex(libGame_gv_players[player].lv_heroIndex), player);
                if ((PlayerType(player) != c_playerTypeComputer)) {
                    libGame_gf_HeroSelectionRandomlyPickSkin(player);
                    libGame_gf_HeroSelectionRandomlyPickMount(player);
                }

            }

        }

    }
    libPBU2_gf_CurateHSUIUpdateHeroButtons();
    SoundPlayForPlayer(SoundLink("UI_BNet_Draft_Countdown_Start", -1), c_maxPlayers, PlayerGroupAll(), 100.0, 0.0);
    libPBU2_gf_CurateHSUILockUI();
    Wait(1.0, c_timeGame);
    DialogControlFadeTransparency(libPBU2_gv_curateHeroSelectionUI.lv_pickHeroPanel, PlayerGroupAll(), 0.5, 100.0);
    Wait(0.5, c_timeGame);
    libPBU2_gf_CurateHSUIShowFinalCountDownHeroCutscene();
    libPBU2_gv_curateHeroSelectionSetting.lv_finalCountDownStarted = true;
    DialogControlSetVisible(libPBU2_gv_curateHeroSelectionUI.lv_countdownLabel, PlayerGroupAll(), false);
    DialogControlSetVisible(libPBU2_gv_curateHeroSelectionUI.lv_finalCountdownFrame, PlayerGroupAll(), true);
    SoundPlayForPlayer(SoundLink("UI_BNet_Draft_Countdown", -1), c_maxPlayers, PlayerGroupAll(), 100.0, 0.0);
    Wait(6.0, c_timeGame);
    DialogControlSetVisible(libPBU2_gv_curateHeroSelectionUI.lv_finalCountdownFrame, PlayerGroupAll(), false);
    DialogSetVisible(libPBU2_gv_curateHeroSelectionUI.lv_dialog, PlayerGroupAll(), false);
    SoundtrackStopCurrent(PlayerGroupAll(), c_soundtrackCategoryAmbience, true);
    SoundtrackPlay(PlayerGroupAll(), c_soundtrackCategoryAmbience, libCore_gv_mAPMapAmbience, c_soundtrackCueAny, c_soundtrackIndexAny, false);
    UISetWorldVisible(PlayerGroupAll(), true);
    DialogControlSetVisible(libUIUI_gv_uIObserverUI.lv_mainPanel, PlayerGroupSingle(libCore_gv_oBSERVER_ObserverUIPlayer), true);
    CinematicFade(true, 0.5, c_fadeStyleNormal, Color(0.00, 0.00, 0.00), 0.0, false);
    libSond_gf_SoundtrackPlayMapSoundtrackAsDefaultSoundtrackForAllPlayers();
    libGame_gv_heroPickDone = true;
    libGame_gv_heroSpawnReady = true;
    SetHeroLeaderPanelEnabled(true);
    return true;
}

