bool libPBU2_DifficultyDialog_Func (bool testConds, bool runActions) {
    bool test;
    int dialog = EventDialogControl();
    if (testConds) {
        if (dialog == libPBU2_difficultyDialogEasy || dialog == libPBU2_difficultyDialogNormal || dialog == libPBU2_difficultyDialogHard) {
            test = true;
        }
        if (!test) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (dialog == libPBU2_difficultyDialogEasy) {
        libPBU2_difficulty = 1;
        DialogControlSetEnabled(libPBU2_difficultyDialogEasy, PlayerGroupAll(), false);
        DialogControlSetEnabled(libPBU2_difficultyDialogNormal, PlayerGroupAll(), true);
        DialogControlSetEnabled(libPBU2_difficultyDialogHard, PlayerGroupAll(), true);
    } else if (dialog == libPBU2_difficultyDialogNormal) {
        libPBU2_difficulty = 2;
        DialogControlSetEnabled(libPBU2_difficultyDialogEasy, PlayerGroupAll(), true);
        DialogControlSetEnabled(libPBU2_difficultyDialogNormal, PlayerGroupAll(), false);
        DialogControlSetEnabled(libPBU2_difficultyDialogHard, PlayerGroupAll(), true);
    } else if (dialog == libPBU2_difficultyDialogHard) {
        libPBU2_difficulty = 3;
        DialogControlSetEnabled(libPBU2_difficultyDialogEasy, PlayerGroupAll(), true);
        DialogControlSetEnabled(libPBU2_difficultyDialogNormal, PlayerGroupAll(), true);
        DialogControlSetEnabled(libPBU2_difficultyDialogHard, PlayerGroupAll(), false);
    }


    return true;
}

//--------------------------------------------------------------------------------------------------
void libPBU2_DifficultyDialog_Init () {
    libPBU2_DifficultyDialogTrigger = TriggerCreate("libPBU2_DifficultyDialog_Func");
    TriggerAddEventDialogControl(libPBU2_DifficultyDialogTrigger, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}

