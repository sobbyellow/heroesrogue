    libPBU2_gt_CurateHSUICountdownTimerExpires = TriggerCreate("libPBU2_gt_CurateHSUICountdownTimerExpires_Func");
    TriggerEnable(libPBU2_gt_CurateHSUICountdownTimerExpires, false);
    TriggerAddEventTimer(libPBU2_gt_CurateHSUICountdownTimerExpires, libPBU2_gv_curateHeroSelectionSetting.lv_countdownTimer);
