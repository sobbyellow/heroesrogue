void libAffx_CreateAffixesOwnedDialogItem(int affix, int offsetX, int offsetY) {
    int label;
    string questIcon;
    int affixWidth = 95;
    int affixHeight = 95;
    text appendTooltip;
    if (libAffx_affixes[affix].quest.isQuest) {
        questIcon = "Affix/Quest";
    }
    if (libAffx_affixes[affix].excludeChoGall && libAffx_affixes[affix].excludeChoGallForAIEffect && libAffx_choPlayer != 0) {
        appendTooltip += StringExternal("Text/ExcludeChoGallForAIEffect");
    } else if (libAffx_affixes[affix].excludeChoGall && libAffx_choPlayer != 0) {
        appendTooltip += StringExternal("Text/ExcludeChoGall");
    }
    if (libAffx_affixes[affix].count > 0 && libAffx_affixes[affix].max != 1) {
        appendTooltip += StringExternal("Affix/Tooltip/Append/" + libAffx_affixes[affix].name);
    }
    libNtve_gf_CreateDialogItemImage(libAffx_dialogOwnedAffixes, affixWidth, affixHeight, c_anchorCenter, offsetX, offsetY, StringExternal("<c val=\"#TooltipNumbers\">") + StringExternal("Affix/Name/" + libAffx_affixes[affix].name) + StringExternal("</c><n/><n/>") + StringExternal("Affix/Tooltip/" + libAffx_affixes[affix].name) + appendTooltip, libAffx_affixes[affix].icon, c_triggerImageTypeNormal, false, Color(100, 100, 100), c_triggerBlendModeNormal);
    libNtve_gf_CreateDialogItemImage(libAffx_dialogOwnedAffixes, affixWidth + 28, affixHeight + 28, c_anchorCenter, offsetX, offsetY, null, "Assets/Textures/icon_overlay" + libAffx_GetAffixSuffix(affix) + ".dds", c_triggerImageTypeNormal, false, Color(100, 100, 100), c_triggerBlendModeNormal);

    libNtve_gf_CreateDialogItemLabel(libAffx_dialogOwnedAffixes, affixWidth + 44, affixHeight - 50, c_anchorCenter, offsetX, offsetY + 75, StringExternal(questIcon) + StringExternal("Affix/Name/" + libAffx_affixes[affix].name) + StringToText(libAffx_CountToString(libAffx_affixes[affix].count, libAffx_affixes[affix].max)), libAffx_GetAffixColor(affix), false, 1.0);
    label = DialogControlLastCreated();
    libNtve_gf_SetDialogItemStyle(label, "Affix_Owned", PlayerGroupAll());

    if (libAffx_affixes[affix].cooldownLink != "" && libAffx_affixes[affix].cooldownLink != null) {
        if (UnitGetCooldown(libGame_gv_players[libAffx_player].lv_heroUnit, libAffx_affixes[affix].cooldownLink) > 0) {
            libNtve_gf_CreateDialogItemImage(libAffx_dialogOwnedAffixes, affixWidth + 8, affixHeight + 8, c_anchorCenter, offsetX, offsetY, null, "Assets/Textures/affix_blackout2.dds", c_triggerImageTypeNormal, false, ColorWithAlpha(0, 0, 0, 0), c_triggerBlendModeNormal);
            libNtve_gf_CreateDialogItemLabel(libAffx_dialogOwnedAffixes, affixWidth + 5, affixHeight + 5, c_anchorCenter, offsetX, offsetY, StringToText(FixedToString(UnitGetCooldown(libGame_gv_players[libAffx_player].lv_heroUnit, libAffx_affixes[affix].cooldownLink), 0)), Color(100, 100, 100), false, 1.0);
            libNtve_gf_SetDialogItemStyle(DialogControlLastCreated(), "Storm_Tutorial_Small_Centered", PlayerGroupAll());
        }
    } else if (libAffx_affixes[affix].cooldown > 0 && !libAffx_affixes[affix].cooldownHidden) {
        libNtve_gf_CreateDialogItemImage(libAffx_dialogOwnedAffixes, affixWidth + 8, affixHeight + 8, c_anchorCenter, offsetX, offsetY, null, "Assets/Textures/affix_blackout2.dds", c_triggerImageTypeNormal, false, ColorWithAlpha(0, 0, 0, 0), c_triggerBlendModeNormal);
        libNtve_gf_CreateDialogItemLabel(libAffx_dialogOwnedAffixes, affixWidth + 5, affixHeight + 5, c_anchorCenter, offsetX, offsetY, StringToText(FixedToString(libAffx_affixes[affix].cooldown, 0)), Color(100, 100, 100), false, 1.0); 
        libNtve_gf_SetDialogItemStyle(DialogControlLastCreated(), "Storm_Tutorial_Small_Centered", PlayerGroupAll());
    }
    if (libAffx_affixes[affix].quest.questDone) {
        libNtve_gf_CreateDialogItemImage(libAffx_dialogOwnedAffixes, affixWidth + 8, affixHeight + 8, c_anchorCenter, offsetX, offsetY, null, "Assets/Textures/affix_blackout2.dds", c_triggerImageTypeNormal, false, ColorWithAlpha(0, 0, 0, 0), c_triggerBlendModeNormal);
        libNtve_gf_SetDialogItemColor(label, Color(60, 60, 60), PlayerGroupAll());
    }
}

