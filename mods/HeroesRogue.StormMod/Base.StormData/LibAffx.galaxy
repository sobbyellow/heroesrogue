bool libAffx_SpeedUpDeathUnitDied_Func (bool testConds, bool runActions) {
    unit deadUnit = EventUnit();
    if (testConds) {
        if (UnitGetOwner(deadUnit) != libAffx_player) {
            return false;
        }
        if (!libAffx_speedUpDeath) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_Wait(0.0625, c_timeGame);
    TriggerExecute(libAffx_SpeedUpDeathTrigger, true, false);
    return true;
}
void libAffx_SpeedUpDeathUnitDied_Init() {
    libAffx_SpeedUpDeathUnitDiedTrigger = TriggerCreate("libAffx_SpeedUpDeathUnitDied_Func");
    TriggerAddEventUnitDied(libAffx_SpeedUpDeathUnitDiedTrigger, null);
}

bool libAffx_SpeedUpDeathTrigger_Func (bool testConds, bool runActions) {
    unitgroup heroGroup = libGame_gv_players[libAffx_player].lv_heroUnitGroup;
    int groupCount = UnitGroupCount(heroGroup, c_unitCountAlive);
    int i;
    unit heroUnit;
    for (i = 1; i <= groupCount; i += 1) {
        heroUnit = UnitGroupUnit(heroGroup, i);
        if (UnitGetType(heroUnit) == "HeroLostVikingsController") {
            UnitGroupRemove(heroGroup, heroUnit);
        }
    }
    if (testConds) {
        if (groupCount > 0) {
            return false;
        }
        if (!libAffx_speedUpDeath) {
            return false;
        }
        if (libGame_gv_gameOver) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_DebugPrint("Speed up...");
    if (libAffx_speedUpDeath) {
        GameSetSpeedValue(4);
        while (groupCount <= 0 && libAffx_speedUpDeath && !libGame_gv_gameOver) {
            groupCount = UnitGroupCount(heroGroup, c_unitCountAlive);
            Wait(0.0625, c_timeGame);
        }
        GameSetSpeedValue(2);
    }
    return true;
}

bool libAffx_SpeedUpTrigger_Func (bool testConds, bool runActions) {
    if (testConds) {
        if (libAffx_GateIsOpen()) {
            return false;
        }
        if (!libAffx_speedUpStart) {
            return false;
        }
        if (libGame_gv_gameOver) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    if (libAffx_speedUpStart) {
        GameSetSpeedValue(4);
        while (!libAffx_GateIsOpen() && libAffx_speedUpStart && !libGame_gv_gameOver) {
            Wait(0.0625, c_timeGame);
        }
        GameSetSpeedValue(2);
    }
    return true;
}

void libAffx_SpeedUpTrigger_Init() {
    libAffx_SpeedUpTrigger = TriggerCreate("libAffx_SpeedUpTrigger_Func");
    libAffx_SpeedUpDeathTrigger = TriggerCreate("libAffx_SpeedUpDeathTrigger_Func");
}

