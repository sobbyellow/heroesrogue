bool libAffx_TalentGainedTrigger_Func (bool testConds, bool runActions) {
    int player = libGame_gf_HeroGainTalentPlayer();
    string talent = libGame_gf_HeroGainTalentGainedTalent();

    if (!runActions) {
        return true;
    }
    
    return true;
}
