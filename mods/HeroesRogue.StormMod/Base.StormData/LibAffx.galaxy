}
void libAffx_AffixSetMap(int affix, int map, bool allowed) {
    libAffx_affixes[affix].allowedMap[map] = allowed;
}
void libAffx_AffixSetMapAll(int affix, bool allowed) {
    int i;
    for (i = 1; i <= libAffx_maxMaps; i += 1) {
        libAffx_affixes[affix].allowedMap[i] = allowed;
    }
}
void libAffx_AffixSetMapSpecific(int affix, int map) {
    int i;
    for (i = 1; i <= libAffx_maxMaps; i += 1) {
        libAffx_affixes[affix].allowedMap[i] = false;
    }
    libAffx_affixes[affix].allowedMap[map] = true;
}
void libAffx_AffixSetWeight(int affix, int weight) {
    libAffx_affixes[affix].weight = weight;
}

bool libAffx_InitVariables_completed = false;

void libAffx_InitVariables () {
    if (libAffx_InitVariables_completed) {
        return;
    }

    libAffx_objectivesWon = 0;
    libAffx_registeredAffixes = 0;
    libAffx_currentRun = 0;
    libAffx_gamePaused = false;
    libAffx_queueCount = 0;
    libAffx_rerolls = 0;
    libAffx_rerollsCurse = 0;
    libAffx_cursesNextGame = 2;
    libAffx_queueActive = false;
    libAffx_showingOwnedAffixes = false;
    libAffx_playersFirstSpawnIn[libAffx_player] = false;
    libAffx_dialogAffixSelection = c_invalidDialogId;
    libAffx_dialogTopRight = c_invalidDialogId;
    libAffx_dialogOwnedAffixes = c_invalidDialogId;
    libAffx_dialogOptions = c_invalidDialogId;
    libAffx_dialogOptionsRestart = c_invalidDialogId;
    libAffx_dialogControlOptionsRestart = c_invalidDialogControlId;
    libAffx_dialogControlOptionsRestartYes = c_invalidDialogControlId;
    libAffx_dialogControlOptionsRestartNo = c_invalidDialogControlId;
    libAffx_dialogControlOptionsReturn = c_invalidDialogControlId;
    libAffx_dialogControlAffixesButton = c_invalidDialogControlId;
    libAffx_dialogControlOptions = c_invalidDialogControlId;
    libAffx_dialogCurrentRun = c_invalidDialogId;
    libAffx_dialogControlOptionsSpeedupDeath = c_invalidDialogControlId;
    libAffx_dialogControlOptionsSpeedup = c_invalidDialogControlId;
    libTRYM_loadTryMeMode = libAffx_debug_enableTryMeMode2;

    libAffx_CreateUI();
    DialogSetVisible(libAffx_dialogTopRight, PlayerGroupAll(), false);
    DialogSetVisible(libAffx_dialogOwnedAffixes, PlayerGroupAll(), false);

    libAffx_InitVariables_completed = true;
}

bool libAffx_InitAffixes_completed = false;

void libAffx_InitAffixes () {
    int i;
    int i2;
    int affixCountLoaded;
    string affixInstance;
    string affixHeroSpecific;
    string affixMapSpecific;
    string affixHeroTags;
    string affixString;
    int affixCatalogMod1;
    int affixCatalogMod2;
    string affixCatalogMod3;
    string affixCatalogMod4;
    string affixCatalogMod5;
    int affixBehavior1;
    int affixBehavior2;
    string affixBehavior3;
    string affixTrigger1;
    string affixTrigger2;
    string affixTrigger3;
    int affixInt;
    string affixExcluded;
    string affixRequired;

    if (libAffx_InitAffixes_completed) {
        return;
    }
    
    libAffx_AffixInitBlank();

    libAffx_DebugPrint("Total number of registered boons and curses: " + IntToString(UserDataInstanceCount("Affix")));
    affixCountLoaded = UserDataInstanceCount("Affix");

    for (i = 1; i <= affixCountLoaded; i += 1) {
        if (i > libAffx_affixMax) {
            return;
        }
        affixInstance = UserDataInstance("Affix", i);
        libAffx_affixes[i].name = affixInstance;
        libAffx_affixes[i].rarity = libAffx_GetRarity(UserDataGetString("Affix", affixInstance, "Rarity", 1));
        libAffx_affixes[i].icon = UserDataGetString("Affix", affixInstance, "Icon", 1);
        libAffx_affixes[i].weight = UserDataGetInt("Affix", affixInstance, "Weight", 1);
        libAffx_affixes[i].minLevel = UserDataGetInt("Affix", affixInstance, "LevelMin", 1);
        libAffx_affixes[i].maxLevel = UserDataGetInt("Affix", affixInstance, "LevelMax", 1);
        libAffx_affixes[i].max = UserDataGetInt("Affix", affixInstance, "Max", 1);
        libAffx_affixes[i].skipCurses = UserDataGetInt("Affix", affixInstance, "SkipCurses", 1);
        libAffx_affixes[i].requiredDifficulty = UserDataGetInt("Affix", affixInstance, "RequiredDifficulty", 1);
        if (UserDataGetInt("Affix", affixInstance, "Quest", 1) == 1) {
            libAffx_affixes[i].quest.isQuest = true;
            libAffx_affixes[i].quest.questDone = false;
        } else {
            libAffx_affixes[i].quest.isQuest = false;
        }
        if (libAffx_IntToBoolean(UserDataGetInt("Affix", affixInstance, "QuestPersists", 1))) {
            libAffx_affixes[i].quest.questProgressPersists = true;
        } else {
            libAffx_affixes[i].quest.questProgressPersists = false;
        }
        if (UserDataGetInt("Affix", affixInstance, "Enabled", 1) == 1) {
            libAffx_affixes[i].enabled = true;
        } else {
            libAffx_affixes[i].enabled = false;
        }
        if (UserDataGetInt("Affix", affixInstance, "Curse", 1) == 2) {
            libAffx_affixes[i].mythicCurse = true;
            libAffx_affixes[i].curse = true;
            libAffx_affixes[i].cannotRoll = true;
        } else if (UserDataGetInt("Affix", affixInstance, "Curse", 1) == 1) {
            libAffx_affixes[i].curse = true;
        } else {
            libAffx_affixes[i].curse = false;
        }
        if (UserDataGetString("Affix", affixInstance, "CooldownLink", 1) != "" && UserDataGetString("Affix", affixInstance, "CooldownLink", 1) != null) {
            libAffx_affixes[i].cooldownLink = UserDataGetString("Affix", affixInstance, "CooldownLink", 1);
        }
        if (UserDataGetInt("Affix", affixInstance, "CooldownHidden", 1) == 1) {
            libAffx_affixes[i].cooldownHidden = true;
        } else {
            libAffx_affixes[i].cooldownHidden = false;
        }
        if (UserDataGetInt("Affix", affixInstance, "ExcludeChoGall", 1) == 2) {
            libAffx_affixes[i].excludeChoGallForAIEffect = true;
            libAffx_affixes[i].excludeChoGall = true;
        } else if (UserDataGetInt("Affix", affixInstance, "ExcludeChoGall", 1) == 1) {
            libAffx_affixes[i].excludeChoGall = true;
        } else {
            libAffx_affixes[i].excludeChoGall = false;
        }
        if (UserDataGetInt("Affix", affixInstance, "NoRoll", 1) == 1) {
            libAffx_affixes[i].cannotRoll = true;
        } else {
            libAffx_affixes[i].cannotRoll = false;
        }
        for (i2 = 1; i2 <= libAffx_maxQuestRetain; i2 += 1) {
            affixString = UserDataGetString("Affix", affixInstance, "QuestRetain", i2);
            if (affixString != "" && affixString != null) {
                libAffx_affixes[i].questRetain[i2].tokenBehavior = StringWord(affixString, 1);
                if (StringWord(affixString, 2) != "" && StringWord(affixString, 2) != null) {
                    libAffx_affixes[i].questRetain[i2].retainModifier = StringToFixed(StringWord(affixString, 2));
                } else {
                    libAffx_affixes[i].questRetain[i2].retainModifier = 1;
                }
            }
        }
        libAffx_affixes[i].count = 0;
        affixHeroSpecific = UserDataGetString("Affix", affixInstance, "HeroSpecific", 1);
        affixHeroTags = UserDataGetString("Affix", affixInstance, "HeroTags", 1);
        libAffx_AffixSetHeroAll(i, true);
        if (affixHeroSpecific != "" && affixHeroSpecific != null) {
            libAffx_AffixSetHeroSpecific(i, affixHeroSpecific);
            libAffx_affixes[i].weight *= 2;
        } else {
            if (affixHeroTags != "" && affixHeroTags != null) {
                affixHeroTags = ";" + affixHeroTags + ";";
                if (StringContains(affixHeroTags, ";mana;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAll(i, false);
                    libAffx_AffixSetHeroUsesMana(i, true);
                } else if (StringContains(affixHeroTags, ";!mana;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAll(i, true);
                    libAffx_AffixSetHeroUsesMana(i, false);
                }
                if (StringContains(affixHeroTags, ";melee;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAllMelee(i, true);
                } else if (StringContains(affixHeroTags, ";!melee;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAllMelee(i, false);
                }
                if (StringContains(affixHeroTags, ";ranged;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAllRanged(i, true);
                } else if (StringContains(affixHeroTags, ";!ranged;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAllRanged(i, false);
                }
                if (StringContains(affixHeroTags, ";all;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAll(i, true);
                } else if (StringContains(affixHeroTags, ";!all;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAll(i, false);
                }
                if (StringContains(affixHeroTags, ";starter;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAll(i, false);
                    libAffx_AffixSetHeroStartersOnly(i, true);
                } else if (StringContains(affixHeroTags, ";!starter;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_AffixSetHeroAll(i, true);
                    libAffx_AffixSetHeroStartersOnly(i, false);
                }
            }
            for (i2 = 1; i2 <= libAffx_maxHeroes; i2 += 1) {
                affixString = UserDataGetString("Affix", affixInstance, "HeroesExcluded", i2);
                if (affixString != "" && affixString != null) {
                    libAffx_AffixSetHero(i, affixString, false);
                }
            }
        }
        affixMapSpecific = UserDataGetString("Affix", affixInstance, "MapSpecific", 1);
        libAffx_AffixSetMapAll(i, true);
        if (affixMapSpecific) {
            libAffx_AffixSetMapSpecific(i, libAffx_GetMapID(affixMapSpecific));
        } else {
            for (i2 = 1; i2 <= libAffx_maxMaps; i2 += 1) {
                affixString = UserDataGetString("Affix", affixInstance, "MapsExcluded", i2);
                if (affixString != "" && affixString != null) {
                    libAffx_AffixSetMap(i, libAffx_GetMapID(affixString), false);
                }
            }
        }
        for (i2 = 1; i2 <= libAffx_maxTalentsAdd; i2 += 1) {
            affixString = UserDataGetString("Affix", affixInstance, "TalentsAdd", i2);
            if (affixString != "" && affixString != null) {
                libAffx_affixes[i].addTalents[i2] = affixString;
            }
            affixString = UserDataGetString("Affix", affixInstance, "TalentsShow", i2);
            if (affixString != "" && affixString != null) {
                libAffx_affixes[i].showTalents[i2] = affixString;
                libAffx_ShowTalent(affixString, false);
            }
            affixString = UserDataGetString("Affix", affixInstance, "TalentsRequired", i2);
            if (affixString != "" && affixString != null) {
                libAffx_affixes[i].requiredTalents[i2] = affixString;
            }
        }
        // Catalog modification: <player> <catalog type> <operation> <reference> <value>
        for (i2 = 1; i2 <= libAffx_maxCatalogModification; i2 += 1) {
            affixString = UserDataGetString("Affix", affixInstance, "CatalogModification", i2);
            if (affixString != "" && affixString != null) {
                affixCatalogMod1 = StringToInt(StringWord(affixString, 1));
                affixCatalogMod2 = StringToInt(StringWord(affixString, 2));
                affixCatalogMod3 = StringWord(affixString, 3);
                affixCatalogMod4 = StringWord(affixString, 4);
                affixCatalogMod5 = StringWord(affixString, 5);
                if (affixCatalogMod3 != "" && affixCatalogMod3 != null && affixCatalogMod4 != "" && affixCatalogMod4 != null && affixCatalogMod5 != "" && affixCatalogMod5 != null) {
                    if (affixCatalogMod1 <= 12 && affixCatalogMod1 >= 0) {
                        libAffx_affixes[i].catalogModifications[i2].player = affixCatalogMod1;
                    } else {
                        libAffx_affixes[i].catalogModifications[i2].player = 0;
                    }
                    if (affixCatalogMod2 != 0) {
                        libAffx_affixes[i].catalogModifications[i2].type = affixCatalogMod2;
                    } else {
                        libAffx_affixes[i].catalogModifications[i2].type = libAffx_catalogTypeFlat;
                    }
                    if (StringCase(affixCatalogMod3, false) == "add" || affixCatalogMod3 == "0") {
                        libAffx_affixes[i].catalogModifications[i2].operation = c_upgradeOperationAdd;
                    } else if (StringCase(affixCatalogMod3, false) == "subtract" || affixCatalogMod3 == "1") {
                        libAffx_affixes[i].catalogModifications[i2].operation = c_upgradeOperationSubtract;
                    } else if (StringCase(affixCatalogMod3, false) == "multiply" || StringCase(affixCatalogMod3, false) == "mult" || affixCatalogMod3 == "4") {
                        libAffx_affixes[i].catalogModifications[i2].operation = c_upgradeOperationMultiply;
                    } else if (StringCase(affixCatalogMod3, false) == "divide" || affixCatalogMod3 == "5") {
                        libAffx_affixes[i].catalogModifications[i2].operation = c_upgradeOperationDivide;
                    } else if (StringCase(affixCatalogMod3, false) == "set" || affixCatalogMod3 == "6") {
                        libAffx_affixes[i].catalogModifications[i2].operation = c_upgradeOperationSet;
                    } else {
                        libAffx_affixes[i].catalogModifications[i2].operation = c_upgradeOperationSet;
                    }
                    libAffx_affixes[i].catalogModifications[i2].reference = affixCatalogMod4;
                    libAffx_affixes[i].catalogModifications[i2].value = StringToFixed(affixCatalogMod5);
                }
            }
        }
        // Behavior: <player> <affected by count?> <behavior> (tags)
        for (i2 = 1; i2 <= libAffx_maxBehavior; i2 += 1) {
            affixString = UserDataGetString("Affix", affixInstance, "Behavior", i2);
            if (affixString != "" && affixString != null) {
                affixBehavior1 = StringToInt(StringWord(affixString, 1));
                affixBehavior2 = StringToInt(StringWord(affixString, 2));
                affixBehavior3 = StringWord(affixString, 3);
                affixTrigger1 = StringWord(affixString, 4);
                if (affixBehavior1 <= 12 && affixBehavior1 >= 0) {
                    libAffx_affixes[i].behaviors[i2].player = affixBehavior1;
                } else {
                    libAffx_affixes[i].behaviors[i2].player = 0;
                }
                if (affixBehavior2 == 1) {
                    libAffx_affixes[i].behaviors[i2].affectedByCount = true;
                } else {
                    libAffx_affixes[i].behaviors[i2].affectedByCount = false;
                }
                affixTrigger1 = ";" + affixTrigger1 + ";";
                if (StringContains(affixTrigger1, ";mana;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_affixes[i].behaviors[i2].onlyManaUsers = true;
                } else if (StringContains(affixTrigger1, ";!mana;", c_stringAnywhere, c_stringNoCase)) {
                    libAffx_affixes[i].behaviors[i2].disallowManaUsers = true;
                }
                libAffx_affixes[i].behaviors[i2].behavior = affixBehavior3;
            }
        }
        // Trigger: <trigger type> <trigger name> <trigger args>
        for (i2 = 1; i2 <= libAffx_maxTrigger; i2 += 1) {
            affixString = UserDataGetString("Affix", affixInstance, "Trigger", i2);
            if (affixString != "" && affixString != null) {
                affixTrigger1 = StringCase(StringWord(affixString, 1), false);
                affixTrigger2 = StringWord(affixString, 2);
                affixTrigger3 = StringWord(affixString, 3);
                if (affixTrigger1 != "" && affixTrigger1 != null && affixTrigger2 != "" && affixTrigger2 != null) {
                    if (affixTrigger1 == "affixadded" || affixTrigger1 == "aa" || affixTrigger1 == "execute" || affixTrigger1 == "e") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerAffixAdded;
                    } else if (affixTrigger1 == "npctakedown" || affixTrigger1 == "nt") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerNPCTakedown;
                    } else if (affixTrigger1 == "onetime" || affixTrigger1 == "ot" || affixTrigger1 == "executeonce" || affixTrigger1 == "eo") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerOneTime;
                    } else if (affixTrigger1 == "oncepergame" || affixTrigger1 == "opg" || affixTrigger1 == "executeoncepergame" || affixTrigger1 == "eopg") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerOncePerGame;
                    } else if (affixTrigger1 == "gamestart" || affixTrigger1 == "gs" || affixTrigger1 == "immediate" || affixTrigger1 == "i" || affixTrigger1 == "executeimmediate" || affixTrigger1 == "ei") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerGameStart;
                    } else if (affixTrigger1 == "herotakedown" || affixTrigger1 == "ht") { 
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerHeroTakedown;
                    } else if (affixTrigger1 == "unitcreated" || affixTrigger1 == "uc") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerUnitCreated;
                    } else if (affixTrigger1 == "unitbehaviorchange" || affixTrigger1 == "ubc" || affixTrigger1 == "behaviorchange" || affixTrigger1 == "bc") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerUnitBehaviorChange;
                    } else if (affixTrigger1 == "unitbehaviorcreate" || affixTrigger1 == "ubcreate" || affixTrigger1 == "behaviorcreate" || affixTrigger1 == "bcreate") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerUnitBehaviorCreate;
                    } else if (affixTrigger1 == "unitbehaviorchangecategory" || affixTrigger1 == "ubcc" || affixTrigger1 == "behaviorchangecategory" || affixTrigger1 == "bcc") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerUnitBehaviorChangeCategory;
                    } else if (affixTrigger1 == "effectused" || affixTrigger1 == "eu" || affixTrigger1 == "playereffectused" || affixTrigger1 == "peu") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerPlayerEffectUsed;
                    } else if (affixTrigger1 == "levelup" || affixTrigger1 == "lu" || affixTrigger1 == "herolevelup" || affixTrigger1 == "hlu") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerHeroLevelUp;
                    } else if (affixTrigger1 == "scaling" || affixTrigger1 == "s") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerScaling;
                    } else if (affixTrigger1 == "unitdied" || affixTrigger1 == "ud") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerUnitDied;
                    } else if (affixTrigger1 == "quest" || affixTrigger1 == "q") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerQuest;
                    } else if (affixTrigger1 == "unitchangeowner" || affixTrigger1 == "uco") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerUnitChangeOwner;
                    } else if (affixTrigger1 == "periodic" || affixTrigger1 == "p") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerPeriodic;
                    } else if (affixTrigger1 == "win" || affixTrigger1 == "w") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerWin;
                    } else if (affixTrigger1 == "herorespawn" || affixTrigger1 == "hr" || affixTrigger1 == "respawn" || affixTrigger1 == "r") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerHeroRespawn;
                    } else if (affixTrigger1 == "herokilled" || affixTrigger1 == "herokill" || affixTrigger1 == "hk") {
                        libAffx_affixes[i].triggers[i2].type = libAffx_triggerHeroKilled;
                    } else {
                        libAffx_affixes[i].triggers[i2].type = 0;
                    }
                    libAffx_affixes[i].triggers[i2].name = affixTrigger2;
                    libAffx_affixes[i].triggers[i2].arg1 = affixTrigger3;
                }
            }
        }
        for (i2 = 1; i2 <= libAffx_affixMax; i2 += 1) {
            affixExcluded = UserDataGetUserInstance("Affix", affixInstance, "AffixesExcluded", i2);
            affixRequired = UserDataGetUserInstance("Affix", affixInstance, "AffixesRequired", i2);
            if (affixExcluded != "" && affixExcluded != "[Default]" && affixExcluded != null) {
                libAffx_AffixAddExclusion(i, libAffx_GetAffixId(affixExcluded));
            }
            if (affixRequired != "" && affixRequired != "[Default]" && affixRequired != null) {
                libAffx_AffixAddRequirement(i, libAffx_GetAffixId(affixRequired));
            }
        }
        libAffx_registeredAffixes += 1;
    }
    
    libAffx_InitAffixes_completed = true;
}

//--------------------------------------------------------------------------------------------------
// Library Initialization
//--------------------------------------------------------------------------------------------------
bool libAffx_InitLib_completed = false;

void libAffx_InitLib () {
    if (libAffx_InitLib_completed) {
        return;
    }

    libAffx_InitLib_completed = true;

    libAffx_InitLibraries();
    libAffx_InitVariables();
    libAffx_InitAffixes();
    libAffx_InitTriggers();
}

include "AffixTriggers"