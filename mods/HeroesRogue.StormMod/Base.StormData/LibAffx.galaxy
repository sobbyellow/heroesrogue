bool libAffx_OptionsRestartClickedTrigger_Func (bool testConds, bool runActions) {
    if (testConds) {
        if (EventDialogControl() != libAffx_dialogControlOptionsReturn && EventDialogControl() != libAffx_dialogControlOptionsRestart && EventDialogControl() != libAffx_dialogControlOptionsRestartYes && EventDialogControl() != libAffx_dialogControlOptionsRestartNo) {
            return false;
        }
        if (!libAffx_showingOptions) {
            return false;
        }
    }
    // Actions
    if (!runActions) {
        return true;
    }
    if (EventDialogControl() == libAffx_dialogControlOptionsRestart) {
        libAffx_CreateOptionRestartUI();
        DialogSetVisible(libAffx_dialogOptionsRestart, PlayerGroupAll(), true);
    } else if (EventDialogControl() == libAffx_dialogControlOptionsRestartYes) {
        libAffx_BankReset();
        GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorialveteran.stormmap");
        KickFromGame(PlayerGroupAll());
    } else if (EventDialogControl() == libAffx_dialogControlOptionsRestartNo) {
        DialogControlDestroyAll(libAffx_dialogOptionsRestart);
    } else if (EventDialogControl() == libAffx_dialogControlOptionsReturn) {
        libAffx_showingOptions = false;
        DialogSetVisible(libAffx_dialogOptions, PlayerGroupAll(), false);
        DialogControlDestroyAll(libAffx_dialogOptionsRestart);
        libAffx_Pause(false);
    }

    return true;
}

void libAffx_OptionsRestartClickedTrigger_Init() {
    libAffx_OptionsRestartClickedTrigger = TriggerCreate("libAffx_OptionsRestartClickedTrigger_Func");
    TriggerAddEventDialogControl(libAffx_OptionsRestartClickedTrigger, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}

bool libAffx_OptionsClickedTrigger_Func (bool testConds, bool runActions) {
    if (testConds) {
        if (EventDialogControl() != libAffx_dialogControlOptions) {
            return false;
        }
        if (libAffx_showingOwnedAffixes) {
            return false;
        }
        if (libAffx_queueActive) {
            return false;
        }
        if (libGame_gv_gameOver) {
            return false;
        }
    }
    // Actions
    if (!runActions) {
        return true;
    }
    if (libAffx_showingOptions) {
        libAffx_showingOptions = false;
        DialogSetVisible(libAffx_dialogOptions, PlayerGroupAll(), false);
        DialogControlDestroyAll(libAffx_dialogOptionsRestart);
        libAffx_Pause(false);
    } else {
        libAffx_showingOptions = true;
        libAffx_CreateOptionUI();
        DialogSetVisible(libAffx_dialogOptions, PlayerGroupAll(), true);
        libAffx_Pause(true);
    }
    return true;
}

void libAffx_OptionsClickedTrigger_Init() {
    libAffx_OptionsClickedTrigger = TriggerCreate("libAffx_OptionsClickedTrigger_Func");
    TriggerAddEventDialogControl(libAffx_OptionsClickedTrigger, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}

bool libAffx_ShowAffixesClickedTrigger_Func (bool testConds, bool runActions) {
    if (testConds) {
        if (EventDialogControl() != libAffx_dialogControlAffixesButton) {
            return false;
        }
        if (libAffx_showingOptions) {
            return false;
        }
    }
    // Actions
    if (!runActions) {
        return true;
    }
    if (libAffx_showingOwnedAffixes) {
        libAffx_showingOwnedAffixes = false;
        DialogSetVisible(libAffx_dialogOwnedAffixes, PlayerGroupAll(), false);
        if (!libAffx_queueActive && !libGame_gv_gameOver) {
            libAffx_Pause(false);
        }
    } else {
        libAffx_showingOwnedAffixes = true;
        libAffx_UpdateOwnedAffixes();
        if (!libAffx_queueActive && !libGame_gv_gameOver) {
            libAffx_Pause(true);
        }
    }
    return true;
}

