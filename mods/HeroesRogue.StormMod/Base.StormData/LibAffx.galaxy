void libAffx_CreateAffixesOwnedGrid(int affixTotal) {
    int i;
    int row;
    int column;
    int affixesThisRow;
    int affixesPerRow = 15;
    int totalRows = CeilingI(IntToFixed(affixTotal) / IntToFixed(affixesPerRow));
    int affixWidth = 134;
    int affixHeight = 150;
    int offsetX;
    int offsetY;
    for (i = 1; i <= affixTotal; i += 1) {
        row     = (i - 1) / affixesPerRow;
        column  = (i - 1) % affixesPerRow;

        if (row == totalRows - 1) {
            affixesThisRow = affixTotal - row * affixesPerRow;
        } else {
            affixesThisRow = affixesPerRow;
        }
        offsetX = -(affixesThisRow - 1) * affixWidth / 2 + column * affixWidth;
        offsetY = -(totalRows - 1) * affixHeight / 2 + row * affixHeight;        

        libAffx_CreateAffixesOwnedDialogItem(libAffx_ownedAffixes[i], offsetX, offsetY);
    }
}

void libAffx_UpdateOwnedAffixes() {
    int[libAffx_affixMax + 1] boons;
    int[libAffx_affixMax + 1] curses;
    int totalAffixes = 0;
    int totalBoons = 0;
    int totalCurses = 0;
    int i;
    int i2;
    if (!libAffx_showingOwnedAffixes) {
        return;
    }

    libAffx_CreateAffixesOwnedDialog();

    for (i = 1; i <= libAffx_rarityMythic; i += 1) {
        for (i2 = 1; i2 <= libAffx_registeredAffixes; i2 += 1) {
            if (libAffx_affixes[i2].rarity == i && libAffx_affixes[i2].count > 0) {
                totalAffixes += 1;
                if (!libAffx_affixes[i2].curse) {
                    totalBoons += 1;
                    boons[totalBoons] = i2;
                } else {
                    totalCurses += 1;
                    curses[totalCurses] = i2;
                }
            }
        }
    }
    for (i = 1; i <= totalAffixes; i += 1) {
        if (i <= totalBoons) {
            libAffx_ownedAffixes[i] = boons[i];
        } else {
            libAffx_ownedAffixes[i] = curses[i - totalBoons];
        }
    }
    libAffx_CreateAffixesOwnedGrid(totalAffixes);  
    DialogSetVisible(libAffx_dialogOwnedAffixes, PlayerGroupAll(), true);
}

