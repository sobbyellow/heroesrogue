// External Library Initialization
void libAffx_InitLibraries () {
    libNtve_InitVariables();
    libCore_InitVariables();
    libGame_InitVariables();
    libMapM_InitVariables();
    libStEx_InitVariables();
    libPBU2_InitLib();
}

void libAffx_DebugPrint(string print) {
    if (libAffx_debug_enableDebugLogging) {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringToText(print));
    }
}
void libAffx_Print(string printText) {
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringToText(printText));
}

int libAffx_GetAffixId(string affixName) {
    int i;
    for (i = 1; i <= libAffx_registeredAffixes; i += 1) {
        if (libAffx_affixes[i].name == affixName) {
            return i;
        }
    }
    return 0;
}

//--------------------------------------------------------------------------------------------------
bool libAffx_HeroSelectionTrigger_Func (bool testConds, bool runActions) {
    int player;

    if (!runActions) {
        return true;
    }
    player = 1;
    for (; player <= libCore_gv_bALMaxPlayers; player += 1 ) {
        if ((PlayerStatus(player) != c_playerStatusUnused) && (PlayerType(player) != c_playerTypeHostile)) {
            if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                if (player != libAffx_player) {
                    if (player == 2 && libGame_gv_players[libAffx_player].lv_heroIndex == libCore_gf_GetIndexFromHero("Cho")) {
                        libGame_gv_players[player].lv_heroIndex = libCore_gf_GetIndexFromHero("Gall");
                        libAffx_choPlayer = libAffx_player;
                        libAffx_gallPlayer = player;
                    } else if (player == 2 && libGame_gv_players[libAffx_player].lv_heroIndex == libCore_gf_GetIndexFromHero("Gall")) {
                        libGame_gv_players[player].lv_heroIndex = libCore_gf_GetIndexFromHero("Cho");
                        libAffx_gallPlayer = libAffx_player;
                        libAffx_choPlayer = player;
                    } else {
                        libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickMetaUnusedHero(player);
                        if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                            libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickUnusedHeroWithRole(player, true, true, true, true, true, false);
                            if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                                libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickAnyUnusedHero(player, false, false);
                                if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                                    libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickAnyUnusedHero(player, true, false);
                                    if ((libGame_gv_players[player].lv_heroIndex == 0)) {
                                        libGame_gv_players[player].lv_heroIndex = libGame_gf_HeroSelectionRandomlyPickAnyUnusedHero(player, true, true);
                                    }
                                }
                            }
                        }
                    }
                    if (libAffx_debug_forcedHeroes) {
                        libGame_gv_players[6].lv_heroIndex = libCore_gf_GetIndexFromHero("Uther");
                        libGame_gv_players[7].lv_heroIndex = libCore_gf_GetIndexFromHero("Leoric");
                        libGame_gv_players[8].lv_heroIndex = libCore_gf_GetIndexFromHero("Tyrael");
                        libGame_gv_players[9].lv_heroIndex = libCore_gf_GetIndexFromHero("Cho");
                        libGame_gv_players[10].lv_heroIndex = libCore_gf_GetIndexFromHero("Gall");
                    }

                    libAffx_playersHeroIndex[player] = libGame_gv_players[player].lv_heroIndex;
                }
                libCore_gf_DataLoadHeroDataIntoIndex(libCore_gf_GetHeroFromIndex(libGame_gv_players[player].lv_heroIndex), player);
                if ((PlayerType(player) != c_playerTypeComputer)) {
                    libGame_gf_HeroSelectionRandomlyPickSkin(player);
                    libGame_gf_HeroSelectionRandomlyPickMount(player);
                    PlayerSetSpray(player, "RandomSpray");
                }
                libAffx_DebugPrint("Player " + IntToString(player) + " set to Hero: " + libCore_gf_GetHeroFromIndex(libGame_gv_players[player].lv_heroIndex));
            }
        }
    }
    libGame_gv_heroPickDone = true;

    return true;
}
void libAffx_HeroSelectionTrigger_Init () {
    libAffx_HeroSelectionTrigger = TriggerCreate("libAffx_HeroSelectionTrigger_Func");
}

