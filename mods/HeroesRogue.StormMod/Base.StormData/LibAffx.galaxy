    libAffx_AffixLogicUnitCreatedTrigger_Init();
    libAffx_TestCommandTrigger_Init();
    libAffx_ResetCommandTrigger_Init();
    libAffx_GameOverCallbackTrigger_Init();
    libAffx_AffixHotkeyPressedTrigger_Init();
    libAffx_ObjectiveWonTrigger_Init();
    libAffx_AffixRerollTrigger_Init();
    libAffx_ProcessQueueTimeElapsed_Init();
    libAffx_Difficulty_Init();
    libAffx_OptionsClickedTrigger_Init();
    libAffx_OptionsRestartClickedTrigger_Init();
    libAffx_DVaTriggers_Init();
    libAffx_OptionsSpeedUpClickedTrigger_Init();
    libAffx_SpeedUpTrigger_Init();
    libAffx_SpeedUpDeathUnitDied_Init();
    libAffx_PBU2DifficultyChangedTrigger_Init();

    TriggerEnable(libGDHL_gt_HeroSylvanasPossessionRewire, true);
    libAffx_pauseVLSK = TriggerCreate("libVLSK_PauseTrigger_Func");
    libAffx_pauseMSHE = TriggerCreate("libMSHE_PauseTrigger_Func");
    libAffx_pauseMSOC = TriggerCreate("libMSOC_PauseTrigger_Func");
}

void libAffx_AffixInitBlank() {
    int i;
    libAffx_affixes[0].name = "AffixNone";
    libAffx_affixes[0].rarity = 0;
    libAffx_affixes[0].icon = "Assets/Textures/affix_icon_question_mark.dds";
    libAffx_affixes[0].weight = 0;
    libAffx_affixes[0].minLevel = 0;
    libAffx_affixes[0].maxLevel = 0;
    libAffx_affixes[0].curse = false;
    libAffx_affixes[0].enabled = true;
    libAffx_affixes[0].count = 0;
    libAffx_affixes[0].max = 0;
    for (i = 1; i <= libAffx_maxHeroes; i += 1) {
        libAffx_affixes[0].allowedHero[i] = true;
    }
    for (i = 1; i <= libAffx_maxMaps; i += 1) {
        libAffx_affixes[0].allowedHero[i] = true;
    }
}

void libAffx_AffixAddExclusion(int affix, int excludeAffix) {
    libAffx_affixes[affix].excludedAffixes[excludeAffix] = true;
    libAffx_affixes[excludeAffix].excludedAffixes[affix] = true;
}
void libAffx_AffixAddRequirement(int affix, int requireAffix) {
    libAffx_affixes[affix].requiredAffixes[requireAffix] = true;
}
void libAffx_AffixSetInfinite(int affix, bool infinite) {
    if (infinite) {
        libAffx_affixes[affix].max = 0;
        libAffx_affixes[affix].weight = 10;
    } else {
        libAffx_affixes[affix].max = 1;
    }
}
void libAffx_AffixSetMax(int affix, int maxCount) {
    libAffx_affixes[affix].max = maxCount;
}
void libAffx_AffixSetLevel(int affix, int minLevel, int maxLevel) {
    libAffx_affixes[affix].minLevel = minLevel;
    libAffx_affixes[affix].maxLevel = maxLevel;
}
void libAffx_AffixSetHero(int affix, string hero, bool allowed) {
    int index = libCore_gf_GetIndexFromHero(hero);
    if (index > libAffx_maxHeroes || index <= 0) {
        return;
    }
    libAffx_affixes[affix].allowedHero[index] = allowed;
}

