bool libAffx_MapInitTrigger_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    SetTalentsEnabled(false);

    TriggerExecute(libAffx_MapInitLoadBankTrigger, false, false);
    libAffx_SettingsLoad();

    libAffx_currentRun += 1;
    libPBU2_timerExpired = libAffx_HeroSelectedTrigger;
    
    if (libAffx_debug_disableHeroSelection) {
        libGame_gv_players[libAffx_player].lv_heroIndex = libCore_gf_GetIndexFromHero(libAffx_debug_playerHero);
        libCore_gf_DataLoadHeroDataIntoIndex(libCore_gf_GetHeroFromIndex(libGame_gv_players[libAffx_player].lv_heroIndex), libAffx_player);
        libGame_gf_HeroSelectionRandomlyPickSkin(libAffx_player);
        libGame_gf_HeroSelectionRandomlyPickMount(libAffx_player);
        PlayerSetSpray(libAffx_player, "RandomSpray");
        libAffx_playersHeroIndex[libAffx_player] = libCore_gf_GetIndexFromHero(libAffx_debug_playerHero);
        libGame_gv_pickingHeroesCallback = libAffx_HeroSelectionTrigger;
    } else if (libAffx_playerHeroIndexLoaded == 0) {
        libGame_gv_pickingHeroesCallback = libAffx_CurateHeroesTrigger;
    } else {
        libGame_gv_players[libAffx_player].lv_heroIndex = libAffx_playerHeroIndexLoaded;
        libAffx_playersHeroIndex[libAffx_player] = libAffx_playerHeroIndexLoaded;
        libCore_gf_DataLoadHeroDataIntoIndex(libCore_gf_GetHeroFromIndex(libGame_gv_players[libAffx_player].lv_heroIndex), libAffx_player);
        libGame_gf_HeroSelectionRandomlyPickSkin(libAffx_player);
        libGame_gf_HeroSelectionRandomlyPickMount(libAffx_player);
        PlayerSetSpray(libAffx_player, "RandomSpray");
        libGame_gv_pickingHeroesCallback = libAffx_HeroSelectionTrigger;
    }
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringToText("Version " + libAffx_version));

    if (libAffx_currentRun == 1) {
        //UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringExternal("Message/GoldenBorder"));
        libAffx_rerolls += libAffx_rerollsStart;
        libAffx_rerollsCurse += libAffx_rerollsStart;
    } else {
        libAffx_rerolls += libAffx_rerollsPerGame;
        libAffx_rerollsCurse += libAffx_rerollsPerGame;
    }
    

    Wait(0.0625, c_timeGame);
    if (libAffx_currentMap != libAffx_GetMapID(libCore_gv_mAPMapStringID) && !libAffx_debug_ignoreMap) {
        if (libAffx_currentMap == libAffx_mapCursedHollow) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorialveteran.stormmap");
            KickFromGame(PlayerGroupAll());
        } else if (libAffx_currentMap == libAffx_mapShrines) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorialmapmechanics.stormmap");
            KickFromGame(PlayerGroupAll());
        } else if (libAffx_currentMap == libAffx_mapCrypts) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorial01.stormmap");
            KickFromGame(PlayerGroupAll());
        } else if (libAffx_currentMap == libAffx_mapDragonShire) {
            GameSetNextMap("heroes/singleplayermaps/(10)trymemode.stormmap");
            KickFromGame(PlayerGroupAll());
        }
    }

    return true;
}
void libAffx_MapInitTrigger_Init () {
    libAffx_MapInitTrigger = TriggerCreate("libAffx_MapInitTrigger_Func");
    TriggerAddEventMapInit(libAffx_MapInitTrigger);
}
