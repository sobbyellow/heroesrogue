    DialogControlSetSize(DialogControlLastCreated(), PlayerGroupAll(), 700, 300);
    DialogControlSetPosition(DialogControlLastCreated(), PlayerGroupAll(), c_anchorCenter, 0, 0);
    libNtve_gf_CreateDialogItemLabel(libAffx_dialogOptionsRestart, 600, 50, c_anchorCenter, 0, -75, StringExternal("Label/Name/OptionsRestart"), ColorWithAlpha(0, 0, 0, 0), false, 1.0);
    libNtve_gf_SetDialogItemStyle(DialogControlLastCreated(), "Affix_Dialog", PlayerGroupAll());

    DialogControlCreateFromTemplate(libAffx_dialogOptionsRestart, c_triggerControlTypeButton, "StandardTemplates/StandardButtonTemplate");
    libAffx_dialogControlOptionsRestartYes = DialogControlLastCreated();
    DialogControlSetSize(libAffx_dialogControlOptionsRestartYes, PlayerGroupAll(), 250, 95);
    DialogControlSetPosition(libAffx_dialogControlOptionsRestartYes, PlayerGroupAll(), c_anchorCenter, -140, 70);
    libNtve_gf_SetDialogItemText(libAffx_dialogControlOptionsRestartYes, StringExternal("Button/Name/OptionsRestartYes"), PlayerGroupAll());

    DialogControlCreateFromTemplate(libAffx_dialogOptionsRestart, c_triggerControlTypeButton, "StandardTemplates/StandardButtonTemplate");
    libAffx_dialogControlOptionsRestartNo = DialogControlLastCreated();
    DialogControlSetSize(libAffx_dialogControlOptionsRestartNo, PlayerGroupAll(), 250, 95);
    DialogControlSetPosition(libAffx_dialogControlOptionsRestartNo, PlayerGroupAll(), c_anchorCenter, 140, 70);
    libNtve_gf_SetDialogItemText(libAffx_dialogControlOptionsRestartNo, StringExternal("Button/Name/OptionsRestartNo"), PlayerGroupAll());
}

