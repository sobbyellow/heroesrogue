void libAffx_ResetCooldowns (unit playerUnit) {
    int i;
    int ability;
    int heroIndex;
    int player;
    string abilLink;
    string cooldownLink;
    string chargeLink;
    int chargeCount;
    unitgroup unitGroup;
    unit unitVar;
    int unitGroupCount;
    int abilityNumber = libCore_gv_dataHeroesMaxAbilitiesPerHero;

    player = UnitGetOwner(playerUnit);
    unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    for (;; unitGroupCount -= 1) {
        unitVar = UnitGroupUnitFromEnd(unitGroup, unitGroupCount);
        if (unitVar == null) { break; }
        libAffx_DebugPrint(UnitGetType(unitVar));
        cooldownLink = "";
        chargeLink = "";
        heroIndex = libCore_gf_GetHeroIndexForUnitType(UnitGetType(unitVar));
        abilityNumber = UnitAbilityCount(unitVar);
        ability = 1;

        for ( ; ability <= abilityNumber ; ability += 1 ) {
            abilLink = UnitAbilityGet(unitVar, ability);
            if ((libGame_gf_HeroAbilityCooldownCanBeReset(heroIndex, abilLink) == true)) {
                cooldownLink = CatalogFieldValueGet(c_gameCatalogAbil, abilLink, "Cost[" + IntToString(0) + "].Cooldown.Link", player);
                libNtve_gf_UnitRemoveCooldown(unitVar, cooldownLink);
                libNtve_gf_PlayerRemoveCooldown(player, cooldownLink);
                chargeLink = CatalogFieldValueGet(c_gameCatalogAbil, abilLink, "Cost[" + IntToString(0) + "].Charge.Link", player);
                chargeCount = CatalogFieldValueGetAsInt(c_gameCatalogAbil, abilLink, "Cost[" + IntToString(0) + "].Charge.CountMax", player);
                UnitAddChargeUsed(unitVar, chargeLink, (-chargeCount));
                PlayerAddChargeUsed(player, chargeLink, (-chargeCount));
            }
        }
    }
}
bool libAffx_IntToBoolean(int value) {
    if (value == 1) {
        return true;
    } else if (value == 0) {
        return false;
    }
    return false;
}

void libAffx_DummyTalentChoicesFromTalentName(int lp_player, string talent) {
    int lv_itBehavior;
    int lv_itAbilityMod;
    int lv_itAbilityModChange;
    int lv_behaviorCount;
    int lv_numberOfAbilitiesModified;
    int lv_numberOfFieldsModified;
    int lv_catalogInt;
    int lv_changeTypeInt;
    int lv_currentTalentModNumber;

    int auto38B17200_ae;
    int autoDE132AE1_ae;
    libGame_gv_talents_TalentChoices[lp_player][0].lv_numberOfTalentsForThisTier = 1; // tier 0 column 0 as dummy talent data
    libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_talentCatalogLink = (talent);
    if ((CatalogFieldValueCount(c_gameCatalogTalent, talent, "RankArray", c_playerAny) != 0)) {
        libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_behaviorCount = MaxI(libCore_gv_talents_MaxBehaviorsPerTalent_C, CatalogFieldValueCount(c_gameCatalogTalent, talent, "RankArray[" + IntToString(0) + "].BehaviorArray", c_playerAny));
    }
    else {
        libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_behaviorCount = 0;
    }
    if ((libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_behaviorCount != 0)) {
        lv_behaviorCount = libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_behaviorCount;
        lv_itBehavior = 1;
        for ( ; ( (1 >= 0 && lv_itBehavior <= lv_behaviorCount) || (1 < 0 && lv_itBehavior >= lv_behaviorCount) ) ; lv_itBehavior += 1 ) {
            libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_behaviors[lv_itBehavior] = (CatalogFieldValueGet(c_gameCatalogTalent, talent, "RankArray[" + IntToString(0) + "].BehaviorArray[" + IntToString((lv_itBehavior - 1)) + "]", c_playerAny));
        }
    }
    libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_totalModifications = 0;
    lv_currentTalentModNumber = 0;
    lv_numberOfAbilitiesModified = MaxI(libCore_gv_talents_MaxModificationsPerTalent_C, CatalogFieldValueCount(c_gameCatalogTalent, talent, "AbilityModificationArray", c_playerAny));

    auto38B17200_ae = lv_numberOfAbilitiesModified;
    lv_itAbilityMod = 1;

    for ( ; ( (1 >= 0 && lv_itAbilityMod <= auto38B17200_ae) || (1 < 0 && lv_itAbilityMod >= auto38B17200_ae) ) ; lv_itAbilityMod += 1 ) {
        lv_numberOfFieldsModified = CatalogFieldValueCount(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString(lv_itAbilityMod - 1) + "].Modifications", c_playerAny);
        autoDE132AE1_ae = lv_numberOfFieldsModified;
        lv_itAbilityModChange = 1;
        for ( ; ( (1 >= 0 && lv_itAbilityModChange <= autoDE132AE1_ae) || (1 < 0 && lv_itAbilityModChange >= autoDE132AE1_ae) ) ; lv_itAbilityModChange += 1 ) {
            lv_currentTalentModNumber += 1;
            if ((lv_currentTalentModNumber > libGame_gv_talents_DebugMaxModifedAbilites)) {
                libGame_gv_talents_DebugMaxModifedAbilites = lv_currentTalentModNumber;
            }

            lv_changeTypeInt = CatalogFieldValueGetAsInt(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].Type", c_playerAny);
            libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_changeType = lv_changeTypeInt;
            lv_catalogInt = CatalogFieldValueGetAsInt(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].Catalog", c_playerAny);
            libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_catalog = lv_catalogInt;
            libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_field = CatalogFieldValueGet(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].Field", c_playerAny);
            libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_fieldIsInteger = (CatalogFieldValueGetAsInt(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].FieldIsInteger", c_playerAny) == 1);
            libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_value = CatalogFieldValueGetAsFixed(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].Value", c_playerAny);
            if ((libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_changeType == c_talentModificationCatalogReplacement)) {
                libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_catalogReplaceFrom = CatalogFieldValueGet(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].Entry", c_playerAny);
                libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_catalogChangeTo = CatalogFieldValueGet(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].StringReplacement", c_playerAny);
            }
            else {
                libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_entry = CatalogFieldValueGet(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].Entry", c_playerAny);
                libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_abilityModificationData[lv_currentTalentModNumber].lv_stringReplacementValue = CatalogFieldValueGet(c_gameCatalogTalent, talent, "AbilityModificationArray[" + IntToString((lv_itAbilityMod - 1)) + "].Modifications[" + IntToString((lv_itAbilityModChange - 1)) + "].StringReplacement", c_playerAny);
            }
        }
    }
    if ((lv_numberOfAbilitiesModified > 0)) {
        libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_totalModifications = lv_currentTalentModNumber;
    }
}

void libAffx_AddTalent(int lp_player, string talent) {
    int behavior;
    int behaviorCount;
    unit heroUnit;

    libAffx_DummyTalentChoicesFromTalentName(lp_player, talent);

    heroUnit = libGame_gv_players[lp_player].lv_heroUnit;
    behaviorCount = libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_behaviorCount;
    behavior = 1;
    for ( ; ( (1 >= 0 && behavior <= behaviorCount) || (1 < 0 && behavior >= behaviorCount) ) ; behavior += 1 ) {
        UnitBehaviorAdd(heroUnit, libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_behaviors[behavior], heroUnit, 1);
    }
    libGame_gf_SendEventHeroGainTalent((libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_talentCatalogLink), lp_player);
    libGame_gf_ApplyAbilityModificationsForPlayerAtTalent(lp_player, 0, 0);

    StatEventCreate("TalentChosen");
    StatEventAddDataInt(StatEventLastCreated(), "PlayerID", lp_player);
    StatEventAddDataString(StatEventLastCreated(), "PurchaseName", (libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_talentCatalogLink));
    StatEventSend(StatEventLastCreated());
    PlayerAddTalent(lp_player, libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_talentCatalogLink);
    libGame_gf_TalentsUpdateChoicePanelForPlayer(lp_player);
    libUIUI_gf_UIPartyFrameHeroicTalentUpdate(lp_player, 0);
    ActorSend(libNtve_gf_MainActorofUnit(libGame_gv_players[lp_player].lv_heroUnit), (("Signal " + (libGame_gv_talents_TalentChoices[lp_player][0].lv_talentData[0].lv_talentCatalogLink))));
}

void libAffx_ShowTalent(string talent, bool show) {
    if (show) {
        SetTalentEnabled(talent, true);
        SetTalentHidden(talent, false);
    } else {
        SetTalentEnabled(talent, false);
        SetTalentHidden(talent, true);
    }
}

void libAffx_CatalogSetForAllPlayers(int type, string entry, string path, string value) {
    int i;
    for (i = 1; i <= libCore_gv_bALMaxEnginePlayerCount; i += 1) {
        CatalogFieldValueSet(type, entry, path, i, value);
    }
}
void libAffx_CatalogSetFixedForAllPlayers(int type, string entry, string path, fixed value) {
    int i;
    for (i = 1; i <= libCore_gv_bALMaxEnginePlayerCount; i += 1) {
        CatalogFieldValueSetFixed(type, entry, path, i, value);
    }
}
void libAffx_CatalogModifyForAllPlayers(string reference, string value) {
    int i;
    for (i = 1; i <= libCore_gv_bALMaxEnginePlayerCount; i += 1) {
        CatalogReferenceModify(reference, i, value, c_upgradeOperationSet);
    }
}

void libAffx_SendAffixAddedEvent (int affix, int amount) {
    DataTableSetInt(false, TriggerEventParamName(libAffx_eventID + libAffx_affixes[affix].name, libAffx_eventParam), affix);
    DataTableSetInt(false, TriggerEventParamName(libAffx_eventID + libAffx_affixes[affix].name, libAffx_eventParam2), amount);
    TriggerSendEvent(libAffx_eventID + libAffx_affixes[affix].name);
}
int libAffx_EventAffix() {
    return DataTableGetInt(false, TriggerEventParamName(EventGenericName(), libAffx_eventParam));
}
int libAffx_EventAffixCountAdded() {
    return DataTableGetInt(false, TriggerEventParamName(EventGenericName(), libAffx_eventParam2));
}

int libAffx_EventAffixCount() {
    return libAffx_affixes[libAffx_EventAffix()].count;
}

bool libAffx_FilterMatchesExclude(unit unitVar, unitfilter unitFilter, int player, string unitType, string exclude) {
    if (unitFilter != null && !UnitFilterMatch(unitVar, libAffx_player, unitFilter)) {
        return false;
    }
    if (player != 0 && UnitGetOwner(unitVar) != player) {
        return false;
    }
    if (exclude != "" && exclude != null && UnitGetType(unitVar) == exclude) {
        return false;
    }
    if (unitType != "" && unitType != null && UnitGetType(unitVar) != unitType) {
        return false;
    }
    return true;
}
bool libAffx_FilterMatches(unit unitVar, unitfilter unitFilter, int player, string unitType) {
    return libAffx_FilterMatchesExclude(unitVar, unitFilter, player, unitType, null);
}
void libAffx_AddBehaviorFilterExclude(unit unitVar, string behavior, unitfilter unitFilter, int player, string unitType, string exclude, int stacks) {
    if (libAffx_FilterMatchesExclude(unitVar, unitFilter, player, unitType, exclude)) {
        libAffx_UnitBehaviorAdd(unitVar, behavior, unitVar, stacks);
    }
}
void libAffx_AddBehaviorFilter(unit unitVar, string behavior, unitfilter unitFilter, int player, string unitType, int stacks) {
    libAffx_AddBehaviorFilterExclude(unitVar, behavior, unitFilter, player, unitType, null, stacks);
}
void libAffx_AddAndRemoveBehaviorFilter(unit unitVar, string behavior, unitfilter unitFilter, int player, string unitType, int stacks) {
    if (libAffx_FilterMatches(unitVar, unitFilter, player, unitType)) {
        libAffx_UnitBehaviorAdd(unitVar, behavior, unitVar, stacks);
    } else {
        UnitBehaviorRemove(unitVar, behavior, stacks);
    }
}
void libAffx_AddBehaviorAllUnitsFilterExclude (string behavior, unitfilter filter, int player, string unitType, string exclude, int stacks) {
    unit unitVar;
    unitgroup unitGroup = UnitGroup(null, c_playerAny, RegionEntireMap(), filter, 0);
    int i = UnitGroupCount(unitGroup, c_unitCountAll);
    for (;; i -= 1) {
        if (i <= 0) { break; }
        unitVar = UnitGroupUnitFromEnd(unitGroup, i);
        if (unitVar == null) {
            break;
        }
        if (exclude != "" && exclude != null && UnitGetType(unitVar) == exclude) {
            continue;
        }
        if (libAffx_FilterMatches(unitVar, filter, player, unitType)) {
            libAffx_UnitBehaviorAdd(unitVar, behavior, unitVar, stacks);
        }
    }
}
void libAffx_AddBehaviorAllUnitsFilter (string behavior, unitfilter filter, int player, string unitType, int stacks) {
    libAffx_AddBehaviorAllUnitsFilterExclude(behavior, filter, player, unitType, null, stacks);
}
void libAffx_RemoveBehaviorAllUnitsFilter (string behavior, unitfilter filter, int player, string unitType, int stacks) {
    unit unitVar;
    unitgroup unitGroup = UnitGroup(null, c_playerAny, RegionEntireMap(), filter, 0);
    int i = UnitGroupCount(unitGroup, c_unitCountAll);
    for (;; i -= 1) {
        unitVar = UnitGroupUnitFromEnd(unitGroup, i);
        if (unitVar == null) {
            break;
        }
        if (libAffx_FilterMatches(unitVar, filter, player, unitType)) {
            UnitBehaviorRemove(unitVar, behavior, stacks);
        }
    }
}

void libAffx_PlayerSetPropertyFixed (int player, int inProp, fixed value, bool applyToAllUnits) {
    int i;
    unitgroup unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    int unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    unit heroUnit;
    if (applyToAllUnits) {
        for (;; unitGroupCount -= 1) {
            if (unitGroupCount <= 0) { break; }
            heroUnit = UnitGroupUnitFromEnd(unitGroup, i);
            if (UnitGetType(heroUnit) != "HeroLostVikingsController") {
                UnitSetPropertyFixed(heroUnit, inProp, value);
            }
        }
    } else {
        heroUnit = UnitGroupUnitFromEnd(unitGroup, unitGroupCount);
        if (UnitGetType(heroUnit) == "HeroLostVikingsController") {
            UnitSetPropertyFixed(UnitGroupUnitFromEnd(unitGroup, unitGroupCount - 1), inProp, value);
        } else {
            UnitSetPropertyFixed(heroUnit, inProp, value);
        }
    }
}
void libAffx_UnitAddPropertyFixed (unit unitVar, int inProp, fixed value) {
    UnitSetPropertyFixed(unitVar, inProp, UnitGetPropertyFixed(unitVar, inProp, true) + value);
}
void libAffx_PlayerAddPropertyFixed (int player, int inProp, fixed value, bool applyToAllUnits) {
    int i;
    unitgroup unitGroup;
    int unitGroupCount;
    unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    if (applyToAllUnits) {
        for (i = unitGroupCount; i > 0; i -= 1) {
            if (UnitGetType(UnitGroupUnitFromEnd(unitGroup, i)) != "HeroLostVikingsController") {
                UnitSetPropertyFixed(UnitGroupUnitFromEnd(unitGroup, i), inProp, UnitGetPropertyFixed(UnitGroupUnitFromEnd(unitGroup, i), inProp, true) + value);
            }
        }
    } else {
        if (UnitGetType(UnitGroupUnitFromEnd(unitGroup, unitGroupCount)) == "HeroLostVikingsController") {
            UnitSetPropertyFixed(UnitGroupUnitFromEnd(unitGroup, unitGroupCount - 1), inProp, UnitGetPropertyFixed(UnitGroupUnitFromEnd(unitGroup, unitGroupCount - 1), inProp, true) + value);
        } else {
            UnitSetPropertyFixed(UnitGroupUnitFromEnd(unitGroup, unitGroupCount), inProp, UnitGetPropertyFixed(UnitGroupUnitFromEnd(unitGroup, unitGroupCount), inProp, true) + value);
        }
    }
}
void libAffx_AddAffixBehavior(int player, string behavior) {
    if (player >= 1 && player <= 10 && libAffx_behaviorIndex[player] <= libAffx_behaviorMax && behavior != "" && behavior != null && libCore_gf_GetHeroFromIndex(player) == "DVa") {
        libAffx_behaviorIndex[player] += 1;
        libAffx_affixBehaviors[player][libAffx_behaviorIndex[player]] = behavior;
        libAffx_DebugPrint("Adding " + behavior + " to affix behaviors for player " + IntToString(player) + " at index " + IntToString(libAffx_behaviorIndex[player]));
    }
}
void libAffx_UnitBehaviorAdd(unit targetUnit, string behavior, unit casterUnit, int stacks) {
    int player = UnitGetOwner(targetUnit);
    UnitBehaviorAdd(targetUnit, behavior, casterUnit, stacks);
    if (player >= 1 && player <= 10 && behavior != "" && behavior != null) {
        if (libAffx_behaviorIndex[player] <= libAffx_behaviorMax) {
            if (!UnitTestState(targetUnit, c_unitStateHallucination) && UnitTypeTestAttribute(UnitGetType(targetUnit), c_unitAttributeHeroic)) {
                libAffx_behaviorIndex[player] += 1;
                if (libAffx_behaviorIndex[player] > 0) {
                    if (libAffx_affixBehaviors[player][libAffx_behaviorIndex[player] - 1] == null || (libAffx_affixBehaviors[player][libAffx_behaviorIndex[player] - 1] != null && libAffx_affixBehaviors[player][libAffx_behaviorIndex[player] - 1] != behavior)) {
                        libAffx_affixBehaviors[player][libAffx_behaviorIndex[player]] = behavior;
                        //libAffx_DebugPrint("Adding " + behavior + " to affix behaviors for player " + IntToString(player) + " at index " + IntToString(libAffx_behaviorIndex[player]));
                    } else {
                        libAffx_behaviorIndex[player] -= 1;
                    }
                }
            }
        } else {
            libAffx_DebugPrint("Warning: Too many affix behaviors added!");
        }
    }
}
void libAffx_AddBehaviorWithExclusion (int player, string behavior, int stacks, bool applyToAllUnits, string excludeUnit) {
    int i;
    unitgroup unitGroup;
    int unitGroupCount;
    unit heroUnit;
    unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    if (applyToAllUnits || (libCore_gf_GetHeroFromIndex(libAffx_playersHeroIndex[player]) == "DVa" && excludeUnit != "HeroDVaMech")) {
        for (i = unitGroupCount; i > 0; i -= 1) {
            heroUnit = UnitGroupUnitFromEnd(unitGroup, i);
            if (UnitGetType(heroUnit) != "HeroLostVikingsController" && UnitGetType(heroUnit) != excludeUnit) {
                if (player == libAffx_choPlayer || player == libAffx_gallPlayer) {
                    libAffx_UnitBehaviorAdd(libGame_gv_players[libAffx_gallPlayer].lv_heroUnit, behavior, libGame_gv_players[libAffx_gallPlayer].lv_heroUnit, stacks);
                    libAffx_UnitBehaviorAdd(libGame_gv_players[libAffx_choPlayer].lv_heroUnit, behavior, libGame_gv_players[libAffx_choPlayer].lv_heroUnit, stacks);
                    break;
                } else {
                    libAffx_UnitBehaviorAdd(heroUnit, behavior, heroUnit, stacks);
                }
            }
        }
    } else {
        heroUnit = UnitGroupUnitFromEnd(unitGroup, unitGroupCount);
        if (UnitGetType(heroUnit) == excludeUnit) {
        } else if (UnitGetType(heroUnit) == "HeroLostVikingsController") {
            libAffx_UnitBehaviorAdd(UnitGroupUnitFromEnd(unitGroup, unitGroupCount - 1), behavior, UnitGroupUnitFromEnd(unitGroup, unitGroupCount - 1), stacks);
        } else {
            if (player == libAffx_choPlayer || player == libAffx_gallPlayer) {
                libAffx_UnitBehaviorAdd(libGame_gv_players[libAffx_gallPlayer].lv_heroUnit, behavior, libGame_gv_players[libAffx_gallPlayer].lv_heroUnit, stacks);
                libAffx_UnitBehaviorAdd(libGame_gv_players[libAffx_choPlayer].lv_heroUnit, behavior, libGame_gv_players[libAffx_choPlayer].lv_heroUnit, stacks);
            } else {
                libAffx_UnitBehaviorAdd(heroUnit, behavior, heroUnit, stacks);
            }
        }
    }
}
void libAffx_AddBehavior (int player, string behavior, int stacks, bool applyToAllUnits) {
    libAffx_AddBehaviorWithExclusion(player, behavior, stacks, applyToAllUnits, null);
}
void libAffx_RemoveBehavior (int player, string behavior, int stacks, bool applyToAllUnits) {
    int i;
    unitgroup unitGroup;
    int unitGroupCount;
    unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    if (applyToAllUnits) {
        for (i = unitGroupCount; i > 0; i -= 1) {
            if (UnitGetType(UnitGroupUnitFromEnd(unitGroup, i)) != "HeroLostVikingsController" && UnitHasBehavior2(UnitGroupUnitFromEnd(unitGroup, i), behavior)) {
                if (player == libAffx_choPlayer || player == libAffx_gallPlayer) {
                    UnitBehaviorRemove(libGame_gv_players[libAffx_gallPlayer].lv_heroUnit, behavior, stacks);
                    UnitBehaviorRemove(libGame_gv_players[libAffx_choPlayer].lv_heroUnit, behavior, stacks);
                    break;
                } else {
                    UnitBehaviorRemove(UnitGroupUnitFromEnd(unitGroup, i), behavior, stacks);
                }
            }
        }
    } else {
        if (UnitHasBehavior2(UnitGroupUnitFromEnd(unitGroup, unitGroupCount), behavior)) {
            if (UnitGetType(UnitGroupUnitFromEnd(unitGroup, unitGroupCount)) == "HeroLostVikingsController") {
                UnitBehaviorRemove(UnitGroupUnitFromEnd(unitGroup, unitGroupCount - 1), behavior, stacks);
            } else {
                if (player == libAffx_choPlayer || player == libAffx_gallPlayer) {
                    UnitBehaviorRemove(libGame_gv_players[libAffx_gallPlayer].lv_heroUnit, behavior, stacks);
                    UnitBehaviorRemove(libGame_gv_players[libAffx_choPlayer].lv_heroUnit, behavior, stacks);
                } else {
                    UnitBehaviorRemove(UnitGroupUnitFromEnd(unitGroup, unitGroupCount), behavior, stacks);
                }
            }
        }
    }
}

void libAffx_ModifyTokenCount (int player, int tokens, string quest) {
    int i;
    unitgroup unitGroup;
    int unitGroupCount;
    unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    for (i = unitGroupCount; i > 0; i -= 1) {
        libGame_gf_ModifyTokenCount(tokens, quest, UnitGroupUnitFromEnd(unitGroup, i));
    }
}

void libAffx_AddTokenCount(unit unitToAdd, string tokenBehavior, fixed value) {
    UnitSetTokenCount(unitToAdd, tokenBehavior, UnitGetTokenCount(unitToAdd, tokenBehavior) + value, unitToAdd);
}

bool libAffx_PlayerHasBehavior (int player, string behavior) {
    int i;
    unitgroup unitGroup;
    int unitGroupCount;
    unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    for (i = unitGroupCount; i > 0; i -= 1) {
        if (UnitHasBehavior2(UnitGroupUnitFromEnd(unitGroup, i), behavior)) {
            return true;
        }
    }
    return false;
}

int libAffx_PlayerBehaviorCount (int player, string behavior) {
    int i;
    unitgroup unitGroup;
    int unitGroupCount;
    unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    for (i = unitGroupCount; i > 0; i -= 1) {
        if (UnitHasBehavior2(UnitGroupUnitFromEnd(unitGroup, i), behavior)) {
            return UnitBehaviorCount(UnitGroupUnitFromEnd(unitGroup, i), behavior);
        }
    }
    return 0;
}

void libAffx_UnitCreateEffectUnit (int player, string effect) {
    int i;
    unitgroup unitGroup;
    int unitGroupCount;
    unitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    unitGroupCount = UnitGroupCount(unitGroup, c_unitCountAll);
    if (unitGroupCount == 1) {
        UnitCreateEffectUnit(libGame_gv_players[player].lv_heroUnit, effect, libGame_gv_players[player].lv_heroUnit);
    } else {
        for (i = unitGroupCount; i > 0; i -= 1) {
            UnitCreateEffectUnit(UnitGroupUnitFromEnd(unitGroup, i), effect, UnitGroupUnitFromEnd(unitGroup, i));
        }
    }
}

unit libAffx_GetDVaMech (int player) { 
    unitgroup heroUnitGroup;
    unit heroUnit;
    unit mechUnit;
    int groupCount;

    heroUnitGroup = libGame_gv_players[player].lv_heroUnitGroup;
    groupCount = UnitGroupCount(heroUnitGroup, c_unitCountAll);

    for (;; groupCount -= 1) {
        if (groupCount <= 0) { break; }
        heroUnit = UnitGroupUnitFromEnd(heroUnitGroup, groupCount);
        if (UnitGetType(heroUnit) == "HeroDVaMech") {
            mechUnit = heroUnit;
        }
    }
    return mechUnit;
}

unit libAffx_GetHeroUnit (int player) {
    unitgroup heroGroup;
    unit heroUnit;
    int unitGroupCount;
    if (libGame_gv_players[player].lv_heroIndex == libCore_gf_GetIndexFromHero("LostVikings")) {
        heroGroup = libGame_gv_players[player].lv_heroUnitGroup;
        unitGroupCount = UnitGroupCount(heroGroup, c_unitCountAll);
        for (;; unitGroupCount -= 1) {
            if (unitGroupCount <= 0) { break; }
            heroUnit = UnitGroupUnitFromEnd(heroGroup, unitGroupCount);
            if (UnitGetType(heroUnit) == "HeroOlaf") {
                return heroUnit;
            }
        }
        return null;
    } else {
        return libGame_gv_players[player].lv_heroUnit;
    }
}

unit libAffx_GetPlayerUnit (int player) {
    return libAffx_GetHeroUnit(player);
}

// Modify catalog with specified scaling scaling and value
void libAffx_LevelUpScaling3(string reference, int player, fixed scaling, fixed value) {
    int level = UnitLevel(libGame_gv_players[player].lv_heroUnit);
    if (player == 0) { return; }
    if (level <= 0) { level = 1; }
    CatalogReferenceModify(reference, player, FixedToString(value * Pow(1 + scaling, level), 4), c_upgradeOperationSet);
}

// Modify catalog with specified scaling scaling
void libAffx_LevelUpScaling2(string reference, int player, fixed scaling) {
    libAffx_LevelUpScaling3(reference, player, scaling, StringToFixed(CatalogReferenceGet(reference, 0)));
}

// Modify catalog with default 4% scaling
void libAffx_LevelUpScaling(string reference, int player) {
    libAffx_LevelUpScaling2(reference, player, 0.04);
}

string libAffx_GetCatalogDefault(string reference) {
    return CatalogReferenceGet(reference, 0);
}

void libAffx_CatalogFieldValueSetFixed(int catalog, string entry, string fieldPath, int player, fixed value) {
    if (player != 0 && (player == libAffx_choPlayer || player == libAffx_gallPlayer)) {
        CatalogFieldValueSetFixed(catalog, entry, fieldPath, libAffx_gallPlayer, value);
        CatalogFieldValueSetFixed(catalog, entry, fieldPath, libAffx_choPlayer, value);
    } else {
        CatalogFieldValueSetFixed(catalog, entry, fieldPath, player, value);
    }
}

void libAffx_CatalogReferenceModify2 (string reference, int player, string value, int operation) {
    if (player != 0 && (player == libAffx_choPlayer || player == libAffx_gallPlayer)) {
        CatalogReferenceModify(reference, libAffx_choPlayer, value, operation);
        CatalogReferenceModify(reference, libAffx_gallPlayer, value, operation);
    } else {
        CatalogReferenceModify(reference, player, value, operation);
    }
}

void libAffx_CatalogReferenceModify (string reference, int player, string value) {
    libAffx_CatalogReferenceModify2(reference, player, value, c_upgradeOperationSet);
}

string libAffx_StringFraction(int value, int precision) {
    int scale = PowI(10, precision);
    int number = value / scale;
    int fractionInt = value % scale;
    string fraction = IntToString(fractionInt);
    while (StringLength(fraction) < precision) {
        fraction = "0" + fraction;
    }

    if (fractionInt == 0) {
        return IntToString(number);
    }
    return IntToString(number) + "." + fraction;
}

// --------------------------------------------------------------------------------
// Affix effects
// --------------------------------------------------------------------------------

void libAffx_ApplyTalents(int affix) {
    int i;
    string addTalent;
    string showTalent;
    for (i = 1; i <= libAffx_maxTalentsAdd; i += 1) {
        addTalent = libAffx_affixes[affix].addTalents[i];
        if (addTalent != "" && addTalent != null) {
            libAffx_AddTalent(libAffx_player, addTalent);
            SetTalentEnabled(addTalent, false);
        }
        showTalent = libAffx_affixes[affix].showTalents[i];
        if (showTalent != "" && showTalent != null) {
            libAffx_ShowTalent(showTalent, true);
        }
    }
}
void libAffx_ApplyCatalogModifications(int affix, int amount) {
    int i;
    int i2;
    int totalAmount = libAffx_affixes[affix].count;
    string catalogReference;
    int catalogType;
    int catalogPlayer;
    fixed catalogValue;
    string catalogValueString;
    int catalogOperation;
    for (i = 1; i <= libAffx_maxCatalogModification; i += 1) {
        catalogReference = libAffx_affixes[affix].catalogModifications[i].reference;
        if (catalogReference != "" && catalogReference != null) {
            catalogType = libAffx_affixes[affix].catalogModifications[i].type;
            catalogValue = libAffx_affixes[affix].catalogModifications[i].value;
            catalogPlayer = libAffx_affixes[affix].catalogModifications[i].player;
            catalogOperation = libAffx_affixes[affix].catalogModifications[i].operation;
            if (catalogType == libAffx_catalogTypeFlat) {
                catalogValueString = FixedToString(catalogValue, c_fixedPrecisionAny);
            } else if (catalogType == libAffx_catalogTypePerStack) {
                catalogValueString = FixedToString(catalogValue * totalAmount, c_fixedPrecisionAny);
            } else if (catalogType == libAffx_catalogTypePerStackDelta) {
                catalogValueString = FixedToString(catalogValue * amount, c_fixedPrecisionAny);
            } else if (catalogType == libAffx_catalogTypePerStackDeltaExclFirst) {
                if (libAffx_affixes[affix].count <= 1 || amount > 1) {
                    catalogValueString = FixedToString(catalogValue * (amount - 1), c_fixedPrecisionAny);
                } else {
                    catalogValueString = FixedToString(catalogValue * amount, c_fixedPrecisionAny);
                }
            } else if (catalogType == libAffx_catalogTypeAdditiveMult) {
                catalogValueString = FixedToString(1 + (catalogValue * totalAmount), c_fixedPrecisionAny);
            } else if (catalogType == libAffx_catalogTypeAdditiveMultDelta) {
                catalogValueString = FixedToString(1 + (catalogValue * amount), c_fixedPrecisionAny);
            } else if (catalogType == libAffx_catalogTypeAdditiveReductionMult) {
                catalogValueString = FixedToString(1 - (catalogValue * totalAmount), c_fixedPrecisionAny);
            } else if (catalogType == libAffx_catalogTypeAdditiveReductionMultDelta) {
                catalogValueString = FixedToString(1 - (catalogValue * amount), c_fixedPrecisionAny);
            } else {
                catalogValueString = FixedToString(catalogValue, c_fixedPrecisionAny);
            }
            if (catalogPlayer == 0) {
                for (i2 = 1; i2 <= 12; i2 += 1) {
                    if ((i2 == libAffx_choPlayer || i2 == libAffx_gallPlayer) && libAffx_affixes[affix].excludeChoGall) {
                        continue;
                    } else {
                        CatalogReferenceModify(catalogReference, i2, catalogValueString, catalogOperation);
                    }
                }
            } else if ((catalogPlayer == libAffx_choPlayer || catalogPlayer == libAffx_gallPlayer) && libAffx_affixes[affix].excludeChoGall) {
                continue;
            } else if (catalogPlayer >= 1 && catalogPlayer <= 12) {
                CatalogReferenceModify(catalogReference, catalogPlayer, catalogValueString, catalogOperation);
            }
        }
    }
}
void libAffx_ApplyBehaviors(int affix, int amount) {
    int i;
    int i2;
    int i3;
    string behavior;
    int behaviorPlayer;
    unitgroup unitGroup;
    int unitGroupCount;
    int amountToAdd;
    bool affectedByCount;
    for (i = 1; i <= libAffx_maxBehavior; i += 1) {
        behavior = libAffx_affixes[affix].behaviors[i].behavior;
        if (behavior != "" && behavior != null) {
            behaviorPlayer = libAffx_affixes[affix].behaviors[i].player;
            if (libAffx_affixes[affix].behaviors[i].affectedByCount) {
                amountToAdd = amount;
            } else {
                amountToAdd = 1;
            }
            if (behaviorPlayer == 0) {
                for (i2 = 1; i2 <= 10; i2 += 1) {
                    if ((i2 == libAffx_choPlayer || i2 == libAffx_gallPlayer) && libAffx_affixes[affix].excludeChoGall) {
                        continue;
                    } else {
                        if (UnitHasBehavior2(libGame_gv_players[i2].lv_heroUnit, "NotManaUserDummy") && libAffx_affixes[affix].behaviors[i].onlyManaUsers) {
                        } else if (!UnitHasBehavior2(libGame_gv_players[i2].lv_heroUnit, "NotManaUserDummy") && libAffx_affixes[affix].behaviors[i].disallowManaUsers) {
                        } else {
                            libAffx_AddBehavior(i2, behavior, amountToAdd, true);
                        }
                    }
                }
            } else if ((behaviorPlayer == libAffx_choPlayer || behaviorPlayer == libAffx_gallPlayer) && libAffx_affixes[affix].excludeChoGall) {
                continue;
            } else if (behaviorPlayer >= 1 && behaviorPlayer <= 10) {
                if (UnitHasBehavior2(libGame_gv_players[behaviorPlayer].lv_heroUnit, "NotManaUserDummy") && libAffx_affixes[affix].behaviors[i].onlyManaUsers) {
                } else if (!UnitHasBehavior2(libGame_gv_players[behaviorPlayer].lv_heroUnit, "NotManaUserDummy") && libAffx_affixes[affix].behaviors[i].disallowManaUsers) {
                } else {
                    libAffx_AddBehavior(behaviorPlayer, behavior, amountToAdd, true);
                }
            }
        }
    }
}
void libAffx_ApplyImmediateTriggers() {
    int i;
    int i2;
    int i3;
    for (i = 1; i <= libAffx_registeredAffixes; i += 1) {
        for (i2 = 1; i2 <= libAffx_maxTrigger; i2 += 1) {
            if (libAffx_affixes[i].triggers[i2].type == libAffx_triggerGameStart) {
                if (libAffx_affixes[i].createdTriggers[i2] == null) {
                    libAffx_affixes[i].createdTriggers[i2] = TriggerCreate(libAffx_affixes[i].triggers[i2].name);
                }
                TriggerExecute(libAffx_affixes[i].createdTriggers[i2], true, false);
            } else if (libAffx_affixes[i].triggers[i2].type == libAffx_triggerScaling) {
                if (libAffx_affixes[i].createdTriggers[i2] == null) {
                    libAffx_affixes[i].createdTriggers[i2] = TriggerCreate(libAffx_affixes[i].triggers[i2].name);
                }
                libGame_gf_HeroLevelUp(libAffx_affixes[i].createdTriggers[i2]);
                for (i3 = 1; i3 <= 10; i3 += 1) {
                    DataTableSetInt(false, TriggerEventParamName(libGame_gv_eventID_HeroLevelUp_C, libGame_gv_eventParam_HeroLevelUp_Player), i3);
                    DataTableSetInt(false, TriggerEventParamName(libGame_gv_eventID_HeroLevelUp_C, libGame_gv_eventParam_HeroLevelUp_Level), UnitLevel(libGame_gv_players[i3].lv_heroUnit));
                    TriggerExecute(libAffx_affixes[i].createdTriggers[i2], true, false);
                }
            } 
        }
    }
}
void libAffx_ApplyTriggers(int affix, int amount) {
    int i;
    int i2;
    int triggerType;
    string triggerName;
    string triggerArg1;

    libAffx_executingAffix = affix;
    libAffx_executingAffixCount = amount;
    for (i = 1; i <= libAffx_maxTrigger; i += 1) {
        triggerType = libAffx_affixes[affix].triggers[i].type;
        triggerName = libAffx_affixes[affix].triggers[i].name;
        triggerArg1 = libAffx_affixes[affix].triggers[i].arg1;
        if (triggerType != 0) {
            if (!libAffx_affixes[affix].triggers[i].init) {
                libAffx_affixes[affix].triggers[i].init = true;
                if (libAffx_affixes[affix].createdTriggers[i] == null) {
                    libAffx_affixes[affix].createdTriggers[i] = TriggerCreate(triggerName);
                }
                if (triggerType == libAffx_triggerAffixAdded) {
                    TriggerAddEventGeneric(libAffx_affixes[affix].createdTriggers[i], libAffx_eventID + libAffx_affixes[affix].name);
                } else if (triggerType == libAffx_triggerNPCTakedown) {
                    libGame_gf_HeroParticipatedInNPCTakedown(libAffx_affixes[affix].createdTriggers[i]);
                } else if (triggerType == libAffx_triggerHeroTakedown) {
                    libGame_gf_HeroParticipatedInTakedown(libAffx_affixes[affix].createdTriggers[i]);
                } else if (triggerType == libAffx_triggerUnitCreated) {
                    TriggerAddEventUnitCreated(libAffx_affixes[affix].createdTriggers[i], null, null, null);
                } else if (triggerType == libAffx_triggerHeroRespawn) {
                    libGame_gf_HeroRespawn(libAffx_affixes[affix].createdTriggers[i]);
                } else if (triggerType == libAffx_triggerUnitBehaviorChange) {
                    if (triggerArg1 != "" && triggerArg1 != null) {
                        TriggerAddEventUnitBehaviorChange(libAffx_affixes[affix].createdTriggers[i], null, triggerArg1, c_unitBehaviorChangeActivate);
                    } else {
                        TriggerAddEventUnitBehaviorChange(libAffx_affixes[affix].createdTriggers[i], null, libAffx_affixes[affix].behaviors[i].behavior, c_unitBehaviorChangeActivate);
                    }
                } else if (triggerType == libAffx_triggerUnitBehaviorCreate) {
                    if (triggerArg1 != "" && triggerArg1 != null) {
                        TriggerAddEventUnitBehaviorChange(libAffx_affixes[affix].createdTriggers[i], null, triggerArg1, c_unitBehaviorChangeCreate);
                    } else {
                        TriggerAddEventUnitBehaviorChange(libAffx_affixes[affix].createdTriggers[i], null, libAffx_affixes[affix].behaviors[i].behavior, c_unitBehaviorChangeCreate);
                    }
                } else if (triggerType == libAffx_triggerUnitBehaviorChangeCategory) {
                    if (StringCase(triggerArg1, false) == "blind") {
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategoryDebuffBlind, c_unitBehaviorChangeCreate);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategoryDebuffBlind, c_unitBehaviorChangeRefresh);
                    } else if (StringCase(triggerArg1, false) == "cc") {
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategorySlow, c_unitBehaviorChangeCreate);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategorySlow, c_unitBehaviorChangeRefresh);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategoryDebuffRoot, c_unitBehaviorChangeCreate);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategoryDebuffRoot, c_unitBehaviorChangeRefresh);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategoryStun, c_unitBehaviorChangeCreate);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategoryStun, c_unitBehaviorChangeRefresh);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategoryDebuffSilence, c_unitBehaviorChangeCreate);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, c_behaviorCategoryDebuffSilence, c_unitBehaviorChangeRefresh);
                    } else if (triggerArg1 != "" && triggerArg1 != null) {
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, StringToInt(triggerArg1), c_unitBehaviorChangeCreate);
                        TriggerAddEventUnitBehaviorChangeFromCategory(libAffx_affixes[affix].createdTriggers[i], null, StringToInt(triggerArg1), c_unitBehaviorChangeRefresh);
                    }
                } else if (triggerType == libAffx_triggerPlayerEffectUsed) {
                    if (triggerArg1 != "" && triggerArg1 != null) {
                        TriggerAddEventPlayerEffectUsed(libAffx_affixes[affix].createdTriggers[i], c_playerAny, triggerArg1);
                    }
                } else if (triggerType == libAffx_triggerHeroLevelUp) {
                    libGame_gf_HeroLevelUp(libAffx_affixes[affix].createdTriggers[i]);
                } else if (triggerType == libAffx_triggerUnitDied) {
                    TriggerAddEventUnitDied(libAffx_affixes[affix].createdTriggers[i], null);
                } else if (triggerType == libAffx_triggerHeroKilled) {
                    libGame_gf_HeroKilled(libAffx_affixes[affix].createdTriggers[i]);
                } else if (triggerType == libAffx_triggerQuest) {
                    if (libAffx_affixes[affix].quest.isQuest && !libAffx_affixes[affix].quest.questDone) {
                        TriggerExecute(libAffx_affixes[affix].createdTriggers[i], true, false);
                    }
                } else if (triggerType == libAffx_triggerUnitChangeOwner) {
                    TriggerAddEventUnitChangeOwner(libAffx_affixes[affix].createdTriggers[i], null);
                } else if (triggerType == libAffx_triggerPeriodic) {
                    if (triggerArg1 != "" && triggerArg1 != null) {
                        TriggerAddEventTimePeriodic(libAffx_affixes[affix].createdTriggers[i], StringToFixed(triggerArg1), c_timeGame);
                    } else {
                        TriggerAddEventTimePeriodic(libAffx_affixes[affix].createdTriggers[i], 0.0625, c_timeGame);
                    }
                } else if (triggerType == libAffx_triggerWin) {
                    TriggerAddEventGeneric(libAffx_affixes[affix].createdTriggers[i], "GameWonEvent");
                }
            }
            if (triggerType == libAffx_triggerAffixAdded) {
                libAffx_SendAffixAddedEvent(affix, amount);
            } else if (libAffx_affixes[affix].createdTriggers[i] != null && triggerType == libAffx_triggerExecute) {
                TriggerExecute(libAffx_affixes[affix].createdTriggers[i], true, false);
            } else if (libAffx_affixes[affix].createdTriggers[i] != null && triggerType == libAffx_triggerOneTime && libAffx_affixes[affix].shouldExecute) {
                TriggerExecute(libAffx_affixes[affix].createdTriggers[i], true, false);
            } else if (libAffx_affixes[affix].createdTriggers[i] != null && triggerType == libAffx_triggerOncePerGame && !libAffx_affixes[affix].triggers[i].hasExecuted) {
                libAffx_affixes[affix].triggers[i].hasExecuted = true;
                TriggerExecute(libAffx_affixes[affix].createdTriggers[i], true, false);
            } else if (libAffx_affixes[affix].createdTriggers[i] != null && triggerType == libAffx_triggerHeroLevelUp && !libAffx_affixes[affix].triggers[i].hasExecuted) {
                libAffx_affixes[affix].triggers[i].hasExecuted = true;
                for (i2 = 1; i2 <= 10; i2 += 1) {
                    DataTableSetInt(false, TriggerEventParamName(libGame_gv_eventID_HeroLevelUp_C, libGame_gv_eventParam_HeroLevelUp_Player), i2);
                    DataTableSetInt(false, TriggerEventParamName(libGame_gv_eventID_HeroLevelUp_C, libGame_gv_eventParam_HeroLevelUp_Level), UnitLevel(libGame_gv_players[i2].lv_heroUnit));
                    TriggerExecute(libAffx_affixes[affix].createdTriggers[i], true, false);
                }
            }
        }
    }
}
void libAffx_ApplyQuest(int affix) {
    int i;
    for (i = 1; i <= libAffx_maxQuestRetain; i += 1) {
        if (libAffx_affixes[affix].questRetain[i].tokenBehavior != "" && libAffx_affixes[affix].questRetain[i].tokenBehavior != null && libAffx_affixes[affix].questRetain[i].tokenCount > 0) {
            libAffx_ModifyTokenCount(libAffx_player, RoundI(libAffx_affixes[affix].questRetain[i].tokenCount), libAffx_affixes[affix].questRetain[i].tokenBehavior);
        }
    }
}
void libAffx_ApplyAffix(int affix, int amount) {
    if (libAffx_affixes[affix].count <= 0 || amount <= 0) {
        return;
    }

    libAffx_ApplyTalents(affix);
    libAffx_ApplyCatalogModifications(affix, amount);
    libAffx_ApplyBehaviors(affix, amount);
    libAffx_ApplyTriggers(affix, amount);
    libAffx_ApplyQuest(affix);

    // AA speed fix for Tassadar
    if (libGame_gv_players[libAffx_player].lv_heroIndex == libCore_gf_GetIndexFromHero("Tassadar") && !UnitHasBehavior2(libGame_gv_players[libAffx_player].lv_heroUnit, "TassadarAAFix")) {
        UnitBehaviorAdd(libGame_gv_players[libAffx_player].lv_heroUnit, "TassadarAAFix", libGame_gv_players[libAffx_player].lv_heroUnit, 1);
    }

    libAffx_affixes[affix].shouldExecute = false;
}
void libAffx_AddAffix(int affix, int count) {
    if (affix == 0) {
        return;
    }
    libAffx_affixes[affix].count += count;
    libAffx_affixes[affix].shouldExecute = true;
    libAffx_skipCurseCounter += libAffx_affixes[affix].skipCurses;
    libAffx_ApplyAffix(affix, count);
}
void libAffx_SetAffix(int affix, int count) {
    if (affix == 0) {
        return;
    }
    libAffx_affixes[affix].count = count;
    libAffx_affixes[affix].shouldExecute = true;
    libAffx_skipCurseCounter += libAffx_affixes[affix].skipCurses;
    libAffx_ApplyAffix(affix, count);
}

