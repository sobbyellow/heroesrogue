    BankLoad("PlayerSettings", libAffx_player);
    return BankValueGetAsString(BankLastCreated(), libAffx_BankSection, key);
}
int libAffx_BankLoadValueInt(string key) {
    BankLoad("PlayerSettings", libAffx_player);
    return BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, key);
}
fixed libAffx_BankLoadValueFixed(string key) {
    BankLoad("PlayerSettings", libAffx_player);
    return BankValueGetAsFixed(BankLastCreated(), libAffx_BankSection, key);
}
void libAffx_BankSaveValueString(string key, string value) {
    BankLoad("PlayerSettings", libAffx_player);
    BankValueSetFromString(BankLastCreated(), libAffx_BankSection, key, value);
    BankSave(BankLastCreated());
}
void libAffx_BankSaveValueInt(string key, int value) {
    BankLoad("PlayerSettings", libAffx_player);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, key, value);
    BankSave(BankLastCreated());
}
void libAffx_BankSaveValueFixed(string key, fixed value) {
    BankLoad("PlayerSettings", libAffx_player);
    BankValueSetFromFixed(BankLastCreated(), libAffx_BankSection, key, value);
    BankSave(BankLastCreated());
}
void libAffx_SettingsSavePBUDifficulty() {
    BankLoad("PlayerSettings", libAffx_player);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSectionSettings, "Difficulty", libPBU2_difficulty);
    BankSave(BankLastCreated());
}
void libAffx_SettingsSave() {
    BankLoad("PlayerSettings", libAffx_player);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSectionSettings, "Difficulty", libAffx_difficulty);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSectionSettings, "SpeedUp", BoolToInt(libAffx_speedUpStart));
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSectionSettings, "SpeedUpDeath", BoolToInt(libAffx_speedUpDeath));
    BankSave(BankLastCreated());
}
void libAffx_SettingsLoad() {
    BankLoad("PlayerSettings", libAffx_player);

    if (BankKeyExists(BankLastCreated(), libAffx_BankSectionSettings, "Difficulty")) {
        libAffx_loadedDifficulty = BankValueGetAsInt(BankLastCreated(), libAffx_BankSectionSettings, "Difficulty");
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSectionSettings, "SpeedUp")) {
        if (BankValueGetAsInt(BankLastCreated(), libAffx_BankSectionSettings, "SpeedUp") == 1) {
            libAffx_speedUpStart = true;
        }
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSectionSettings, "SpeedUpDeath")) {
        if (BankValueGetAsInt(BankLastCreated(), libAffx_BankSectionSettings, "SpeedUpDeath") == 1) {
            libAffx_speedUpDeath = true;
        }
    }
    libPBU2_SetDifficulty(libAffx_loadedDifficulty);
}
void libAffx_BankSave() {
    string affixName;
    int i;
    int i2;
    unitgroup heroGroup = libGame_gv_players[libAffx_player].lv_heroUnitGroup;
    unit heroUnit;
    int groupCount;
    BankLoad("PlayerSettings", libAffx_player);
    BankValueSetFromString(BankLastCreated(), libAffx_BankSection, "Map", libAffx_nextMap);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, "CurrentRun", libAffx_currentRun);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, "Hero", libAffx_playersHeroIndex[libAffx_player]);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, "ObjectiveCounter", libAffx_objectivesWonCounter);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, "SkipCurseCounter", libAffx_skipCurseCounter);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, "Rerolls", libAffx_rerolls);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, "RerollsCurse", libAffx_rerollsCurse);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, "Difficulty", libAffx_difficulty);
    BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, "CursesNextGame", libAffx_cursesNextGame);
    for (i = 1; i <= libAffx_registeredAffixes; i += 1) {
        affixName = libAffx_affixes[i].name;
        if (libAffx_affixes[i].quest.isQuest) {
            if (libAffx_affixes[i].quest.questDone) {
                BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, affixName + "_QuestDone", 1);
            }
            if (libAffx_affixes[i].quest.questProgressPersists && libAffx_affixes[i].quest.questProgress > 0) {
                BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, affixName + "_QuestProgress", libAffx_affixes[i].quest.questProgress);
            }
        }
        for (i2 = 1; i2 <= libAffx_maxQuestRetain; i2 += 1) {
            if (libAffx_affixes[i].questRetain[i2].tokenBehavior != "" && libAffx_affixes[i].questRetain[i2].tokenBehavior != null) {
                groupCount = UnitGroupCount(heroGroup, c_unitCountAll);
                for (;; groupCount -= 1) {
                    heroUnit = UnitGroupUnitFromEnd(heroGroup, groupCount);
                    if (groupCount <= 0) { break; }
                    if (heroUnit == null) { continue; }
                    if (UnitGetTokenCount(heroUnit, libAffx_affixes[i].questRetain[i2].tokenBehavior) > 0) {
                        BankValueSetFromFixed(BankLastCreated(), libAffx_BankSection, libAffx_affixes[i].questRetain[i2].tokenBehavior, UnitGetTokenCount(heroUnit, libAffx_affixes[i].questRetain[i2].tokenBehavior) * libAffx_affixes[i].questRetain[i2].retainModifier);
                    }
                }
            }
        }
        if (libAffx_affixes[i].count > 0) {
            BankValueSetFromInt(BankLastCreated(), libAffx_BankSection, affixName + "_Count", libAffx_affixes[i].count);
        }
    }
    BankSave(BankLastCreated());
}
void libAffx_BankLoad() {
    string affixName;
    int i;
    int i2;
    BankLoad("PlayerSettings", libAffx_player);

    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "Map")) {
        libAffx_currentMap = libAffx_GetMapID(BankValueGetAsString(BankLastCreated(), libAffx_BankSection, "Map"));
    } else {
        libAffx_currentMap = libAffx_startingMap;
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "CurrentRun")) {
        libAffx_currentRun = BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, "CurrentRun");
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "Hero")) {
        libAffx_playerHeroIndexLoaded = BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, "Hero");
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "ObjectiveCounter")) {
        libAffx_objectivesWonCounter = BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, "ObjectiveCounter");
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "SkipCurseCounter")) {
        libAffx_skipCurseCounter = BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, "SkipCurseCounter");
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "Rerolls")) {
        libAffx_rerolls += BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, "Rerolls");
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "RerollsCurse")) {
        libAffx_rerollsCurse += BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, "RerollsCurse");
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "Difficulty")) {
        libAffx_difficulty = BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, "Difficulty");
    }
    if (BankKeyExists(BankLastCreated(), libAffx_BankSection, "CursesNextGame")) {
        libAffx_cursesQueued += BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, "CursesNextGame");
    }

    for (i = 1; i <= libAffx_registeredAffixes; i += 1) {
        affixName = libAffx_affixes[i].name;
        if (BankKeyExists(BankLastCreated(), libAffx_BankSection, affixName + "_Count")) {
            libAffx_affixes[i].count = BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, affixName + "_Count");
        } else {
            libAffx_affixes[i].count = 0;
        }
        if (libAffx_affixes[i].quest.isQuest) {
            if (BankKeyExists(BankLastCreated(), libAffx_BankSection, affixName + "_QuestDone")) {
                if (BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, affixName + "_QuestDone") == 1) {
                    libAffx_affixes[i].quest.questDone = true;
                } else {
                    libAffx_affixes[i].quest.questDone = false;
                }
            }
            if (libAffx_affixes[i].quest.questProgressPersists) {
                libAffx_affixes[i].quest.questProgress = BankValueGetAsInt(BankLastCreated(), libAffx_BankSection, affixName + "_QuestProgress");
            }
        }
        for (i2 = 1; i2 <= libAffx_maxQuestRetain; i2 += 1) {
            if (BankKeyExists(BankLastCreated(), libAffx_BankSection, libAffx_affixes[i].questRetain[i2].tokenBehavior)) {
                libAffx_affixes[i].questRetain[i2].tokenCount = BankValueGetAsFixed(BankLastCreated(), libAffx_BankSection, libAffx_affixes[i].questRetain[i2].tokenBehavior);
            }
        }
    }
    while (!libAffx_playersFirstSpawnIn[libAffx_player]) {
        libAffx_Wait(0.0625, c_timeGame);
    }
    libAffx_Wait(libAffx_gameStartDelay, c_timeGame);
    for (i = 1; i <= libAffx_registeredAffixes; i += 1) {
        if (libAffx_affixes[i].count > 0) {
            libAffx_ApplyAffix(i, libAffx_affixes[i].count);
        }
    }
    libAffx_DebugPrint("Boons & Curses loaded!");
}
void libAffx_BankReset() {
    string affixName;
    int i;
    BankLoad("PlayerSettings", libAffx_player);
    BankSectionRemove(BankLastCreated(), libAffx_BankSection);
    BankSave(BankLastCreated());
}

bool libAffx_GameOverCallbackTrigger_Func (bool testConds, bool runActions) {
    int winningTeam;
    int map;
    // Actions
    if (!runActions) {
        return true;
    }
    winningTeam = libGame_winningTeam;
    map = libAffx_GetMapID(libCore_gv_mAPMapStringID);

    if (winningTeam == 1) {
        if (map == libAffx_mapCursedHollow) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorialmapmechanics.stormmap");
            libAffx_nextMap = "Shrines";
        } else if (map == libAffx_mapShrines) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorial01.stormmap");
            libAffx_nextMap = "Crypts";
        } else if (map == libAffx_mapCrypts) {
            GameSetNextMap("heroes/singleplayermaps/(10)trymemode.stormmap");
            libAffx_nextMap = "DragonShire";
        } else if (map == libAffx_mapDragonShire) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorialveteran.stormmap");
            libAffx_nextMap = "CursedHollow";
        }
        libAffx_BankSave();
    } else {
        libAffx_BankReset();
    }

    return true;
}
void libAffx_GameOverCallbackTrigger_Init () {
    libAffx_GameOverCallbackTrigger = TriggerCreate("libAffx_GameOverCallbackTrigger_Func");
    libGame_gv_gameOverCallback = libAffx_GameOverCallbackTrigger;
}

//
// Affix logic every second
//
bool libAffx_AffixLogicPeriodicTrigger_Func (bool testConds, bool runActions) {

    // Actions
    if (!runActions) {
        return true;
    }

    return true;
}
void libAffx_AffixLogicPeriodicTrigger_Init () {
    libAffx_AffixLogicPeriodicTrigger = TriggerCreate("libAffx_AffixLogicPeriodicTrigger_Func");
    TriggerAddEventTimePeriodic(libAffx_AffixLogicPeriodicTrigger, 1.0, c_timeGame);
}

//
// Affix logic on unit creation
//
bool libAffx_AffixLogicUnitCreatedTrigger_Func (bool testConds, bool runActions) {
    unit createdUnit = EventUnitCreatedUnit();
    int player = UnitGetOwner(createdUnit);
    if (!runActions) {
        return true;
    }

    if (player == libAffx_player && !libAffx_playersFirstSpawnIn[libAffx_player]) {
        libAffx_playersFirstSpawnIn[libAffx_player] = true;
        DialogSetVisible(libAffx_dialogTopRight, PlayerGroupAll(), true);
        libGame_gv_players[libAffx_player].lv_heroIndex = libAffx_playersHeroIndex[libAffx_player];
        if (libAffx_currentRun <= 1) {
            libAffx_difficulty = libPBU2_difficulty;
            libAffx_SettingsSave();
        }
        libAffx_CreateCurrentRunDialog();

        if (libGame_gv_players[libAffx_player].lv_heroIndex == libCore_gf_GetIndexFromHero("Gall")) {
            libAffx_gallPlayer = 1;
            libAffx_choPlayer = 2;
        } else if (libGame_gv_players[libAffx_player].lv_heroIndex == libCore_gf_GetIndexFromHero("Cho")) {
            libAffx_choPlayer = 1;
            libAffx_gallPlayer = 2;
        }
        libAffx_ApplyImmediateTriggers();
    }
    if (player >= 2 && player <= 10 && !libAffx_playersFirstSpawnIn[player]) {
        libAffx_playersFirstSpawnIn[player] = true;
        libGame_gv_players[player].lv_heroIndex = libAffx_playersHeroIndex[player];
    }

    return true;
}
void libAffx_AffixLogicUnitCreatedTrigger_Init () {
    libAffx_AffixLogicUnitCreatedTrigger = TriggerCreate("libAffx_AffixLogicUnitCreatedTrigger_Func");
    TriggerAddEventUnitCreated(libAffx_AffixLogicUnitCreatedTrigger, null, null, null);
}

int libAffx_RollRarity(int baseRarity, bool curse) {
    int result = baseRarity;
    fixed roll;
    fixed modifier = 1.0;
    fixed modifierHigh = 0;
    roll = RandomFixed(0, 1.0);
    if (curse) {
        modifier += libAffx_curseAddRoll;
        modifierHigh += libAffx_curseAddHighRoll;
    }
    if (baseRarity == libAffx_rarityCommon) {
        if (roll <= libAffx_commonToLegendary * (modifier + modifierHigh)) {
            result = libAffx_rarityLegendary;
        } else if (roll <= (libAffx_commonToLegendary + libAffx_commonToEpic) * (modifier + modifierHigh)) {
            result = libAffx_rarityEpic;
        } else if (roll <= (libAffx_commonToLegendary + libAffx_commonToEpic + libAffx_commonToRare) * modifier) {
            result = libAffx_rarityRare;
        } else if (roll <= (libAffx_commonToLegendary + libAffx_commonToEpic + libAffx_commonToRare + libAffx_commonToUncommon) * modifier) {
            result = libAffx_rarityUncommon;
        }
    } else if (baseRarity == libAffx_rarityUncommon) {
        if (roll <= libAffx_uncommonToLegendary * (modifier + modifierHigh)) {
            result = libAffx_rarityLegendary;
        } else if (roll <= (libAffx_uncommonToLegendary + libAffx_uncommonToEpic) * (modifier + modifierHigh)) {
            result = libAffx_rarityEpic;
        } else if (roll <= (libAffx_uncommonToLegendary + libAffx_uncommonToEpic + libAffx_uncommonToRare) * modifier) {
            result = libAffx_rarityRare;
        }
    } else if (baseRarity == libAffx_rarityRare) {
        if (roll <= libAffx_rareToLegendary * (modifier + modifierHigh)) {
            result = libAffx_rarityLegendary;
        } else if (roll <= (libAffx_rareToLegendary + libAffx_rareToEpic) * (modifier + modifierHigh)) {
            result = libAffx_rarityEpic;
        }
    } else if (baseRarity == libAffx_rarityEpic) {
        if (roll <= libAffx_epicToLegendary * (modifier + modifierHigh)) {
            result = libAffx_rarityLegendary;
        }
    }
    return result;
}

int libAffx_RollAffix(int rarity, bool curse, int level, bool preventUpgrade) {
    int[libAffx_rollMax + 1] eligibleAffixes;
    int rolledAffix;
    int totalWeight = 0;
    int cumulativeWeight = 0;
    int slotRarity;
    int slotAffixCount = 0;
    int upgradeCount = 0;
    int i;
    int i2;
    bool eligible;
    bool upgradeRarity = true;
    int repeat = 3;

    slotRarity = rarity;

    while (true) {
        slotAffixCount = 0;
        
        // Search for eligible affixes
        for (i = 1; i <= libAffx_registeredAffixes; i += 1) {
            eligible = true;
            if (libAffx_affixes[i].name == "" || !libAffx_affixes[i].enabled || libAffx_affixes[i].cannotRoll) {
                continue;
            }
            if (slotAffixCount > libAffx_rollMax) {
                //continue; no cap for now
            }

            if (libAffx_affixes[i].requiredDifficulty != 0 && libAffx_affixes[i].requiredDifficulty > libAffx_difficulty) {
                continue;
            }

            if (curse && !libAffx_affixes[i].curse || !curse && libAffx_affixes[i].curse) {
                continue;
            }

            // Check for affix exclusions and requirements
            for (i2 = 1; i2 <= libAffx_registeredAffixes; i2 += 1) {
                if ((libAffx_affixes[i].excludedAffixes[i2] && libAffx_affixes[i2].count > 0) || (libAffx_affixes[i].requiredAffixes[i2] && libAffx_affixes[i2].count < 1 && libAffx_affixes[i2].max != 0) || (libAffx_affixes[i].requiredAffixes[i2] && libAffx_affixes[i2].count <= 0 && libAffx_affixes[i2].max == 0)) {
                    eligible = false;
                    break;
                }
            }
            for (i2 = 1; i2 <= libAffx_maxTalentsAdd; i2 += 1) {
                if (libAffx_affixes[i].requiredTalents[i2] != "" && libAffx_affixes[i].requiredTalents[i2] != null && !PlayerHasTalent(libAffx_player, libAffx_affixes[i].requiredTalents[i2])) {
                    eligible = false;
                    break;
                }
            }
            if (!eligible) {
                continue;
            }
            // Check for correct Map
            if (!libAffx_affixes[i].allowedMap[libAffx_GetMapID(libCore_gv_mAPMapStringID)]) {
                continue;
            }
            // Check for correct Hero
            if (!libAffx_affixes[i].allowedHero[libAffx_playersHeroIndex[libAffx_player]]) {
                continue;
            }
            // Check maximum count
            if ((libAffx_affixes[i].count >= libAffx_affixes[i].max) && libAffx_affixes[i].max != 0) {
                continue;
            }
            // Check for already rolled affixes
            if (libAffx_rolledAffixes[1] == i || libAffx_rolledAffixes[2] == i || libAffx_rolledAffixes[3] == i) {
                continue;
            }
            // Check min and max level requirement
            if ((libAffx_affixes[i].minLevel > 0 && level < libAffx_affixes[i].minLevel) || (libAffx_affixes[i].maxLevel > 0 && level > libAffx_affixes[i].maxLevel)) {
                continue;
            }
            // Check for rarity
            if (libAffx_affixes[i].rarity != slotRarity && !curse) {
                continue;
            }
            if (libAffx_affixes[i].lastSeen > 0) {
                libAffx_affixes[i].lastSeen -= 1;
                continue;
            }

            slotAffixCount += 1;
            eligibleAffixes[slotAffixCount] = i;
            if (curse) {
                totalWeight += FixedToInt(libAffx_affixes[i].weight / (1 + (libAffx_affixes[i].rarity - 1) * 0.25));
            } else {
                totalWeight += libAffx_affixes[i].weight;
            }
        }

        // Shuffle
        if (slotAffixCount > 0) {
            i2 = RandomInt(1, MaxI(totalWeight, 1));
            for (i = 1; i <= slotAffixCount; i += 1) {
                if (curse) {
                    cumulativeWeight += FixedToInt(libAffx_affixes[eligibleAffixes[i]].weight / (1 + (libAffx_affixes[eligibleAffixes[i]].rarity - 1) * 0.25));
                } else {
                    cumulativeWeight += libAffx_affixes[eligibleAffixes[i]].weight;
                }
                if (i2 <= cumulativeWeight) {
                    libAffx_affixes[eligibleAffixes[i]].lastSeen = 3;
                    return eligibleAffixes[i];
                }
            }
            i2 = RandomInt(1, slotAffixCount);
            libAffx_affixes[eligibleAffixes[i2]].lastSeen = 3;
            return eligibleAffixes[i2];
        }

        // Upgrade rarity if no affixes are found, and then downgrade if no upgraded rarity affixes are found
        if (!preventUpgrade) {
            if (slotRarity < libAffx_rarityLegendary && upgradeRarity) {
                slotRarity += 1;
                upgradeRarity = false;
                upgradeCount += 1;
            } else if (upgradeRarity) {
                upgradeCount += 1;
                upgradeRarity = false;
                slotRarity = MaxI(rarity - 1, libAffx_rarityCommon);
            } else if (slotRarity > libAffx_rarityCommon) {
                slotRarity -= 1;
            } else {
                if (repeat > 0) {
                    repeat -= 1;
                } else {
                    return 0;
                }
            }
        } else if (preventUpgrade && slotRarity > libAffx_rarityCommon && slotRarity != libAffx_rarityStarter) {
            slotRarity -= 1;
        } else {
            if (repeat > 0) {
                repeat -= 1;
            } else {
                return 0;
            }
        } 
    }

    return 0;
}

bool libAffx_ProcessQueueTimeElapsed_Func (bool testConds, bool runActions) {
    if (!runActions) {
        return true;
    }
    if (libAffx_processQueueTimeElapsed < 600) {
        libAffx_processQueueTimeElapsed += 0.0625;
    }
    return true;
}
void libAffx_ProcessQueueTimeElapsed_Init() {
    libAffx_ProcessQueueTimeElapsedTrigger = TriggerCreate("libAffx_ProcessQueueTimeElapsed_Func");
    TriggerAddEventTimePeriodic(libAffx_ProcessQueueTimeElapsedTrigger, 0.0625, c_timeGame);
}

void libAffx_ChooseAffixes(int rarity, bool curse, int level, bool preventUpgrade) {
    int slot;
    int rolledRarity;
    int totalRarity;
    int i;
    int run = libAffx_currentRun - 1;

    libAffx_processQueueTimeElapsed = 0;
    if (rarity == libAffx_rarityMythic) {
        if (run == 0) {
            libAffx_rolledAffixes[1] = libAffx_GetAffixId("Mythic1");
        } else if (run == 4) {
            libAffx_rolledAffixes[1] = libAffx_GetAffixId("Mythic2");
        } else if (run == 8) {
            libAffx_rolledAffixes[1] = libAffx_GetAffixId("Mythic3");
        } else if (run == 12) {
            libAffx_rolledAffixes[1] = libAffx_GetAffixId("Mythic4");
        } else if (run == 16) {
            libAffx_rolledAffixes[1] = libAffx_GetAffixId("Mythic5");
        } else if (run >= 20) {
            libAffx_rolledAffixes[1] = libAffx_GetAffixId("Mythic6");
        }
        SoundPlayOnUnit(SoundLink("UI_Game_LevelUp_Talent", -1), PlayerGroupSingle(1), libGame_gv_players[libAffx_player].lv_heroUnit, 8.0, 100.0, 0.0);
        libAffx_ShowAffixDialog(1);
        libAffx_Pause(true);
    } else {
        for (slot = 1; slot <= libAffx_affixSelectionMax; slot += 1) {
            libAffx_rolledAffixes[slot] = 0;
            if (preventUpgrade) {
                totalRarity += rarity;
                libAffx_rolledAffixes[slot] = libAffx_RollAffix(rarity, curse, level, preventUpgrade);
            } else {
                if (curse) { // Curses don't use rarities
                    rolledRarity = libAffx_rarityCommon;
                } else {
                    rolledRarity = libAffx_RollRarity(rarity, curse);
                }
                totalRarity += rolledRarity;
                libAffx_rolledAffixes[slot] = libAffx_RollAffix(rolledRarity, curse, level, preventUpgrade);
            }
        }
    
        libAffx_currentAffixRarity = CeilingI(totalRarity / libAffx_affixSelectionMax);
        libAffx_currentAffixCurse = curse;
        libAffx_currentAffixLevel = level;
        libAffx_currentAffixPreventUpgrade = preventUpgrade;
    
        if (libAffx_rolledAffixes[1] == 0 && libAffx_rolledAffixes[2] == 0 && libAffx_rolledAffixes[3] == 0) {
            libAffx_queueActive = false;
            libAffx_MoveQueue();
            libAffx_ProcessQueue();
        } else {
            SoundPlayOnUnit(SoundLink("UI_Game_LevelUp_Talent", -1), PlayerGroupSingle(1), libGame_gv_players[libAffx_player].lv_heroUnit, 8.0, 100.0, 0.0);
            libAffx_ShowAffixDialog(libAffx_affixSelectionMax);
            libAffx_Pause(true);
        }
    }
}

void libAffx_MoveQueue() {
    int i;
    for (i = 1; i <= libAffx_queueCount; i += 1) {
        libAffx_queueAffixRarity[i] = libAffx_queueAffixRarity[i + 1];
        libAffx_queueAffixCurse[i] = libAffx_queueAffixCurse[i + 1];
        libAffx_queueAffixLevel[i] = libAffx_queueAffixLevel[i + 1];
        libAffx_queueAffixPreventUpgrade[i] = libAffx_queueAffixPreventUpgrade[i + 1];
    }
    
    libAffx_queueCount = MaxI(0, libAffx_queueCount - 1);
}

void libAffx_ProcessQueue() {
    int i;
    if (libAffx_queueActive || libAffx_queueCount <= 0 || libGame_gv_gameOver) {
        return;
    }
    for (i = 1; i <= libAffx_registeredAffixes; i += 1) {
        libAffx_affixes[i].lastSeen = 0;
    }

    if (libAffx_objectivesWonCounter > 0 && libAffx_queueAffixCurse[1] && !libAffx_debugCommandsAddAll && libAffx_queueAffixRarity[1] != libAffx_rarityMythic) {
        libAffx_queueActive = true;
        libAffx_objectivesWonCounter -= 1;
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringExternal("Message/CurseSwap"));
        libAffx_ChooseAffixes(libAffx_rarityCommon, false, libAffx_queueAffixLevel[1], libAffx_queueAffixPreventUpgrade[1]);
        libAffx_MoveQueue();
    } else if (libAffx_skipCurseCounter > 0 && libAffx_queueAffixCurse[1] && !libAffx_debugCommandsAddAll && libAffx_queueAffixRarity[1] != libAffx_rarityMythic) {
        libAffx_queueActive = false;
        libAffx_skipCurseCounter -= 1;
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringExternal("Message/CurseSkipped"));
        libAffx_MoveQueue();
        libAffx_ProcessQueue();
    } else {
        libAffx_queueActive = true;
        libAffx_ChooseAffixes(libAffx_queueAffixRarity[1], libAffx_queueAffixCurse[1], libAffx_queueAffixLevel[1], libAffx_queueAffixPreventUpgrade[1]);
        libAffx_MoveQueue();
    }
}

void libAffx_QueueAffix2(int rarity, bool curse, int level, int amount, bool preventUpgrade, bool mythicCurse) {
    int i;
    if (amount > 0) {
        for (i = 1; i <= amount; i += 1) {
            if (libAffx_queueCount >= libAffx_queueMax || libAffx_debug_disableAffixQueue) {
                break;
            }
            libAffx_queueCount += 1;
            libAffx_queueAffixRarity[libAffx_queueCount] = rarity;
            libAffx_queueAffixCurse[libAffx_queueCount] = curse;
            libAffx_queueAffixLevel[libAffx_queueCount] = level;
            libAffx_queueAffixPreventUpgrade[libAffx_queueCount] = preventUpgrade;
        }
    }

    libAffx_ProcessQueue();
}

void libAffx_QueueAffix(int rarity, bool curse, int level, int amount, bool preventUpgrade) {
    libAffx_QueueAffix2(rarity, curse, level, amount, preventUpgrade, false);
}

void libAffx_QueueCurse(int amount) {
    libAffx_QueueAffix(libAffx_rarityCommon, true, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), amount, false);
}

void libAffx_AffixSelected(int selectionIndex) {
    int i;

    libAffx_lastSelected = selectionIndex;
    DialogSetVisible(libAffx_dialogAffixSelection, PlayerGroupAll(), false);
    libAffx_AddAffix(libAffx_rolledAffixes[selectionIndex], 1);
    if (!libAffx_showingOwnedAffixes) {
        libAffx_Pause(false);
    }
    libAffx_UpdateOwnedAffixes();
    libAffx_queueActive = false;
    libAffx_ProcessQueue();
}
bool libAffx_AffixHotkeyPressedTrigger_Func (bool testConds, bool runActions) {
    int hotkeyPressed;
    if (testConds) {
        if (!libAffx_queueActive){
            return false;
        }
        if (libAffx_processQueueTimeElapsed < 0.25) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    if (libAffx_rolledAffixes[EventKeyPressed() - 3] == 0) {
        return true;
    }

    libAffx_AffixSelected(EventKeyPressed() - 3);
    SoundPlayForPlayer(SoundLink("UI_Game_Click", -1), libAffx_player, PlayerGroupSingle(libAffx_player), 100.0, 0.0);

    return true;
}
void libAffx_AffixHotkeyPressedTrigger_Init() {
    libAffx_AffixHotkeyPressedTrigger = TriggerCreate("libAffx_AffixHotkeyPressedTrigger_Func");
    TriggerAddEventKeyPressed(libAffx_AffixHotkeyPressedTrigger, libAffx_player, c_key1, false, c_keyModifierStateIgnore, c_keyModifierStateRequire, c_keyModifierStateIgnore);
    TriggerAddEventKeyPressed(libAffx_AffixHotkeyPressedTrigger, libAffx_player, c_key2, false, c_keyModifierStateIgnore, c_keyModifierStateRequire, c_keyModifierStateIgnore);
    TriggerAddEventKeyPressed(libAffx_AffixHotkeyPressedTrigger, libAffx_player, c_key3, false, c_keyModifierStateIgnore, c_keyModifierStateRequire, c_keyModifierStateIgnore);
}
bool libAffx_AffixSelectedTrigger_Func (bool testConds, bool runActions) {
    int dialogButton;
    int selectedButton;
    bool testForButton;
    int i;

    if (testConds) {
        if (libAffx_processQueueTimeElapsed < 0.25) {
            return false;
        }
        testForButton = false;
        for (i = 1; i <= libAffx_affixSelectionMax; i += 1) {
            if (EventDialogControl() == libAffx_dialogAffixSelectionButton[i]) {
                testForButton = true;
            }
        }
        if (!testForButton || !libAffx_queueActive){
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    dialogButton = EventDialogControl();

    for (i = 1; i <= libAffx_affixSelectionMax; i += 1) {
        if (dialogButton == libAffx_dialogAffixSelectionButton[i]) {
            selectedButton = i;
        }
    }
    if (libAffx_rolledAffixes[selectedButton] == 0) {
        return true;
    }

    libAffx_AffixSelected(selectedButton);

    return true;
}
void libAffx_AffixSelectedTrigger_Init() {
    libAffx_AffixSelectedTrigger = TriggerCreate("libAffx_AffixSelectedTrigger_Func");
    TriggerAddEventDialogControl(libAffx_AffixSelectedTrigger, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}
bool libAffx_AffixRerollTrigger_Func (bool testConds, bool runActions) {
    int dialogButton;

    dialogButton = EventDialogControl();
    if (testConds) {
        if (dialogButton != libAffx_dialogAffixReroll){
            return false;
        }
        if (libAffx_rerolls <= 0 && !libAffx_currentAffixCurse) {
            return false;
        }
        if (libAffx_rerollsCurse <= 0 && libAffx_currentAffixCurse) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    if (libAffx_currentAffixCurse) {
        libAffx_rerollsCurse -= 1;
        libAffx_ChooseAffixes(libAffx_currentAffixRarity, libAffx_currentAffixCurse, libAffx_currentAffixLevel, libAffx_currentAffixPreventUpgrade);
    } else {
        libAffx_rerolls -= 1;
        libAffx_ChooseAffixes(libAffx_currentAffixRarity, libAffx_currentAffixCurse, libAffx_currentAffixLevel, libAffx_currentAffixPreventUpgrade);
    }

    return true;
}
void libAffx_AffixRerollTrigger_Init() {
    libAffx_AffixRerollTrigger = TriggerCreate("libAffx_AffixRerollTrigger_Func");
    TriggerAddEventDialogControl(libAffx_AffixRerollTrigger, c_playerAny, c_invalidDialogControlId, c_triggerControlEventTypeClick);
}

bool libAffx_ObjectiveWonTrigger_Func (bool testConds, bool runActions) {
    if (testConds) {
        if (libAffx_objectivesWon >= libAffx_maxAffixesFromObjectives) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_objectivesWon += 1;
    libAffx_objectivesWonCounter += 1;
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringExternal("Message/CurseToBoon"));

    return true;
}
void libAffx_ObjectiveWonTrigger_Init() {
    libAffx_ObjectiveWonTrigger = TriggerCreate("libAffx_ObjectiveWonTrigger_Func");
    TriggerAddEventGeneric(libAffx_ObjectiveWonTrigger, "AffixObjectiveWon");
}

bool libAffx_ResetCommandTrigger_Func (bool testConds, bool runActions) {

    // Conditions
    if (testConds) {
        if (StringWord(EventChatMessage(false), 1) != "resetgame") {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    libAffx_Print("Resetting...");
    libAffx_BankReset();
    GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorialveteran.stormmap");
    KickFromGame(PlayerGroupAll());

    return true;
}
void libAffx_ResetCommandTrigger_Init () {
    libAffx_ResetCommandTrigger = TriggerCreate("libAffx_ResetCommandTrigger_Func");
    TriggerAddEventChatMessage(libAffx_ResetCommandTrigger, c_playerAny, "resetgame", false);
}

bool libAffx_TestCommandTrigger_Func (bool testConds, bool runActions) {
    int i;
    int i2;
    int affix;
    int affixes;
    int affixesNegative;
    int arg1;
    if (testConds) {
        if (!libAffx_debug_enableCheatCommands) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }

    if (StringWord(EventChatMessage(false), 1) == "test") {
        libAffx_Print("Player: " + libCore_gf_GetHeroFromIndex(libGame_gv_players[libAffx_player].lv_heroIndex));
        for (i = 1; i <= libAffx_rarityStarter; i += 1) {
            affixes = 0;
            affixesNegative = 0;
            for (i2 = 1; i2 <= libAffx_registeredAffixes; i2 += 1) {
                if (libAffx_affixes[i2].rarity == i && libAffx_affixes[i2].enabled) {
                    if (!libAffx_affixes[i2].curse) {
                        affixes += 1;
                    } else {
                        affixesNegative += 1;
                    }
                }
            }
            libAffx_Print(libAffx_GetRarityString(i) + " affixes: " + IntToString(affixes) + " positives and " + IntToString(affixesNegative) + " negatives");
        }
    } else if (StringWord(EventChatMessage(false), 1) == "afxaddall") {
        affixes = 0;
        arg1 = 1;
        if (StringWord(EventChatMessage(false), 2) != null) {
            arg1 = StringToInt(StringWord(EventChatMessage(false), 2));
        }
        libAffx_debugCommandsAddAll = true;
        for (i = 1; i <= libAffx_registeredAffixes; i += 1) {
            if (libAffx_affixes[i].enabled && libAffx_affixes[i].allowedHero[libAffx_playersHeroIndex[libAffx_player]] && ((libAffx_affixes[i].max > 0 && libAffx_affixes[i].count <= libAffx_affixes[i].max) || (libAffx_affixes[i].max <= 0))) {
                if (libAffx_affixes[i].max <= 0) {
                    affixes += arg1;
                    libAffx_AddAffix(i, arg1);
                } else if (libAffx_affixes[i].count < libAffx_affixes[i].max) {
                    affixes += libAffx_affixes[i].max - libAffx_affixes[i].count;
                    libAffx_AddAffix(i, libAffx_affixes[i].max - libAffx_affixes[i].count);
                }
            }
        }
        libAffx_debugCommandsAddAll = false;
        libAffx_UpdateOwnedAffixes();
        libAffx_Print("Added a total of " + IntToString(affixes) + " affixes!");
    } else if (StringWord(EventChatMessage(false), 1) == "nextmap") {
        libAffx_Print("Loading next map...");
        if (libAffx_GetMapID(libCore_gv_mAPMapStringID) == libAffx_mapCursedHollow) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorialmapmechanics.stormmap");
            libAffx_nextMap = "Shrines";
        } else if (libAffx_GetMapID(libCore_gv_mAPMapStringID) == libAffx_mapShrines) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorial01.stormmap");
            libAffx_nextMap = "Crypts";
        } else if (libAffx_GetMapID(libCore_gv_mAPMapStringID) == libAffx_mapCrypts) {
            GameSetNextMap("heroes/singleplayermaps/(10)trymemode.stormmap");
            libAffx_nextMap = "DragonShire";
        } else if (libAffx_GetMapID(libCore_gv_mAPMapStringID) == libAffx_mapDragonShire) {
            GameSetNextMap("heroes/singleplayermaps/startingexperience/tutorialveteran.stormmap");
            libAffx_nextMap = "CursedHollow";
        }
        libAffx_BankSave();
        Wait(1, c_timeGame);
        KickFromGame(PlayerGroupAll());
    } else if (StringWord(EventChatMessage(false), 1) == "rerolls") {
        libAffx_Print("Adding rerolls!");
        libAffx_rerolls += 99;
        libAffx_rerollsCurse += 99;
    } else if (StringWord(EventChatMessage(false), 1) == "forceunpause") {
        libAffx_Print("Forced unpause!");
        libAffx_Pause(false);
    } else if (StringWord(EventChatMessage(false), 1) == "testmap") {
        GameSetNextMap(StringWord(EventChatMessage(false), 2));
        KickFromGame(PlayerGroupAll());
    } else if (StringWord(EventChatMessage(false), 1) == "camera") {
        CameraSetValue(libAffx_player, StringToInt(StringWord(EventChatMessage(false), 2)), StringToFixed(StringWord(EventChatMessage(false), 3)), StringToFixed(StringWord(EventChatMessage(false), 4)), -1, 10);
    } else if (StringWord(EventChatMessage(false), 1) == "cooldown" || StringWord(EventChatMessage(false), 1) == "cd") {
        if (StringWord(EventChatMessage(false), 2) == "") {
            libAffx_Print("Usage: cooldown <affix> (value)");
        } else {
            affix = libAffx_GetAffixId(StringWord(EventChatMessage(false), 2));
            if (affix == 0) {
                libAffx_Print("Affix " + StringWord(EventChatMessage(false), 2) + " not found.");
            } else if (StringWord(EventChatMessage(false), 3) == "") {
                libAffx_affixes[affix].cooldown = 0;
            } else {
                libAffx_affixes[affix].cooldown = StringToFixed(StringWord(EventChatMessage(false), 3));
            }
        }
    } else if (StringWord(EventChatMessage(false), 1) == "curse") {
        if (StringWord(EventChatMessage(false), 2) == "") {
            libAffx_Print("Usage: curse <team>");
        } else {
            libMapM_gf_MMRavenTributeCollectionThresholdReached(StringToInt(StringWord(EventChatMessage(false), 2)));
        }
    } else if (StringWord(EventChatMessage(false), 1) == "printallheroes") {
        for (i = 1; i <= 10; i += 1) {
            libAffx_Print("Player " + IntToString(i) + ": " + libCore_gf_GetHeroFromIndex(libGame_gv_players[i].lv_heroIndex));
        }
    }
    return true;
}
void libAffx_TestCommandTrigger_Init () {
    libAffx_TestCommandTrigger = TriggerCreate("libAffx_TestCommandTrigger_Func");
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "test", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "testmap", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "afxaddall", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "nextmap", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "rerolls", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "forceunpause", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "camera", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "cooldown", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "cd", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "curse", false);
    TriggerAddEventChatMessage(libAffx_TestCommandTrigger, c_playerAny, "printallheroes", false);
}

bool libAffx_QueueAffixCommandTrigger_Func (bool testConds, bool runActions) {
    int rarity;
    int amount;
    int affix;

    if (testConds) {
        if (StringWord(EventChatMessage(false), 1) != "afxq" && StringWord(EventChatMessage(false), 1) != "afxqueue" && StringWord(EventChatMessage(false), 1) != "afxadd" && StringWord(EventChatMessage(false), 1) != "afx") {
            return false;
        }
        if (!libAffx_debug_enableCheatCommands) {
            return false;
        }
    }

    if (!runActions) {
        return true;
    }
    if (StringWord(EventChatMessage(false), 1) == "afxq" || StringWord(EventChatMessage(false), 1) == "afxqueue") {
        rarity = libAffx_rarityCommon;
        amount = 1;
        if (StringWord(EventChatMessage(false), 4) != null) {
            amount = StringToInt(StringWord(EventChatMessage(false), 4));
        }

        if ((StringWord(EventChatMessage(false), 1) == null)) {
            libAffx_Print("Usage: <afxq/afxqueue> [curse] [rarity] [amount]");
        }
        else {
            if ((StringWord(EventChatMessage(false), 3) != null)) {
                rarity = StringToInt(StringWord(EventChatMessage(false), 3));
            }
            if ((StringWord(EventChatMessage(false), 2) != null)) {
                if (StringWord(EventChatMessage(false), 2) == "true" || StringWord(EventChatMessage(false), 2) == "1") {
                    libAffx_QueueAffix(MaxI(rarity, libAffx_rarityCommon), true, UnitLevel(libGame_gv_players[libAffx_enemy].lv_heroUnit), amount, false);
                } else {
                    libAffx_QueueAffix(MaxI(rarity, libAffx_rarityCommon), false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), amount, false);
                }
            } else {
                libAffx_QueueAffix(MaxI(rarity, libAffx_rarityCommon), false, UnitLevel(libGame_gv_players[libAffx_player].lv_heroUnit), amount, false);
            }
        }
    } else if (StringWord(EventChatMessage(false), 1) == "afx" || StringWord(EventChatMessage(false), 1) == "afxadd") {
        amount = 1;
        if ((StringWord(EventChatMessage(false), 2) == null)) {
            libAffx_Print("Usage: <afx/afxadd> <affix name> [amount]");
        } else {
            if (StringWord(EventChatMessage(false), 3) != null) {
                amount = StringToInt(StringWord(EventChatMessage(false), 3));
            }
            affix = libAffx_GetAffixId(StringWord(EventChatMessage(false), 2));
            if (affix == 0) {
                libAffx_Print("Could not find affix by the name " + StringWord(EventChatMessage(false), 2));
            } else {
                libAffx_AddAffix(affix, amount);
                libAffx_Print("Added affix: " + libAffx_affixes[affix].name);
            }
        }
    }
    return true;
}
void libAffx_QueueAffixCommandTrigger_Init () {
    libAffx_QueueAffixCommandTrigger = TriggerCreate("libAffx_QueueAffixCommandTrigger_Func");
    TriggerAddEventChatMessage(libAffx_QueueAffixCommandTrigger, c_playerAny, "afxqueue", false);
    TriggerAddEventChatMessage(libAffx_QueueAffixCommandTrigger, c_playerAny, "afxq", false);
    TriggerAddEventChatMessage(libAffx_QueueAffixCommandTrigger, c_playerAny, "afxadd", false);
    TriggerAddEventChatMessage(libAffx_QueueAffixCommandTrigger, c_playerAny, "afx", false);
}

bool libAffx_DifficultyUnitCreated_Func (bool testConds, bool runActions) {
    if (testConds) {
        if (libAffx_difficulty <= 2) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_AddBehaviorFilter(EventUnitCreatedUnit(), "AffixDifficultyBuff", libCore_gv_filtersEnemy, 0, "", 1);
    return true;
}
bool libAffx_DifficultyUnitChangeOwner_Func (bool testConds, bool runActions) {
    if (testConds) {
        if (libAffx_difficulty <= 2) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_AddAndRemoveBehaviorFilter(EventUnit(), "AffixDifficultyBuff", libCore_gv_filtersEnemy, 0, "", 1);
    return true;
}
void libAffx_Difficulty_Init() {
    libAffx_DifficultyUnitCreatedTrigger = TriggerCreate("libAffx_DifficultyUnitCreated_Func");
    libAffx_DifficultyUnitChangeOwner = TriggerCreate("libAffx_DifficultyUnitChangeOwner_Func");
    TriggerAddEventUnitCreated(libAffx_DifficultyUnitCreatedTrigger, null, null, null);
    TriggerAddEventUnitChangeOwner(libAffx_DifficultyUnitChangeOwner, null);
}

void libAffx_ApplyDifficulty () {
    fixed modifier;
    fixed scaledModifier;
    int i;

    if (libAffx_difficulty == 3) {
        modifier = 0.04;
        libAffx_difficultyXPMod = 0.01 * libAffx_currentRun;
        libGame_teamChaosXPMod += libAffx_difficultyXPMod;
        scaledModifier = (modifier + 0.01 * libAffx_currentRun) * libAffx_currentRun;
        libAffx_SetAffix(libAffx_GetAffixId("DifficultyHard"), libAffx_currentRun);
    } else if (libAffx_difficulty == 2) {
        modifier = 0.04;
        scaledModifier = Pow((1 + modifier), libAffx_currentRun) - 1;
        libAffx_SetAffix(libAffx_GetAffixId("DifficultyNormal"), libAffx_currentRun);
    } else {
        modifier = 0;
        libAffx_SetAffix(libAffx_GetAffixId("DifficultyEasy"), 1);
    }
    if (scaledModifier < 0) {
        scaledModifier = 0;
    }
    libAffx_CatalogModifyForAllPlayers("Behavior,AffixDifficultyBuff,Modification.DamageDealtFraction[Ability]", FixedToString(scaledModifier, c_fixedPrecisionAny));
    libAffx_CatalogModifyForAllPlayers("Behavior,AffixDifficultyBuff,Modification.DamageDealtFraction[Basic]", FixedToString(scaledModifier, c_fixedPrecisionAny));
    libAffx_CatalogModifyForAllPlayers("Behavior,AffixDifficultyBuff,Modification.VitalMaxFractionArray[Life]", FixedToString(scaledModifier, c_fixedPrecisionAny));
    libAffx_CatalogModifyForAllPlayers("Behavior,AffixDifficultyBuff,Modification.VitalRegenMultiplier[Life]", FixedToString(scaledModifier, c_fixedPrecisionAny));
    for (i = 6; i <= 10; i += 1) {
        if (!UnitHasBehavior2(libGame_gv_players[i].lv_heroUnit, "NotManaUserDummy")) {
            libAffx_CatalogReferenceModify("Behavior,AffixDifficultyBuff,Modification.VitalMaxFractionArray[Energy]", i, FixedToString(scaledModifier, c_fixedPrecisionAny));
            libAffx_CatalogReferenceModify("Behavior,AffixDifficultyBuff,Modification.VitalRegenMultiplier[Energy]", i, FixedToString(scaledModifier, c_fixedPrecisionAny));
        } else {
            libAffx_CatalogReferenceModify("Behavior,AffixDifficultyBuff,Modification.VitalMaxFractionArray[Energy]", i, "0");
            libAffx_CatalogReferenceModify("Behavior,AffixDifficultyBuff,Modification.VitalRegenMultiplier[Energy]", i, "0");
        }
        libAffx_AddBehavior(i, "AffixDifficultyBuff", 1, true);
    }
    if (libAffx_difficulty == 3) {
        libAffx_AddBehaviorAllUnitsFilter("AffixDifficultyBuff", libCore_gv_filtersEnemy, 0, "", 1);
    }
    
}

bool libAffx_LevelUpTrigger_Func (bool testConds, bool runActions) {
    int player = libGame_gf_HeroLevelUpPlayer();
    int level = libGame_gf_HeroLevelUpLevel();
    if (!runActions) {
        return true;
    }
    if (player == libAffx_player) {
        if (level == 1) {
            libAffx_Wait(libAffx_gameStartDelay, c_timeGame);
            if ((libAffx_currentRun - 1) % 4 == 0 && libAffx_difficulty == 3) {
                libAffx_QueueAffix2(libAffx_rarityMythic, true, level, 1, true, true);
            }
            if (libAffx_currentRun <= 1) {
                libAffx_QueueAffix(libAffx_rarityStarter, false, level, 1, false);
            } else {
                if ((libAffx_currentRun - 1) % 4 == 0) {
                    libAffx_QueueAffix(libAffx_rarityLegendary, false, level, 1, false);
                } else {
                    libAffx_QueueAffix(libAffx_rarityRare, false, level, 1, false);
                }
            }
        } else if (level == 4) {
            libAffx_QueueAffix(libAffx_rarityCommon, false, level, 1, false);
        } else if (level == 7) {
            libAffx_QueueAffix(libAffx_rarityCommon, false, level, 1, false);
        } else if (level == 10) {
            libAffx_QueueAffix(libAffx_rarityCommon, false, level, libAffx_boonsLevel10, false);
        }
        libAffx_startingBoonsQueued = true;
    }
    if (player == libAffx_enemy) {
        if (level == 1) {
            libAffx_Wait(libAffx_gameStartDelay, c_timeGame);
            while (!libAffx_startingBoonsQueued) {
                libAffx_Wait(0.0625, c_timeGame);
            }
            if (libAffx_difficulty == 3) {
                libAffx_ApplyDifficulty();
                //libAffx_QueueAffix(libAffx_rarityCommon, true, level, 1, false);
            } else if (libAffx_difficulty == 2) {
                libAffx_ApplyDifficulty();
            } else {
            }
            libAffx_QueueAffix(libAffx_rarityCommon, true, level, libAffx_cursesLevel1, false);
            if (libAffx_cursesQueued > 0) {
                if (libAffx_cursesQueued >= 2) {
                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringExternal("Message/CurseNextGame2"));
                } else if (libAffx_cursesQueued == 1) {
                    UIDisplayMessage(PlayerGroupAll(), c_messageAreaChat, StringExternal("Message/CurseNextGame1"));
                }
                libAffx_QueueAffix(libAffx_rarityCommon, true, level, libAffx_cursesQueued, false);
                libAffx_cursesQueued = 0;
            }
        } else {
            while (!libAffx_startingBoonsQueued) {
                libAffx_Wait(0.0625, c_timeGame);
            }
            if (level == 4) {
                libAffx_QueueAffix(libAffx_rarityCommon, true, level, 1, false);
                libAffx_cursesNextGame -= 1;
            } else if (level == 7) {
                libAffx_QueueAffix(libAffx_rarityCommon, true, level, 1, false);
                libAffx_cursesNextGame -= 1;
            } else if (level == 10) {
                libAffx_QueueAffix(libAffx_rarityCommon, true, level, 1, false);
            } else if (level == 13) {
                libAffx_QueueAffix(libAffx_rarityUncommon, true, level, 1, false);
            } else if (level == 16) {
                libAffx_QueueAffix(libAffx_rarityUncommon, true, level, 1, false);
            } else if (level == 20) {
                libAffx_QueueAffix(libAffx_rarityRare, true, level, 1, false);
            } else if (level == 24) {
                libAffx_QueueAffix(libAffx_rarityRare, true, level, 1, false);
            } else if (level == 27) {
                libAffx_QueueAffix(libAffx_rarityRare, true, level, 1, false);
            } else if (level == 30) {
                libAffx_QueueAffix(libAffx_rarityEpic, true, level, 1, false);
            }
        }
    }
    return true;
}
void libAffx_LevelUpTrigger_Init () {
    libAffx_LevelUpTrigger = TriggerCreate("libAffx_LevelUpTrigger_Func");
    libGame_gf_HeroLevelUp(libAffx_LevelUpTrigger);
}
