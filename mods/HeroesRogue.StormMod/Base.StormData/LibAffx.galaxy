    libGame_gf_HeroGainTalent(libAffx_TalentGainedTrigger);
}
//--------------------------------------------------------------------------------------------------
// D.va fixes
//--------------------------------------------------------------------------------------------------
void libAffx_SyncBehaviors(unit sourceUnit, unit targetUnit) {
    int i;
    int player = UnitGetOwner(sourceUnit); 
    int totalBehaviors = UnitBehaviorCountAll(sourceUnit);
    string behavior;
    int behaviorStacks;
    fixed behaviorDuration;
    string debug_behaviors;

    Wait(0.0625, c_timeGame);
    for (i = 1; i <= libAffx_behaviorMax; i += 1) {
        behavior = libAffx_affixBehaviors[player][i];
        if (behavior == "") { break; }
        behaviorStacks = UnitBehaviorCount(sourceUnit, behavior);
        if (behaviorStacks <= 0) { behaviorStacks = 1; }
        behaviorDuration = UnitBehaviorDuration(sourceUnit, behavior);
        UnitModifyCooldown(targetUnit, "Abil/" + behavior, UnitGetCooldown(sourceUnit, "Abil/" + behavior), c_cooldownOperationSet);
        if (UnitHasBehavior2(targetUnit, behavior) && UnitBehaviorCount(targetUnit, behavior) == UnitBehaviorCount(sourceUnit, behavior)) {
            continue;
        }
        libAffx_DebugPrint("Adding behavior " + behavior + " with " + IntToString(behaviorStacks) + " stacks and duration " + FixedToString(behaviorDuration, 2) + " to unit " + UnitGetType(targetUnit) + " for player " + IntToString(player));
        UnitBehaviorAdd(targetUnit, behavior, sourceUnit, behaviorStacks);
        UnitBehaviorSetDuration(targetUnit, behavior, behaviorDuration);
    }
}

bool libAffx_DVaRespawnTrigger_Func (bool testConds, bool runActions) {
    int player = libGame_gf_HeroRespawnPlayer();
    unit respawnUnit = libGame_gf_HeroRespawnUnit();
    if (testConds) {
        if (libAffx_playersHeroIndex[player] != libCore_gf_GetIndexFromHero("DVa")) {
            return false;
        }
    }
    if (!runActions) {
        return true;
    }
    libAffx_SyncBehaviors(respawnUnit, libAffx_GetDVaMech(player));
    return true;
}

bool libAffx_DVaCallMechCompletedTrigger_Func (bool testConds, bool runActions) {
    unit dvaPilot = EventUnit();
    int dvaPlayer = UnitGetOwner(dvaPilot);

    if (!runActions) {
        return true;
    }

    libAffx_SyncBehaviors(dvaPilot, libHDVA_gv_dVaCallMechMechBeingSummoned[dvaPlayer]);
    
    return true;
}
bool libAffx_DVaEjectTrigger_Func (bool testConds, bool runActions) {
    unit dvaPilot = EventPlayerEffectUsedUnit(c_effectUnitTarget);
    unit dvaMech = EventPlayerEffectUsedUnit(c_effectUnitCaster);
    int dvaPlayer = UnitGetOwner(dvaPilot);
    if (!runActions) {
        return true;
    }
    libAffx_SyncBehaviors(dvaMech, dvaPilot);
    return true;
}
//--------------------------------------------------------------------------------------------------
void libAffx_DVaTriggers_Init () {
    libAffx_DVaCallMechCompletedTrigger = TriggerCreate("libAffx_DVaCallMechCompletedTrigger_Func");
    libAffx_DVaRespawnTrigger = TriggerCreate("libAffx_DVaRespawnTrigger_Func");
    libAffx_DVaEjectTrigger = TriggerCreate("libAffx_DVaEjectTrigger_Func");
    TriggerAddEventUnitAbility(libAffx_DVaCallMechCompletedTrigger, null, AbilityCommand("DVaPilotCallMech", 0), c_abilEffectStageFinish, false);
    TriggerAddEventGeneric(libAffx_DVaRespawnTrigger, libGame_gv_eventID_HeroRespawn_C);
    TriggerAddEventPlayerEffectUsed(libAffx_DVaEjectTrigger, c_playerAny, "DVaMechPilotUnloadSet");
}

void libAffx_Wait(fixed duration, int inTimeType) {
    fixed elapsed = 0.0;
    while (elapsed < duration) {
        if (libAffx_gamePaused) {
            Wait(0.0625, inTimeType);
        } else {
            Wait(0.0625, inTimeType);
            elapsed += 0.0625;
        }
    }
}

bool libAffx_GateIsOpen() {
    if (TimerGetElapsed(libGame_gv_openTheGatesTimer) > 0.0 && TimerGetRemaining(libGame_gv_openTheGatesTimer) <= 0.0) {
        return true;
    }
    return false;
}

bool libAffx_IsMinion(unit unitVar) {
    if (UnitGetType(unitVar) == "FootmanMinion" || UnitGetType(unitVar) == "RangedMinion" || UnitBehaviorCount(unitVar, "IsCatapultMinionOrCatapultReplacement") > 0 || UnitGetType(unitVar) == "WizardMinion") {
        return true;
    } else {
        return false;
    }
}

//---------------------------------------------------------------------------------------------------------
// Pause function
//---------------------------------------------------------------------------------------------------------

void libAffx_Pause(bool pause) {
    int i;

    if (libGame_gv_gameOver || libAffx_debug_ignoreMap) {
        return;
    }

    if (pause && !libAffx_gamePaused) {
        libAffx_gamePaused = true;
        libNtve_gf_MakeUnitUncommandable(libGame_gv_players[libAffx_player].lv_heroUnit, true);
        libStEx_gf_FreezeUnfreezeAllUnits(0); // Freeze units
        GameSetGlobalTimeScale(0);
        SetTalentsEnabled(false); // Disable talents
        if (TimerGetRemaining(libGame_gv_openTheGatesTimer) > 0.0) {
            TimerPause(libGame_gv_openTheGatesTimer, true);
        } else if (TimerGetElapsed(libGame_gv_openTheGatesTimer) > 0.0 && TimerGetRemaining(libGame_gv_openTheGatesTimer) <= 0.0) {
            libGame_paused = true;
            //TriggerEnable(libGame_gt_XPTrickle, false);
            TriggerEnable(libGame_gt_CapturePointLogic, false); // Capture for watch towers, mercs
        }
        if (TimerGetRemaining(libGame_gv_scalingTimer) > 0.0) {
            TimerPause(libGame_gv_scalingTimer, true); // Minion scaling
        }
        for (i = 1; i <= libMapM_gv_jungleNumberOfCreepCamps; i += 1) { // Mercenaries
            if (TimerGetRemaining(libMapM_gv_jungleCreepCamps[i].lv_stateCreepBirthTimer) > 0.0) {
                TimerPause(libMapM_gv_jungleCreepCamps[i].lv_stateCreepBirthTimer, true);
            }
            if (TimerGetRemaining(libMapM_gv_jungleCreepCamps[i].lv_stateCreepRespawnTimer) > 0.0) {
                TimerPause(libMapM_gv_jungleCreepCamps[i].lv_stateCreepRespawnTimer, true);
            }
        }
        for (i = 1; i <= libCore_gv_bALMaxPlayers; i += 1) {
            if (TimerGetRemaining(libGame_gv_players[i].lv_respawnTimer) > 0.0) { // Respawn timer
                TimerPause(libGame_gv_players[i].lv_respawnTimer, true);
            }
            if (TimerGetRemaining(libGame_gv_players[i].lv_respawnSoundCueTimer) > 0.0) {
                TimerPause(libGame_gv_players[i].lv_respawnSoundCueTimer, true);
            }
            if (TimerGetRemaining(libGame_gv_players[i].lv_multikillTimer) > 0.0) {
                TimerPause(libGame_gv_players[i].lv_multikillTimer, true);
            }
        }
        // Pause map specific stuff
        if (libCore_gv_mAPMapStringID == "Volskaya" && libAffx_pauseVLSK != null) {
            TriggerExecute(libAffx_pauseVLSK, false, false);
        } else if (libCore_gv_mAPMapStringID == "CursedHollow") {
            libMapM_gf_PauseUnpauseCurseHollowTimers(true);
        } else if (libCore_gv_mAPMapStringID == "Shrines" && libAffx_pauseMSHE != null) {
            TriggerExecute(libAffx_pauseMSHE, false, false);
        } else if (libCore_gv_mAPMapStringID == "Crypts" && libAffx_pauseMSOC != null) {
            TriggerExecute(libAffx_pauseMSOC, false, false);
        } else if (libCore_gv_mAPMapStringID == "DragonShire") {
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonTowerStartTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonTowerStartTimer, true);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonTowerRespawnTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonTowerRespawnTimer, true);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonTowerWarningTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonTowerWarningTimer, true);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonStatueActiveReminderTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonStatueActiveReminderTimer, true);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonTowerGoalActivationTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonTowerGoalActivationTimer, true);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonKnightLifeTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonKnightLifeTimer, true);
            }
        }
    } else if (!pause && libAffx_gamePaused) {
        libAffx_gamePaused = false;

        libStEx_gf_FreezeUnfreezeAllUnits(1);
        libNtve_gf_MakeUnitUncommandable(libGame_gv_players[libAffx_player].lv_heroUnit, false);
        GameSetGlobalTimeScale(1);
        SetTalentsEnabled(true);

        if (TimerGetRemaining(libGame_gv_openTheGatesTimer) > 0.0) {
            TimerPause(libGame_gv_openTheGatesTimer, false);
        } else if (TimerGetElapsed(libGame_gv_openTheGatesTimer) > 0.0 && TimerGetRemaining(libGame_gv_openTheGatesTimer) <= 0.0) {
            libGame_paused = false;
            //TriggerEnable(libGame_gt_XPTrickle, true); 
            TriggerEnable(libGame_gt_CapturePointLogic, true); 
        }
        if (TimerGetRemaining(libGame_gv_scalingTimer) > 0.0) {
            TimerPause(libGame_gv_scalingTimer, false);
        }

        for (i = 1; i <= libMapM_gv_jungleNumberOfCreepCamps; i += 1) {
            if (TimerGetRemaining(libMapM_gv_jungleCreepCamps[i].lv_stateCreepBirthTimer) > 0.0) {
                TimerPause(libMapM_gv_jungleCreepCamps[i].lv_stateCreepBirthTimer, false);
            }
            if (TimerGetRemaining(libMapM_gv_jungleCreepCamps[i].lv_stateCreepRespawnTimer) > 0.0) {
                TimerPause(libMapM_gv_jungleCreepCamps[i].lv_stateCreepRespawnTimer, false);
            }
        }

        if (libCore_gv_mAPMapStringID == "Volskaya" && libAffx_pauseVLSK != null) {
            TriggerExecute(libAffx_pauseVLSK, false, false);
        } else if (libCore_gv_mAPMapStringID == "CursedHollow") {
            libMapM_gf_PauseUnpauseCurseHollowTimers(false);
        } else if (libCore_gv_mAPMapStringID == "Shrines" && libAffx_pauseMSHE != null) {
            TriggerExecute(libAffx_pauseMSHE, false, false);
        } else if (libCore_gv_mAPMapStringID == "Crypts" && libAffx_pauseMSOC != null) {
            TriggerExecute(libAffx_pauseMSOC, false, false);
        } else if (libCore_gv_mAPMapStringID == "DragonShire") {
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonTowerStartTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonTowerStartTimer, false);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonTowerRespawnTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonTowerRespawnTimer, false);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonTowerWarningTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonTowerWarningTimer, false);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonStatueActiveReminderTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonStatueActiveReminderTimer, false);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonTowerGoalActivationTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonTowerGoalActivationTimer, false);
            }
            if (TimerGetRemaining(libMapM_gv_mMGardensDragonDragonKnightLifeTimer) > 0.0) {
                TimerPause(libMapM_gv_mMGardensDragonDragonKnightLifeTimer, false);
            }
        }
        for (i = 1; i <= libCore_gv_bALMaxPlayers; i += 1) {
            if (TimerGetRemaining(libGame_gv_players[i].lv_respawnTimer) > 0.0) {
                TimerPause(libGame_gv_players[i].lv_respawnTimer, false);
            }
            if (TimerGetRemaining(libGame_gv_players[i].lv_respawnSoundCueTimer) > 0.0) {
                TimerPause(libGame_gv_players[i].lv_respawnSoundCueTimer, false);
            }
            if (TimerGetRemaining(libGame_gv_players[i].lv_multikillTimer) > 0.0) {
                TimerPause(libGame_gv_players[i].lv_multikillTimer, false);
            }
        }
    }
}

string libAffx_GetAffixLabel(int affix) {
    if (libAffx_affixes[affix].rarity == libAffx_rarityMythic && libAffx_affixes[affix].mythicCurse) {
        return "Label/Name/RarityCurseMythic";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityMythic && !libAffx_affixes[affix].mythicCurse) {
        return "Label/Name/RarityMythic";
    } else if (libAffx_affixes[affix].curse) {
        return "Label/Name/RarityCurse";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityCommon) {
        return "Label/Name/RarityCommon";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityUncommon) {
        return "Label/Name/RarityUncommon";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityRare) {
        return "Label/Name/RarityRare";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityEpic) {
        return "Label/Name/RarityEpic";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityLegendary) {
        return "Label/Name/RarityLegendary";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityStarter) {
        return "Label/Name/RarityStarter";
    }
    return "Label/Name/AffixNone";
}
string libAffx_GetAffixLabelSuffix(int affix) {
    if (libAffx_affixes[affix].mythicCurse) {
        return "Label/Name/RaritySuffixNone";
    } else if (libAffx_affixes[affix].max > 1) {
        return "Label/Name/RaritySuffixStackable";
    } else if (libAffx_affixes[affix].max <= 0) {
        return "Label/Name/RaritySuffixInfinite";
    }
    return "Label/Name/RaritySuffixNone";
}

color libAffx_GetAffixColor(int affix) {
    if (libAffx_affixes[affix].rarity == libAffx_rarityMythic && libAffx_affixes[affix].mythicCurse) {
        return Color(66, 29, 53);
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityMythic && !libAffx_affixes[affix].mythicCurse) {
        return Color(0, 100, 100);
    } else if (libAffx_affixes[affix].curse) {
        return Color(77, 12, 12);
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityCommon) {
        return Color(100, 100, 100);
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityUncommon) {
        return Color(12, 100, 0);
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityRare) {
        return Color(0, 44, 87);
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityEpic) {
        return Color(64, 21, 93);
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityLegendary) {
        return Color(100, 50, 0);
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityStarter) {
        return Color(90, 80, 50);
    }
    return Color(100, 100, 100);
}

string libAffx_GetAffixSuffix(int affix) {
    if (libAffx_affixes[affix].rarity == libAffx_rarityMythic && libAffx_affixes[affix].mythicCurse) {
        return "_curse_mythic";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityMythic && !libAffx_affixes[affix].mythicCurse) {
        return "_mythic";
    } else if (libAffx_affixes[affix].curse) {
        return "_curse";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityCommon) {
        return "_common";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityUncommon) {
        return "_uncommon";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityRare) {
        return "_rare";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityEpic) {
        return "_epic";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityLegendary) {
        return "_legendary";
    } else if (libAffx_affixes[affix].rarity == libAffx_rarityStarter) {
        return "_starter";
    }
    return "";
}
string libAffx_CountToString(int count, int maxCount) {
    if (count > 0 && maxCount > 1) {
        return " (" + IntToString(count) + "/" + IntToString(maxCount) + ")";
    } else if (count > 0 && maxCount != 1) {
        return " (" + IntToString(count) + ")";
    }
    return "";
}
int libAffx_GetMapID(string mapString) {
    string map = StringCase(mapString, false);
    if (map == "volskaya") {
        return libAffx_mapVolskaya;
    } else if (map == "cursedhollow") {
        return libAffx_mapCursedHollow;
    } else if (map == "shrines") {
        return libAffx_mapShrines;
    } else if (map == "crypts") {
        return libAffx_mapCrypts;
    } else if (map == "dragonshire") {
        return libAffx_mapDragonShire;
    }
    return 0;
}
string libAffx_GetMapString(int map) {
    if (map == libAffx_mapVolskaya) {
        return "Volskaya";
    } else if (map == libAffx_mapCursedHollow) {
        return "CursedHollow";
    } else if (map == libAffx_mapShrines) {
        return "Shrines";
    } else if (map == libAffx_mapCrypts) {
        return "Crypts";
    } else if (map == libAffx_mapDragonShire) {
        return "DragonShire";
    }
    return "";
}
int libAffx_GetRarity(string rarityString) {
    string rarity = StringCase(rarityString, false);
    if (rarity == "common") {
        return libAffx_rarityCommon;
    } else if (rarity == "uncommon") {
        return libAffx_rarityUncommon;
    } else if (rarity == "rare") {
        return libAffx_rarityRare;
    } else if (rarity == "epic") {
        return libAffx_rarityEpic;
    } else if (rarity == "legendary") {
        return libAffx_rarityLegendary;
    } else if (rarity == "starter") {
        return libAffx_rarityStarter;
    } else if (rarity == "mythiccurse" || rarity == "mythic curse") {
        return libAffx_rarityMythic;
    } else if (rarity == "mythic") {
        return libAffx_rarityMythic;
    }
    return 0;
}
string libAffx_GetRarityString(int rarity) {
    if (rarity == libAffx_rarityCommon) {
        return "Common";
    } else if (rarity == libAffx_rarityUncommon) {
        return "Uncommon";
    } else if (rarity == libAffx_rarityRare) {
        return "Rare";
    } else if (rarity == libAffx_rarityEpic) {
        return "Epic";
    } else if (rarity == libAffx_rarityLegendary) {
        return "Legendary";
    } else if (rarity == libAffx_rarityStarter) {
        return "Starter";
    } else if (rarity == libAffx_rarityMythic) {
        return "Mythic Curse";
    }
    return "";
}


void libAffx_CreateAffixDialogItem(int buttonIndex, int affix, int xOffset) {    
    int yOffset = 140;
    int windowXSize = 400;
    int windowYSize = 850;
    text appendTooltip;
    
    libNtve_gf_CreateDialogItemImage(libAffx_dialogAffixSelection, windowXSize, windowYSize + 5, c_anchorTop, xOffset, yOffset - 5, null, "Assets/Textures/affix_bg.dds", c_triggerImageTypeNormal, false, Color(100, 100, 100), c_triggerBlendModeNormal);
    if (affix == 0) {
        libNtve_gf_CreateDialogItemImage(libAffx_dialogAffixSelection, windowXSize, windowYSize, c_anchorTop, xOffset, yOffset, null, "Assets/Textures/affix_bg_none.dds", c_triggerImageTypeNormal, false, Color(100, 100, 100), c_triggerBlendModeNormal);
        return;
    }
    libNtve_gf_CreateDialogItemImage(libAffx_dialogAffixSelection, windowXSize + 71, windowYSize + 60, c_anchorTop, xOffset + 2, yOffset - 30, null, "Assets/Textures/affix_bg" + libAffx_GetAffixSuffix(affix) + ".dds", c_triggerImageTypeNormal, false, Color(100, 100, 100), c_triggerBlendModeNormal);
    DialogControlCreateFromTemplate(libAffx_dialogAffixSelection, c_triggerControlTypeButton, "StandardTemplates/StandardButtonTemplate");
    libAffx_dialogAffixSelectionButton[buttonIndex] = DialogControlLastCreated();
    libNtve_gf_SetDialogItemText(libAffx_dialogAffixSelectionButton[buttonIndex], StringExternal("Button/Name/PickAffix"), PlayerGroupAll());
    DialogControlSetPosition(libAffx_dialogAffixSelectionButton[buttonIndex], PlayerGroupAll(), c_anchorTop, xOffset, yOffset + 17);

    libNtve_gf_CreateDialogItemImage(libAffx_dialogAffixSelection, 200, 200, c_anchorTop, xOffset, yOffset + 130, null, libAffx_affixes[affix].icon, c_triggerImageTypeNormal, false, Color(100, 100, 100), c_triggerBlendModeNormal);
    libNtve_gf_CreateDialogItemImage(libAffx_dialogAffixSelection, 256, 256, c_anchorTop, xOffset, yOffset + 102, null, "Assets/Textures/icon_overlay_large" + libAffx_GetAffixSuffix(affix) + ".dds", c_triggerImageTypeNormal, false, Color(100, 100, 100), c_triggerBlendModeNormal);
    
    libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 320, 100, c_anchorTop, xOffset, yOffset + 335, StringExternal("Affix/Name/" + libAffx_affixes[affix].name) + StringToText(libAffx_CountToString(libAffx_affixes[affix].count, libAffx_affixes[affix].max)), libAffx_GetAffixColor(affix), false, 1.0);
    libNtve_gf_SetDialogItemStyle(DialogControlLastCreated(), "Storm_Tutorial_Small_Centered", PlayerGroupAll());

    if (libAffx_affixes[affix].excludeChoGall && libAffx_affixes[affix].excludeChoGallForAIEffect && libAffx_choPlayer != 0) {
        appendTooltip += StringExternal("Text/ExcludeChoGallForAIEffect");
    } else if (libAffx_affixes[affix].excludeChoGall && libAffx_choPlayer != 0) {
        appendTooltip += StringExternal("Text/ExcludeChoGall");
    }
    if (libAffx_appendTooltipInSelection && libAffx_affixes[affix].count > 0 && libAffx_affixes[affix].max != 1) {
        appendTooltip += StringExternal("Affix/Tooltip/Append/" + libAffx_affixes[affix].name);
    }
    
    libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 310, 400, c_anchorTop, xOffset, yOffset + 420, StringExternal("Affix/Tooltip/" + libAffx_affixes[affix].name) + appendTooltip, ColorWithAlpha(0, 0, 0, 0), false, 1.0);
    libNtve_gf_SetDialogItemStyle(DialogControlLastCreated(), "TalentDescription", PlayerGroupAll());

    libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 310, 100, c_anchorTop, xOffset, yOffset + 745, StringExternal(libAffx_GetAffixLabel(affix)) + StringExternal(libAffx_GetAffixLabelSuffix(affix)), ColorWithAlpha(0, 0, 0, 0), false, 1.0);
    libNtve_gf_SetDialogItemStyle(DialogControlLastCreated(), "Storm_MapMechanic_MechanicCounterCentered_Small", PlayerGroupAll());
}

text libAffx_GetAffixTitle(bool curse) {
    if (curse) {
        return StringExternal("Label/Name/PickAffixCurse");
    } else {
        return StringExternal("Label/Name/PickAffix");
    }
}

void libAffx_CreateAffixDialog(bool curse) {
    DialogControlDestroyAll(libAffx_dialogAffixSelection);

    DialogCreate(500, 400, c_anchorCenter, 0, 0, true);
    libAffx_dialogAffixSelection = DialogLastCreated();
    DialogSetFullscreen(libAffx_dialogAffixSelection, true);
    DialogSetImageVisible(libAffx_dialogAffixSelection, false);
    libNtve_gf_CreateDialogItemImage(libAffx_dialogAffixSelection, 3000, 3000, c_anchorCenter, 0, 0, null, "Assets/Textures/affix_blackout2.dds", c_triggerImageTypeNormal, false, ColorWithAlpha(0, 0, 0, 0), c_triggerBlendModeNormal);

    if ((libAffx_affixes[libAffx_rolledAffixes[1]].rarity == libAffx_rarityMythic && libAffx_affixes[libAffx_rolledAffixes[1]].mythicCurse) || (libAffx_affixes[libAffx_rolledAffixes[2]].rarity == libAffx_rarityMythic && libAffx_affixes[libAffx_rolledAffixes[2]].mythicCurse) || (libAffx_affixes[libAffx_rolledAffixes[3]].rarity == libAffx_rarityMythic && libAffx_affixes[libAffx_rolledAffixes[3]].mythicCurse)) {
        libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 1000, 60, c_anchorTop, 0, 45, StringExternal("Label/Name/PickAffixCurseMythic"), ColorWithAlpha(0, 0, 0, 0), true, 1.0);
    } else {
        libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 1000, 60, c_anchorTop, 0, 45, libAffx_GetAffixTitle(curse), ColorWithAlpha(0, 0, 0, 0), true, 1.0);
    }
    libAffx_dialogAffixSelectionLabel = DialogControlLastCreated();
    libNtve_gf_SetDialogItemStyle(libAffx_dialogAffixSelectionLabel, "Storm_Map_Large_Bold_Centered", PlayerGroupAll());

    if ((libAffx_affixes[libAffx_rolledAffixes[1]].rarity == libAffx_rarityMythic && libAffx_affixes[libAffx_rolledAffixes[1]].mythicCurse) || (libAffx_affixes[libAffx_rolledAffixes[2]].rarity == libAffx_rarityMythic && libAffx_affixes[libAffx_rolledAffixes[2]].mythicCurse) || (libAffx_affixes[libAffx_rolledAffixes[3]].rarity == libAffx_rarityMythic && libAffx_affixes[libAffx_rolledAffixes[3]].mythicCurse)) {
        //libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 325, 100, c_anchorTop, 0, 1050, StringExternal("Label/Name/RerollCurseMythic"), ColorWithAlpha(0,0,0,0), false, 1.0);
    } else {
        DialogControlCreateFromTemplate(libAffx_dialogAffixSelection, c_triggerControlTypeButton, "StandardTemplates/StandardButtonTemplate");
        libAffx_dialogAffixReroll = DialogControlLastCreated();
        libNtve_gf_SetDialogItemText(libAffx_dialogAffixReroll, StringExternal("Button/Name/Reroll"), PlayerGroupAll());
        DialogControlSetPosition(libAffx_dialogAffixReroll, PlayerGroupAll(), c_anchorTop, 0, 990);
        DialogControlSetSize(libAffx_dialogAffixReroll, PlayerGroupAll(), 300, 100);
        DialogControlSetEnabled(libAffx_dialogAffixReroll, PlayerGroupAll(), true);
        if (libAffx_affixes[libAffx_rolledAffixes[1]].rarity == libAffx_rarityStarter || libAffx_affixes[libAffx_rolledAffixes[2]].rarity == libAffx_rarityStarter || libAffx_affixes[libAffx_rolledAffixes[3]].rarity == libAffx_rarityStarter) {
            DialogControlSetEnabled(libAffx_dialogAffixReroll, PlayerGroupAll(), false);
            libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 325, 100, c_anchorTop, 0, 1050, StringExternal("Label/Name/RerollStarter"), ColorWithAlpha(0,0,0,0), false, 1.0);
        } else if (curse) {
            libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 325, 100, c_anchorTop, 0, 1050, StringExternal("Label/Name/RerollCurse") + IntToText(libAffx_rerollsCurse), ColorWithAlpha(0,0,0,0), false, 1.0);
        } else {
            libNtve_gf_CreateDialogItemLabel(libAffx_dialogAffixSelection, 325, 100, c_anchorTop, 0, 1050, StringExternal("Label/Name/Reroll") + IntToText(libAffx_rerolls), ColorWithAlpha(0,0,0,0), false, 1.0); 
        }
        libNtve_gf_SetDialogItemStyle(DialogControlLastCreated(), "Storm_Tutorial_Small_Centered", PlayerGroupAll());
    }
    
}

void libAffx_ShowAffixDialog(int showCount) {
    int i;
    int affixSpacing = 425;
    int windowWidth = affixSpacing * (showCount - 1);
    if (libAffx_affixes[libAffx_rolledAffixes[1]].curse || libAffx_affixes[libAffx_rolledAffixes[2]].curse || libAffx_affixes[libAffx_rolledAffixes[3]].curse) {
        libAffx_CreateAffixDialog(true);
    } else {
        libAffx_CreateAffixDialog(false);
    }

    for (i = 1; i <= showCount; i += 1) {
        libAffx_CreateAffixDialogItem(i, libAffx_rolledAffixes[i], -windowWidth / 2 + affixSpacing * (i - 1));
    }

    DialogSetVisible(libAffx_dialogAffixSelection, PlayerGroupAll(), true);
}

