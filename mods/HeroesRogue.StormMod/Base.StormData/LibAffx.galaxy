void libAffx_AffixSetHeroAll(int affix, bool allowed) {
    int i;
    for (i = 1; i <= libAffx_maxHeroes; i += 1) {
        libAffx_affixes[affix].allowedHero[i] = allowed;
    }
}
void libAffx_AffixSetHeroSpecific(int affix, string hero) {
    int index;
    int i;
    index = libCore_gf_GetIndexFromHero(hero);
    if (index > libAffx_maxHeroes || index <= 0) {
        return;
    }
    for (i = 1; i <= libAffx_maxHeroes; i += 1) {
        libAffx_affixes[affix].allowedHero[i] = false;
    }
    libAffx_affixes[affix].allowedHero[index] = true;
}
