    libNtve_gf_CreateDialogItemLabel(libAffx_dialogOwnedAffixes, 1000, 50, c_anchorTop, 0, 10, StringExternal("Label/Name/ShowAffixes"), ColorWithAlpha(0, 0, 0, 0), true, 1.0);
    libNtve_gf_SetDialogItemStyle(DialogControlLastCreated(), "Storm_Map_Large_Bold_Centered", PlayerGroupAll());
